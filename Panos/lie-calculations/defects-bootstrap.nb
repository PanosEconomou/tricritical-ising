Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"isRedundant", "[", 
   RowBox[{"A_", ",", "i_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"rest", ",", "n", ",", "sol"}], "}"}], ",", 
    RowBox[{
     RowBox[{"n", "=", 
      RowBox[{
       RowBox[{"Dimensions", "[", "A", "]"}], "[", 
       RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rest", "=", 
      RowBox[{"Delete", "[", 
       RowBox[{"A", ",", "i"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Minimize", " ", 
        RowBox[{
         RowBox[{"A", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ".", "x"}], " ", "subject", " ", 
        RowBox[{"to", ":", 
         RowBox[{
          RowBox[{"rest", ".", "x"}], ">=", 
          RowBox[{"0", " ", "x"}], ">=", 
          RowBox[{"0", " ", 
           RowBox[{"Sum", "[", "x", "]"}]}]}]}]}], "=", 
       RowBox[{"1", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
          "normalization", " ", "to", " ", "avoid", " ", "trivial", " ", 
           "x"}], "=", "0"}], ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"sol", "=", 
      RowBox[{"LinearProgramming", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"A", "[", 
         RowBox[{"[", "i", "]"}], "]"}], ",", 
        RowBox[{"(*", 
         RowBox[{"minimize", " ", 
          RowBox[{
           RowBox[{"A", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ".", "x"}]}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"Append", "[", 
         RowBox[{"rest", ",", 
          RowBox[{"Table", "[", 
           RowBox[{"1", ",", "n"}], "]"}]}], "]"}], ",", 
        RowBox[{"(*", 
         RowBox[{"constraint", " ", "matrix"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"Append", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "1"}], "}"}], ",", 
            RowBox[{"Length", "[", "rest", "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"1", ",", "0"}], "}"}]}], "]"}], ",", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{">=", "0"}], ",", 
          RowBox[{"then", "=", "1"}]}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "Infinity"}], "}"}], ",", "n"}], "]"}]}], " ", 
       RowBox[{"(*", 
        RowBox[{"x", ">=", "0"}], "*)"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "Redundant", " ", "if", " ", "minimum", " ", "value", " ", "is"}], ">=",
        "0"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"NumberQ", "[", 
       RowBox[{"First", "@", "sol"}], "]"}], "&&", 
      RowBox[{
       RowBox[{
        RowBox[{"A", "[", 
         RowBox[{"[", "i", "]"}], "]"}], ".", "sol"}], ">=", "0"}]}]}]}], 
   "\[IndentingNewLine]", "]"}]}], "\n", 
 RowBox[{
  RowBox[{"essential", "=", 
   RowBox[{"Select", "[", 
    RowBox[{
     RowBox[{"Range", "[", 
      RowBox[{"Length", "[", "B", "]"}], "]"}], ",", 
     RowBox[{
      RowBox[{"!", 
       RowBox[{"isRedundant", "[", 
        RowBox[{"B", ",", "#"}], "]"}]}], "&"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"B", "[", 
   RowBox[{"[", "essential", "]"}], "]"}], "//", "MatrixPlot"}]}], "Input",
 CellChangeTimes->{{3.98338258812824*^9, 3.983382675145959*^9}, {
