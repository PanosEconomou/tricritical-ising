Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearDenominators", "[", "e_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"l", ",", "r", ",", "L"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"l", "=", 
       RowBox[{"e", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"r", "=", 
       RowBox[{"e", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"L", "=", 
       RowBox[{"LCM", "@@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Level", "[", 
              RowBox[{
               RowBox[{"List", "@@", "#"}], ",", "1"}], "]"}], "&"}], "/@", 
            RowBox[{"Flatten", "[", 
             RowBox[{"{", 
              RowBox[{"l", ",", "r"}], "}"}], "]"}]}], "//", "Flatten"}], "//",
           "Denominator"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"e", "[", 
        RowBox[{"[", "0", "]"}], "]"}], "[", 
       RowBox[{
        RowBox[{
         RowBox[{"L", "*", 
          RowBox[{"(", 
           RowBox[{"l", "-", "r"}], ")"}]}], "//", "ExpandAll"}], ",", "0"}], 
       "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eqn", "=", 
