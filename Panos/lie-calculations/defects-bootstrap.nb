Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "y", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Nz", "=", 
   RowBox[{"Position", "[", 
    RowBox[{"MM", ",", " ", 
     RowBox[{"_", "?", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"#", " ", "\[NotEqual]", "0"}], " ", "&"}], ")"}]}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"zeroes", "=", 
   RowBox[{"Position", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"ConjugateTranspose", "[", "s", "]"}], ".", 
        RowBox[{"ReplacePart", "[", 
         RowBox[{"z", ",", 
          RowBox[{"Thread", "[", 
           RowBox[{"nz", "\[Rule]", 
            RowBox[{"d", "[", 
             RowBox[{"[", "15", "]"}], "]"}]}], "]"}]}], "]"}], ".", "s"}], "//",
        "N"}], "//", "Chop"}], ",", 
     RowBox[{"_", "?", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"#", " ", "==", "0"}], " ", "&"}], ")"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Y", "=", 
   RowBox[{"Array", "[", 
    RowBox[{"y", ",", 
     RowBox[{"Length", "[", "Nz", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"my", "=", 
   RowBox[{"Extract", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", "s", "]"}], " ", ".", " ", 
      RowBox[{"ReplacePart", "[", 
       RowBox[{"MM", ",", 
        RowBox[{"Thread", "[", 
         RowBox[{"Nz", "\[Rule]", "Y"}], "]"}]}], "]"}], " ", ".", " ", "s"}],
      ",", "zeroes"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ay", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"CoefficientArrays", "[", 
       RowBox[{
        RowBox[{"Thread", "[", 
         RowBox[{"my", "==", "0"}], "]"}], ",", "Y"}], "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}], "//", "Simplify"}], "//", "Normal"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ay", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"Ay", "[", 
         RowBox[{"[", 
          RowBox[{"#", ",", "All"}], "]"}], "]"}], "&"}], "/@", 
       RowBox[{"(", 
        RowBox[{"DeleteMissing", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"FirstPosition", "[", 
             RowBox[{"#", ",", "1"}], "]"}], "&"}], "/@", " ", 
           RowBox[{"RowReduce", "[", 
            RowBox[{"Transpose", "[", 
             RowBox[{"Chop", "[", 
              RowBox[{"N", "[", "Ay", "]"}], "]"}], "]"}], "]"}]}], "]"}], 
         "]"}], ")"}]}], " ", ")"}], "//", "FullSimplify"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"LinearSolve", "[", 
    RowBox[{
     RowBox[{"ay", "//", "N"}], ",", 
     RowBox[{
      RowBox[{"0", "&"}], "/@", "Y"}]}], "]"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"act", "=", 
   RowBox[{"RootApproximant", "/@", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"NullSpace", "[", 
       RowBox[{"ay", "//", "N"}], "]"}], "//", "Chop"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"act", "/", 
   RowBox[{"Min", "[", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Abs", "[", "act", "]"}], "//", "Flatten"}], ",", " ", 
      RowBox[{
       RowBox[{"#", "!=", "0"}], "&"}]}], "]"}], "]"}]}], " ", "//", 
  "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"N", "[", "Ay", "]"}], "]"}], "//", "RowReduce"}], "//", 
  "MatrixPlot"}], "\[IndentingNewLine]", 
