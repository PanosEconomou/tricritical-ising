Cell[BoxData[{
 RowBox[{
  RowBox[{"b", "=", 
   RowBox[{
    RowBox[{"Inverse", "[", 
     RowBox[{"N", "[", "a", "]"}], "]"}], "//", "Chop"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", 
   RowBox[{"RootApproximant", "/@", "b"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "=", 
   RowBox[{
    RowBox[{"b", ".", "X"}], "//", "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"m", "=", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"ConjugateTranspose", "[", "s", "]"}], " ", ".", " ", 
     RowBox[{"ReplacePart", "[", 
      RowBox[{"z", ",", 
       RowBox[{"Thread", "[", 
        RowBox[{"nz", "\[Rule]", "y"}], "]"}]}], "]"}], " ", ".", " ", "s"}], 
    "]"}]}], " ", ";"}]}], "Input",
 CellChangeTimes->{{3.98337745784221*^9, 3.98337746665298*^9}, {
  3.983377537827364*^9, 3.9833775807848663`*^9}, {3.983387524205844*^9, 
  3.983387524573976*^9}},
 CellLabel->
  "In[688]:=",ExpressionUUID->"08efbad1-6661-4bb1-93e9-5724cb35089f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearDenominators", "[", "e_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"l", ",", "r", ",", "L"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"l", "=", 
       RowBox[{"e", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"r", "=", 
       RowBox[{"e", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"L", "=", 
       RowBox[{"LCM", "@@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Level", "[", 
              RowBox[{
               RowBox[{"List", "@@", "#"}], ",", "1"}], "]"}], "&"}], "/@", 
            RowBox[{"Flatten", "[", 
             RowBox[{"{", 
              RowBox[{"l", ",", "r"}], "}"}], "]"}]}], "//", "Flatten"}], "//",
           "Denominator"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"e", "[", 
        RowBox[{"[", "0", "]"}], "]"}], "[", 
       RowBox[{
        RowBox[{
         RowBox[{"L", "*", 
          RowBox[{"(", 
           RowBox[{"l", "-", "r"}], ")"}]}], "//", "ExpandAll"}], ",", "0"}], 
       "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eqn", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"#", " ", "\[GreaterEqual]", " ", "0"}], " ", "&"}], " ", "/@", 
