Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "y", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Nz", "=", 
   RowBox[{"Position", "[", 
    RowBox[{"MM", ",", " ", 
     RowBox[{"_", "?", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"#", " ", "\[NotEqual]", "0"}], " ", "&"}], ")"}]}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"zeroes", "=", 
   RowBox[{"Position", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"ConjugateTranspose", "[", "s", "]"}], ".", 
        RowBox[{"ReplacePart", "[", 
         RowBox[{"z", ",", 
          RowBox[{"Thread", "[", 
           RowBox[{"nz", "\[Rule]", 
            RowBox[{"d", "[", 
             RowBox[{"[", "4", "]"}], "]"}]}], "]"}]}], "]"}], ".", "s"}], "//",
        "N"}], "//", "Chop"}], ",", 
     RowBox[{"_", "?", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"#", " ", "==", "0"}], " ", "&"}], ")"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Y", "=", 
   RowBox[{"Array", "[", 
    RowBox[{"y", ",", 
     RowBox[{"Length", "[", "Nz", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"my", "=", 
   RowBox[{"Extract", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", "s", "]"}], " ", ".", " ", 
      RowBox[{"ReplacePart", "[", 
       RowBox[{"MM", ",", 
        RowBox[{"Thread", "[", 
         RowBox[{"Nz", "\[Rule]", "Y"}], "]"}]}], "]"}], " ", ".", " ", "s"}],
      ",", "zeroes"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ay", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"CoefficientArrays", "[", 
       RowBox[{
        RowBox[{"Thread", "[", 
         RowBox[{"my", "==", "0"}], "]"}], ",", "Y"}], "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}], "//", "Simplify"}], "//", "Normal"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ay", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Ay", "[", 
        RowBox[{"[", 
         RowBox[{"#", ",", "All"}], "]"}], "]"}], "&"}], "/@", 
      RowBox[{"(", 
       RowBox[{"DeleteMissing", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"FirstPosition", "[", 
            RowBox[{"#", ",", "1"}], "]"}], "&"}], "/@", " ", 
          RowBox[{"RowReduce", "[", 
           RowBox[{"Transpose", "[", 
            RowBox[{"Chop", "[", 
             RowBox[{"N", "[", "Ay", "]"}], "]"}], "]"}], "]"}]}], "]"}], 
        "]"}], ")"}]}], " ", ")"}], "//", "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"N", "[", "Ay", "]"}], "]"}], "//", "RowReduce"}], "//", 
  "MatrixPlot"}], "\[IndentingNewLine]", 
 RowBox[{"ay", "//", "MatrixPlot"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"ReplacePart", "[", 
    RowBox[{"MM", ",", 
     RowBox[{"Thread", "[", 
      RowBox[{"Nz", "\[Rule]", "Y"}], "]"}]}], "]"}], "*)"}]}]}], "Input",
