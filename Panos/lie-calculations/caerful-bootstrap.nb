      "their", " ", "self", " ", "fusion", " ", "to", " ", "further", " ", 
     "constrain", " ", "them"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ConstrainWithSelfFusion", "[", "defects_", "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vars", "=", 
