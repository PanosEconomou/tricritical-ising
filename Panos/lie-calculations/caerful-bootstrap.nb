Cell[CellGroupData[{

Cell["Search Fusion Rules", "Subsection",
 CellChangeTimes->{{3.985357275402993*^9, 
  3.985357279185727*^9}},ExpressionUUID->"95bd5ae3-dbd7-4f6c-a4b6-\
31f282ea2812"],

Cell["\<\
Since we can obtain some partial information for the fusion rules among \
defects belonging to each family we can extract and list them in the following\
\>", "Text",
 CellChangeTimes->{{3.9853572836175137`*^9, 3.985357326258501*^9}, {
  3.98560630134757*^9, 
  3.985606303514105*^9}},ExpressionUUID->"996b05f4-1d1c-44b3-bb68-\
db0c4e77164b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Takes", " ", "a", " ", "matrix", " ", "M", " ", "and", " ", "a", " ", 
    "vector", " ", "v", " ", "and", " ", "finds", " ", "all", " ", "possible",
     " ", "nonnegative", " ", "integer", " ", "combinations", " ", "of", " ", 
    "rows", " ", "of", " ", "M", " ", "that", " ", "sum", " ", "to", " ", 
    "v"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"FindIntegerCombinations", "[", 
      RowBox[{"M_", ",", "v_"}], "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"n", "=", 
          RowBox[{"Length", "[", "M", "]"}]}], ",", 
         RowBox[{"m", "=", 
          RowBox[{"Length", "[", "v", "]"}]}], ",", 
         RowBox[{"MT", "=", 
          RowBox[{"Transpose", "[", 
           RowBox[{"N", "[", "M", "]"}], "]"}]}], ",", "ubounds", ",", " ", 
         "enumerate", ",", 
         RowBox[{"results", "=", 
          RowBox[{"{", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Use", " ", "linear", " ", "programming", " ", "to", " ", "estimate", 
         " ", "the", " ", "maximum", " ", "number", " ", "a", " ", "row", " ",
          "can", " ", "be", " ", "added", " ", "in", " ", "a", " ", 
         "solution", " ", "for", " ", "v"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ubounds", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Module", "[", 
            RowBox[{
             RowBox[{"{", "sol", "}"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"sol", "=", 
               RowBox[{"Quiet", "[", 
                RowBox[{"LinearProgramming", "[", 
                 RowBox[{
                  RowBox[{"-", 
                   RowBox[{"UnitVector", "[", 
                    RowBox[{"n", ",", "i"}], "]"}]}], ",", "MT", ",", 
                  RowBox[{"Transpose", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"N", "[", "v", "]"}], ",", 
                    RowBox[{"ConstantArray", "[", 
                    RowBox[{"0", ",", "m"}], "]"}]}], "}"}], "]"}], ",", 
                  RowBox[{"ConstantArray", "[", 
                   RowBox[{"0", ",", "n"}], "]"}]}], "]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"VectorQ", "[", "sol", "]"}], ",", 
                RowBox[{"Max", "[", 
                 RowBox[{"0", ",", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"sol", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "//", "Chop"}], "//", 
                   "RootApproximant"}]}], "]"}], ",", "sol"}], "]"}]}]}], 
            "]"}], "\[IndentingNewLine]", ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "n"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Explore", " ", "the", " ", "rest", " ", "recursively", " ", "until",
           " ", "you", " ", "hit", " ", "zero"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"enumerate", "[", 
          RowBox[{"rem_", ",", "idx_", ",", "current_"}], "]"}], ":=", 
         RowBox[{"Which", "[", 
          RowBox[{
           RowBox[{"idx", ">", "n"}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Chop", "[", 
               RowBox[{"N", "[", "rem", "]"}], "]"}], "==", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"0", ",", "m"}], "]"}]}], ",", 
             RowBox[{"AppendTo", "[", 
              RowBox[{"results", ",", "current"}], "]"}]}], "]"}], ",", 
           "True", ",", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"enumerate", "[", 
              RowBox[{
               RowBox[{"rem", "-", 
                RowBox[{"k", "*", 
                 RowBox[{"M", "[", 
                  RowBox[{"[", "idx", "]"}], "]"}]}]}], ",", 
               RowBox[{"idx", "+", "1"}], ",", 
               RowBox[{"Append", "[", 
                RowBox[{"current", ",", "k"}], "]"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"k", ",", "0", ",", 
               RowBox[{"ubounds", "[", 
                RowBox[{"[", "idx", "]"}], "]"}]}], "}"}]}], "]"}]}], "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"enumerate", "[", 
         RowBox[{"v", ",", "1", ",", 
          RowBox[{"{", "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
        "results"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Store", " ", "maximum", " ", "possible", " ", "fusion", " ", "pathways", 
     " ", "between", " ", "families"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"fusionPathways", "=", 
      RowBox[{"ParallelArray", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"FindIntegerCombinations", "[", 
          RowBox[{
           RowBox[{"familiesNondeg", "//", "N"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"familiesNondeg", "[", 
              RowBox[{"[", "#1", "]"}], "]"}], "*", 
             RowBox[{"familiesNondeg", "[", 
              RowBox[{"[", "#2", "]"}], "]"}]}], "//", "N"}]}], "]"}], "&"}], 
        ",", 
        RowBox[{"{", 
         RowBox[{"famNum", ",", " ", "famNum"}], "}"}]}], "]"}]}], ";"}], 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.9853573293745947`*^9, 3.985357355083605*^9}, {
   3.9853574421551*^9, 3.985357630591894*^9}, {3.985357671648127*^9, 
   3.985357804412588*^9}, {3.985357862270877*^9, 3.9853578833133993`*^9}, {
   3.985358382954053*^9, 3.9853584141917133`*^9}, {3.9853586361387167`*^9, 
   3.985358637795376*^9}, 3.985358929128791*^9, 3.985359046771819*^9, {
   3.985359145952524*^9, 3.9853592176757097`*^9}, 3.985359302909829*^9, {
   3.985359396971925*^9, 3.9853593973895683`*^9}, {3.985359491877936*^9, 
   3.985359496260504*^9}, 3.985367914646564*^9, {3.9853680159323*^9, 
   3.985368045442729*^9}, {3.985368269181342*^9, 3.985368269570895*^9}, {
