Cell[CellGroupData[{

Cell["Obtaining Modular Bootstrap Equations", "Subsection",
 CellChangeTimes->{{3.985351008868718*^9, 
  3.985351054383965*^9}},ExpressionUUID->"3894c1b6-35c8-4321-a689-\
26d75a27f199"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SolveModularBootstrap", "[", 
    RowBox[{"z_", ",", "s_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"X", ",", "x", ",", "nz", ",", " ", 
       RowBox[{"st", "=", 
        RowBox[{"ConjugateTranspose", "[", "s", "]"}]}], ",", "m", ",", 
       "coeff", ",", "A", ",", " ", "eqn", ",", "multipliers", ",", "basis"}],
       "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Needs", "[", "\"\<math4ti2`\>\"", "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Get", " ", "Nonzero", " ", "positions", " ", "on", " ", "the", " ", 
        "Mass", " ", "Matrix", " ", "and", " ", "replace", " ", "them", " ", 
        "with", " ", "variables"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"nz", "=", 
       RowBox[{"Position", "[", 
        RowBox[{"z", ",", " ", 
         RowBox[{"_", "?", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"#", " ", "!=", "0"}], " ", "&"}], ")"}]}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"X", "=", 
       RowBox[{"Array", "[", 
        RowBox[{"x", ",", 
         RowBox[{"Length", "[", "nz", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"m", "=", 
       RowBox[{
        RowBox[{"st", ".", " ", 
         RowBox[{"ReplacePart", "[", 
          RowBox[{"z", ",", 
           RowBox[{"Thread", "[", 
            RowBox[{"nz", "\[Rule]", "X"}], "]"}]}], "]"}], " ", ".", " ", 
         "s"}], "//", "Flatten"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Extract", " ", "the", " ", "coefficients", " ", "for", " ", "each", " ",
         "variable", " ", "in", " ", "the", " ", "S", " ", "transformed", " ",
         "Mass", " ", "Matrix"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"coeff", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"CoefficientArrays", "[", 
            RowBox[{"m", ",", "X"}], "]"}], "[", 
           RowBox[{"[", "2", "]"}], "]"}], "//", "Normal"}], "//", "N"}], "//",
         "Chop"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Pick", " ", "the", " ", "maximum", " ", "number", " ", "of", " ", 
        "independent", " ", "equations", " ", "and", " ", "invert", " ", 
        "them"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"A", "=", 
       RowBox[{"Chop", "@", 
        RowBox[{"Inverse", "@", 
         RowBox[{"N", "@", 
          RowBox[{"coeff", "[", 
           RowBox[{"[", 
            RowBox[{"Flatten", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"FirstPosition", "[", 
                RowBox[{"#", ",", "1"}], "]"}], "&"}], "/@", 
              RowBox[{"DeleteCases", "[", 
               RowBox[{
                RowBox[{"Chop", "@", 
                 RowBox[{"RowReduce", "@", 
                  RowBox[{"N", "@", 
                   RowBox[{"Transpose", "@", "coeff"}]}]}]}], ",", 
                RowBox[{"{", 
                 RowBox[{"0", ".."}], "}"}]}], "]"}]}], "]"}], "]"}], 
           "]"}]}]}]}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
        "Plug", " ", "them", " ", "back", " ", "in", " ", "to", " ", "the", " ",
          "S"}], "-", 
        RowBox[{
        "Transformed", " ", "Modular", " ", "Matrix", " ", "to", " ", 
         "obtain", " ", "constraints"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"m", "=", 
       RowBox[{
        RowBox[{"Chop", "[", 
         RowBox[{"N", "[", 
          RowBox[{"coeff", ".", "A"}], "]"}], "]"}], ".", "X"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"A", "=", 
       RowBox[{"RootApproximant", "[", "A", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"eqn", "=", 
       RowBox[{"DeleteDuplicates", "@", 
        RowBox[{"Rationalize", "@", 
         RowBox[{"Chop", "@", 
          RowBox[{"Expand", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"#", ">=", "0"}], "&"}], "/@", "m"}], "]"}]}]}]}]}], ";",
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Rescale", " ", "any", " ", "variables", " ", "that", " ", "need", " ",
         "it", " ", "so", " ", "that", " ", "the", " ", "system", " ", "has", 
        " ", "integer", " ", "coefficients"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"multipliers", "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Min", "@", 
           RowBox[{"Cases", "[", 
            RowBox[{"eqn", ",", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"a_.", "*", "#"}], ")"}], ">=", "0"}], ":>", "a"}]}], 
            "]"}]}], "^", 
          RowBox[{"-", "1"}]}], "&"}], "/@", "X"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"eqn", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "0", "]"}], "]"}], "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Subtract", "@@", "#"}], "//", "ExpandAll"}], ",", "0"}],
            "]"}], ")"}], "&"}], "/@", 
        RowBox[{"(", 
         RowBox[{"eqn", "/.", " ", 
          RowBox[{"Thread", "[", 
           RowBox[{"X", "->", 
            RowBox[{"multipliers", "*", "X"}]}], "]"}]}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"Use", " ", "Z"}], "-", 
        RowBox[{
        "Solve", " ", "to", " ", "find", " ", "a", " ", "basis", " ", "of", " ",
          "simple", " ", "objects"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"basis", " ", "=", 
       RowBox[{
        RowBox[{"math4ti2`zsolve", "[", "eqn", "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"A", ".", " ", 
          RowBox[{"(", 
           RowBox[{"multipliers", "*", "#"}], ")"}]}], "&"}], "/@", "basis"}],
        " ", "//", "FullSimplify"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"families", "=", 
   RowBox[{"Sort", "[", 
    RowBox[{
     RowBox[{"SolveModularBootstrap", "[", 
      RowBox[{"z", ",", "s"}], "]"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"#1", "[", 
        RowBox[{"[", "1", "]"}], "]"}], " ", "<=", " ", 
       RowBox[{"#2", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "&"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"families", "//", "Transpose"}], "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"noninvertibleFamilies", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"families", ",", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "!=", "1"}], "&"}]}], "]"}]}], 
  ";"}]}], "Input",
