Cell[CellGroupData[{

Cell["Automatic Bootstrap", "Title",
 CellChangeTimes->{{3.98587156065201*^9, 3.985871575971093*^9}, {
  3.985871621241683*^9, 
  3.985871629974016*^9}},ExpressionUUID->"ae133458-673b-474a-9432-\
3b29c27a0ab9"],

Cell["\<\
Now we have the building blocks to do the pruning for the entire family of \
fusion rules. The only things we need to figure out now \
are:\[LineSeparator]1. Keeping track of gauge degrees of freedom efficiently
2. Updating Gauge Transformation based on the current solved defects.
3. Keep track of the growing collection of defect lines.\
\>", "Text",
 CellChangeTimes->{{3.9858716326298637`*^9, 3.9858716484396563`*^9}, {
  3.985871938818655*^9, 3.985871948985817*^9}, {3.985871989311371*^9, 
  3.985872105050642*^9}, {3.985872234915187*^9, 
  3.985872240934265*^9}},ExpressionUUID->"013f97c6-b8d4-49de-bf76-\
32f7d0527088"],

Cell[CellGroupData[{

Cell["Structures to keep track of the problem", "Section",
 CellChangeTimes->{{3.985872246294042*^9, 3.985872248901875*^9}, {
  3.985872280853262*^9, 
  3.9858722950050907`*^9}},ExpressionUUID->"5710fd62-7a4c-4cfc-8a07-\
b99cf5dbe55e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "A", " ", "collection", " ", "of", " ", "all", " ", "solved", " ", 
    "defects", " ", "in", " ", "the", " ", "theory"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"L", "=", 
     RowBox[{"GetInvertibleLines", "[", "]"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"~", "Join", "~", 
      RowBox[{"(", 
       RowBox[{"res", "/.", 
        RowBox[{"Thread", "[", 
         RowBox[{
          RowBox[{"Variables", "[", "res", "]"}], "->", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Unique", "[", "\"\<x\>\"", "]"}], ",", 
            RowBox[{"Length", "@", 
             RowBox[{"Variables", "@", "res"}]}]}], "]"}]}], "]"}]}], ")"}]}],
      ";"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Automatic", " ", "Gauge", " ", "Transformations"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gaugeVars", "=", " ", 
     RowBox[{"getVars", "[", "L", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gaugeVarRules", "=", 
     RowBox[{"Thread", "[", 
      RowBox[{"gaugeVars", "!=", "0"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GetGeneralGaugeTransform", "[", 
      RowBox[{"L_", ",", "gaugeVars_", ",", "gaugeVarRules_", ",", 
       RowBox[{"var_", ":", "P"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Lp", ",", "LpInvertibleQ", ",", "Lpp"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Build", " ", "a", " ", "General", " ", "Gauge", " ", 
         "Transformation"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Lp", "=", 
         RowBox[{"Array", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Which", "[", 
             RowBox[{
              RowBox[{"!", 
               RowBox[{"deg", "[", "#", "]"}]}], ",", "1", ",", 
              RowBox[{"deg", "[", "#", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"var", "[", 
                   RowBox[{"#", ",", "1"}], "]"}], " ", ",", 
                  RowBox[{"var", "[", 
                   RowBox[{"#", ",", "2"}], "]"}]}], " ", "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"var", "[", 
                   RowBox[{"#", ",", "3"}], "]"}], ",", 
                  RowBox[{"var", "[", 
                   RowBox[{"#", ",", "4"}], "]"}]}], "}"}]}], "}"}]}], "]"}], 
            "&"}], ",", "famNum"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Lp", "=", 
         RowBox[{"(", 
          RowBox[{"Lp", " ", "//.", 
           RowBox[{"{", 
            RowBox[{"Assuming", "[", 
             RowBox[{"gaugeVarRules", ",", 
              RowBox[{"ToRules", "[", 
               RowBox[{"Reduce", "[", 
                RowBox[{
                 RowBox[{"And", "@@", 
                  RowBox[{"Thread", "[", 
                   RowBox[{
                    RowBox[{"Flatten", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Lp", "\[CircleTimes]", "#"}], " ", "-", 
                    RowBox[{"#", "\[CircleTimes]", "Lp"}]}], ")"}], "&"}], "/@",
                     "L"}], "]"}], "==", "0"}], "]"}]}], ",", 
                 RowBox[{"Backsubstitution", "->", "True"}]}], "]"}], "]"}]}],
              "]"}], "}"}]}], ")"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Lpp", "=", 
         RowBox[{"DeleteElements", "[", 
          RowBox[{
           RowBox[{"Variables", "[", "Lp", "]"}], ",", "gaugeVars"}], "]"}]}],
         ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Checks", " ", "if", " ", "Lp", " ", "is", " ", "invertible", " ", 
          "for", " ", "a", " ", "given", " ", "numerical", " ", "set", " ", 
          "of", " ", "P", " ", "variables"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"vars", "=", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"Unique", "[", "\"\<p\>\"", "]"}], ",", 
               RowBox[{"Length", "@", "Lpp"}]}], "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"varsg", "=", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"Unique", "[", "\"\<g\>\"", "]"}], ",", 
               RowBox[{"Length", "@", "gaugeVars"}]}], "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"invertibleLp", "=", 
             RowBox[{"And", "@@", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"Simplify", "@", 
                   RowBox[{"Not", "@", 
                    RowBox[{"Reduce", "[", 
                    RowBox[{"Or", "@@", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Which", "[", 
                    RowBox[{
                    RowBox[{"MatrixQ", "[", "#", "]"}], ",", 
                    RowBox[{
                    RowBox[{"Det", "[", "#", "]"}], "==", "0"}], ",", "True", 
                    ",", 
                    RowBox[{"#", "==", "0"}]}], "]"}], "&"}], "/@", "#"}], 
                    ")"}]}], "]"}]}]}], ")"}], "&"}], "/@", "Lp"}], 
               ")"}]}]}]}], "\[IndentingNewLine]", "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"invertibleLp", "=", 
            RowBox[{
             RowBox[{"invertibleLp", "/.", 
              RowBox[{"Thread", "[", 
               RowBox[{"Lpp", "->", "vars"}], "]"}]}], "/.", 
             RowBox[{"Thread", "[", 
              RowBox[{"gaugeVars", "->", "varsg"}], "]"}]}]}], ";", "\n", 
           "\t", 
           RowBox[{"Echo", "[", "invertibleLp", "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"LpInvertibleQ", ":=", 
            RowBox[{"Function", "@@", 
             RowBox[{"{", 
              RowBox[{"vars", ",", 
               RowBox[{"Assuming", "[", 
                RowBox[{
                 RowBox[{"gaugeVarRules", "/.", 
                  RowBox[{"Thread", "[", 
                   RowBox[{"gaugeVars", "->", "varsg"}], "]"}]}], ",", 
                 RowBox[{"Simplify", "[", 
                  RowBox[{"Evaluate", "[", "invertibleLp", "]"}], "]"}]}], 
                "]"}]}], "}"}]}]}]}]}], "\[IndentingNewLine]", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"Lp", ",", "Lpp", ",", "LpInvertibleQ"}], "}"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Calculate", " ", "Conjugate", " ", "Orbit"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", "conjugateOrbitS", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"conjugateOrbitS", "[", 
      RowBox[{"x_", ",", 
       RowBox[{"Li_", ":", "Li"}], ",", 
       RowBox[{"gaugeVarRules_", ":", "gaugeVarRules"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"conjugateOrbitS", "[", 
       RowBox[{"x", ",", "Li", ",", "gaugeVarRules"}], "]"}], "=", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Simplify", "[", 
          RowBox[{
           RowBox[{"#", "\[CircleTimes]", "x", "\[CircleTimes]", 
            RowBox[{"(", 
             RowBox[{"inv", "/@", "#"}], ")"}]}], ",", 
           RowBox[{"Assumptions", "->", "gaugeVarRules"}]}], "]"}], "&"}], "/@",
         "Li"}], "]"}]}]}], ";"}]}]}]], "Input",
