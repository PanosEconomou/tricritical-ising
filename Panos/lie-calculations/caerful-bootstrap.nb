   3.985368578092824*^9, 3.985368632947525*^9, {3.985368679772201*^9, 
   3.9853686824588947`*^9}, 3.98536886465869*^9, {3.985369008854233*^9, 
   3.985369030225857*^9}, {3.985369089335786*^9, 3.985369096241766*^9}, 
   3.985369170579146*^9, 3.985369229851967*^9, {3.9853692909880867`*^9, 
   3.985369298347982*^9}, {3.985369391260331*^9, 3.985369391947888*^9}, {
   3.985369458276133*^9, 3.9853694595816917`*^9}, {3.985370011670536*^9, 
   3.985370015149963*^9}, {3.98537004988813*^9, 3.9853700678891478`*^9}, {
   3.985370155486998*^9, 3.9853701561090603`*^9}, {3.985370239620748*^9, 
   3.9853702520206203`*^9}, {3.9853703563012247`*^9, 
   3.9853703609254436`*^9}, {3.98537039929458*^9, 3.985370401893641*^9}, {
   3.98560620346139*^9, 3.9856062208208437`*^9}, 3.985606268267918*^9, {
   3.985623568082878*^9, 3.985623568578953*^9}, {3.9857033976719923`*^9, 
   3.9857033995942907`*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"d4bc87e6-b41e-4a78-9c92-d1e21847cbd2"]
