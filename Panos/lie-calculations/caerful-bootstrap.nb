              RowBox[{
               RowBox[{
                RowBox[{"N", "[", 
                 RowBox[{"#", ".", "families"}], "]"}], "&"}], "/@", "#"}]}], 
             "}"}], "]"}], "&"}], "/@", 
          RowBox[{"Tuples", "[", 
           RowBox[{"fusions", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", " ", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "Convert", " ", "to", " ", "equations", " ", "for", " ", "their", " ",
            "traces"}], ",", " ", 
          RowBox[{
          "then", " ", "solve", " ", "and", " ", "plug", " ", "back", " ", 
           "in"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"fusions", "=", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Flatten", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"MapThread", "[", "Equal", "]"}], "/@", "#"}], ",", 
