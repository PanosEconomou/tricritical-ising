Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"nz", "=", 
   RowBox[{"Position", "[", 
    RowBox[{"z", ",", " ", 
     RowBox[{"_", "?", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"#", " ", "!=", "0"}], " ", "&"}], ")"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"X", "=", 
   RowBox[{"Array", "[", 
    RowBox[{"x", ",", 
     RowBox[{"Length", "[", "nz", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"m", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"ConjugateTranspose", "[", "s", "]"}], " ", ".", " ", 
     RowBox[{"ReplacePart", "[", 
      RowBox[{"z", ",", 
       RowBox[{"Thread", "[", 
        RowBox[{"nz", "\[Rule]", "X"}], "]"}]}], "]"}], " ", ".", " ", "s"}], 
    "  ", "//", "Flatten"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"A", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"CoefficientArrays", "[", 
       RowBox[{
        RowBox[{"Thread", "[", 
         RowBox[{"m", "==", "0"}], "]"}], ",", "X"}], "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}], "//", "Simplify"}], "//", "Normal"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"a", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"A", "[", 
        RowBox[{"[", 
         RowBox[{"#", ",", "All"}], "]"}], "]"}], "&"}], "/@", 
      RowBox[{"(", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"FirstPosition", "[", 
           RowBox[{"#", ",", "1"}], "]"}], "&"}], "/@", " ", 
         RowBox[{"RowReduce", "[", 
          RowBox[{"Transpose", "[", 
           RowBox[{"Chop", "[", 
            RowBox[{"N", "[", "A", "]"}], "]"}], "]"}], "]"}]}], "]"}], 
       ")"}]}], " ", ")"}], "//", "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Transpose", "[", 
    RowBox[{"N", "[", "A", "]"}], "]"}], "//", "RowReduce"}], "//", 
  "MatrixPlot"}], "\[IndentingNewLine]", 
 RowBox[{"a", "//", "MatrixPlot"}]}], "Input",
