Cell[CellGroupData[{

Cell["Constrain Using Invertible Defect Fusion", "Subsection",
 CellChangeTimes->{{3.985606375629017*^9, 
  3.9856064134842463`*^9}},ExpressionUUID->"6485ac9b-e864-4737-aa9d-\
986958320d4c"],

Cell["\<\
Use fusion rules with invertible defects to constrain the possible candidates \
for lines in a family up to fusion by invertible and gauge transformations\
\>", "Text",
 CellChangeTimes->{{3.9856064203802557`*^9, 3.985606466079618*^9}, {
  3.9856236593559217`*^9, 
  3.985623660114664*^9}},ExpressionUUID->"d637bdf1-f948-4f89-9f26-\
511a108a7fbd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Functions", " ", "to", " ", "create", " ", "a", " ", "defect", " ", 
     "with", " ", "free", " ", "variables", " ", "and", " ", "given", " ", 
     "traces"}], ",", " ", 
    RowBox[{
    "as", " ", "well", " ", "to", " ", "extract", " ", "the", " ", 
     "variables"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"l", "[", 
      RowBox[{"traces_", ",", "var_"}], "]"}], ":=", " ", 
     RowBox[{"Array", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Which", "[", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"deg", "[", "#", "]"}]}], ",", 
          RowBox[{"traces", "[", 
           RowBox[{"[", "#", "]"}], "]"}], ",", 
          RowBox[{"deg", "[", "#", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"var", "[", 
               RowBox[{"#", ",", "1"}], "]"}], " ", ",", 
              RowBox[{"var", "[", 
               RowBox[{"#", ",", "2"}], "]"}]}], " ", "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"var", "[", 
               RowBox[{"#", ",", "3"}], "]"}], ",", 
              RowBox[{
               RowBox[{"traces", "[", 
                RowBox[{"[", "#", "]"}], "]"}], "-", 
               RowBox[{"var", "[", 
                RowBox[{"#", ",", "1"}], "]"}]}]}], "}"}]}], "}"}]}], "]"}], 
        "&"}], ",", 
       RowBox[{"Length", "@", "traces"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"getVars", "[", "x_", "]"}], ":=", 
     RowBox[{
      RowBox[{"x", "//", "Flatten"}], "//", "Variables"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Cleans", " ", "up", " ", "some", " ", "variables"}], " ", "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"CanonicalizeVars", "[", "list_", "]"}], ":=", 
     RowBox[{"Array", "[", 
      RowBox[{
       RowBox[{"i", "|->", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "vars", "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"vars", "=", 
            RowBox[{"getVars", "@", 
             RowBox[{"list", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
           
           RowBox[{
            RowBox[{"list", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "/.", 
            RowBox[{"MapIndexed", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"#", "->", 
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "0", "]"}], "]"}], "[", 
                 RowBox[{"i", ",", 
                  RowBox[{"#2", "[", 
                   RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], "&"}], ",", 
              "vars"}], "]"}]}]}]}], "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"Length", "@", "list"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Given", " ", "a", " ", "defect", " ", "with", " ", "free", " ", 
      "variables"}], ",", " ", 
     RowBox[{
     "it", " ", "outputs", " ", "a", " ", "list", " ", "of", " ", "the", " ", 
      "variables", " ", "that", " ", "are", " ", "pure", " ", "gauge"}]}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GaugeParams", "[", "x_", "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vars", "=", 
          RowBox[{"getVars", "@", "x"}]}], ",", "u"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Pick", "[", 
        RowBox[{"vars", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"GaugeQ", "[", 
            RowBox[{"x", ",", 
             RowBox[{"x", "/.", " ", 
              RowBox[{"#", "->", "\[FormalZ]"}]}]}], "]"}], "&"}], "/@", 
          "vars"}]}], "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Provide", " ", "candidates", " ", "for", " ", "the", " ", 
     "representation", " ", "of", " ", "a", " ", "defect", " ", "line", " ", 
     "up", " ", "to", " ", "fusion", " ", "with", " ", "invertible", " ", 
     "lines", " ", "and", " ", "gauge", " ", "transformation"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ConstrainWithInvertibles", "[", 
      RowBox[{"traces_", ",", "var_"}], "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", " ", 
        RowBox[{
         RowBox[{"defect", "=", 
          RowBox[{"l", "[", 
           RowBox[{"traces", ",", "var"}], "]"}]}], ",", "vars", ",", 
         "products", ",", "fusions", ",", "result"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"vars", "=", 
         RowBox[{"getVars", "[", "defect", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"SetAttributes", "[", 
         RowBox[{"var", ",", "NHoldAll"}], "]"}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Calculate", " ", "the", " ", "possible", " ", "fusion", " ", 
          "channels", " ", "with", " ", "the", " ", "invertible", " ", 
          "defects"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"products", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"#", "\[CircleTimes]", "defect"}], ")"}], "&"}], "/@", 
            "Li"}]}], ";"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"products", "=", 
         RowBox[{
          RowBox[{"productOrbit", "[", "defect", "]"}], "//", 
          "DeleteDuplicates"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"fusions", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"MapThread", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"N", "[", 
                 RowBox[{"tr", "/@", "#1"}], "]"}], ",", 
                RowBox[{"FindIntegerCombinations", "[", 
                 RowBox[{"familiesNondeg", ",", 
                  RowBox[{"#2", "[", 
                   RowBox[{"[", "nondegPos", "]"}], "]"}]}], "]"}]}], "}"}], 
              "&"}], ",", 
             RowBox[{"{", 
              RowBox[{"products", ",", "products"}], "}"}]}], "]"}], "//", 
           "DeleteDuplicates"}], "//", "Time"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"fusions", "=", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"fusions", "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"N", "[", 
                  RowBox[{"#", ".", "families"}], "]"}], "&"}], "/@", "#"}]}],
               "}"}], "]"}], "&"}], "/@", 
           RowBox[{"Tuples", "[", 
            RowBox[{"fusions", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], "//", 
          "Time"}]}], ";", "\[IndentingNewLine]", " ", "\[IndentingNewLine]", 
        
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "Convert", " ", "to", " ", "equations", " ", "for", " ", "their", " ",
            "traces"}], ",", " ", 
          RowBox[{
          "then", " ", "solve", " ", "and", " ", "plug", " ", "back", " ", 
           "in"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"fusions", "=", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Flatten", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"MapThread", "[", "Equal", "]"}], "/@", "#"}], ",", 
              "1"}], "]"}], "&"}], ",", "fusions"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"result", "=", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"DeleteCases", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"defect", "//.", "#"}], ")"}], "&"}], "/@", 
                 RowBox[{"(", 
                  RowBox[{"Quiet", "@", 
                   RowBox[{"Solve", "[", 
                    RowBox[{"#", ",", "vars"}], "]"}]}], ")"}]}], ")"}], 
               "&"}], "/@", "fusions"}], ",", 
             RowBox[{"{", "}"}]}], "]"}], ",", "1"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "Convert", " ", "numerical", " ", "constants", " ", "back", " ", 
           "to", " ", "algebraic", " ", "form"}], ",", " ", 
          RowBox[{"preserving", " ", "variables"}]}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"result", "=", 
         RowBox[{"result", "/.", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"a_", "?", "NumericQ"}], "/;", 
            RowBox[{"!", 
             RowBox[{"IntegerQ", "[", "a", "]"}]}]}], ":>", 
           RowBox[{"RootApproximant", "[", 
            RowBox[{"a", ",", "4"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"CanonicalizeVars", "@", 
         RowBox[{"DeleteDuplicates", "[", 
          RowBox[{
           RowBox[{"Simplify", "@", "result"}], ",", "OrbitGaugeQ"}], 
          "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9856063988193398`*^9, 3.985606416725305*^9}, {
   3.9856064703897743`*^9, 3.9856065247062397`*^9}, {3.985606559057447*^9, 
   3.9856066112080803`*^9}, {3.985606648644642*^9, 3.985606858491893*^9}, {
   3.985606936540194*^9, 3.985606981642331*^9}, {3.985607057648725*^9, 
   3.985607255028636*^9}, {3.9856073163291903`*^9, 3.985607374896885*^9}, {
   3.985607418728427*^9, 3.985607432858974*^9}, 3.985607473528916*^9, {
   3.985607529963173*^9, 3.985607680304585*^9}, {3.985607786194228*^9, 
   3.985607831974389*^9}, {3.985607892447155*^9, 3.985607971346109*^9}, {
   3.985608002175*^9, 3.985608103012013*^9}, {3.985608133401888*^9, 
   3.98560818439375*^9}, {3.985611091792625*^9, 3.985611092227378*^9}, {
   3.9856186962454967`*^9, 3.985618756393588*^9}, {3.985618799153585*^9, 
   3.985618838331748*^9}, 3.9856189919589453`*^9, {3.985619033638089*^9, 
   3.9856190347787867`*^9}, {3.9856190878359213`*^9, 3.985619098687307*^9}, {
   3.98561913679035*^9, 3.985619170077545*^9}, {3.985619219926408*^9, 
   3.985619262752778*^9}, {3.985619331197607*^9, 3.9856193396796227`*^9}, {
