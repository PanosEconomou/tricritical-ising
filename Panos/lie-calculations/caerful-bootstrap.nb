                 RowBox[{"families", "[", 
                  RowBox[{"[", 
                   RowBox[{"All", ",", "indices"}], "]"}], "]"}], ",", 
                 RowBox[{"#2", "[", 
                  RowBox[{"[", "indices", "]"}], "]"}]}], "]"}]}], "}"}], 
             "&"}], ",", 
            RowBox[{"{", 
             RowBox[{"products", ",", "products"}], "}"}]}], "]"}], "//", 
          "DeleteDuplicates"}]}], ";", "\[IndentingNewLine]", 
