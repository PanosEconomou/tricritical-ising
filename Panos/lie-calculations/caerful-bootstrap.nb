          "family"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"products", "=", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"tr", "/@", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"#", "[", 
