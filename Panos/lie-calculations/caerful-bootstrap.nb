           "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"result", "=", 
         RowBox[{"result", "/.", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"a_", "?", "NumericQ"}], "/;", 
