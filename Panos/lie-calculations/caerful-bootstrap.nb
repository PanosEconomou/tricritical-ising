Cell[BoxData[
 RowBox[{
  RowBox[{"FindIntegerCombinations", "[", 
   RowBox[{"M_", ",", "v_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"n", "=", 
       RowBox[{"Length", "[", "M", "]"}]}], ",", 
      RowBox[{"m", "=", 
       RowBox[{"Length", "[", "v", "]"}]}], ",", "MT", ",", "ubounds", ",", 
      RowBox[{"results", "=", 
       RowBox[{"{", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"MT", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"N", "[", "M", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ubounds", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "sol", "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"sol", "=", 
            RowBox[{"LinearProgramming", "[", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"UnitVector", "[", 
                RowBox[{"n", ",", "i"}], "]"}]}], ",", "MT", ",", 
              RowBox[{"Transpose", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"N", "[", "v", "]"}], ",", 
                 RowBox[{"ConstantArray", "[", 
                  RowBox[{"0", ",", "m"}], "]"}]}], "}"}], "]"}], ",", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"0", ",", "n"}], "]"}]}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"VectorQ", "[", "sol", "]"}], ",", 
             RowBox[{"Max", "[", 
              RowBox[{"0", ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"sol", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "//", "Chop"}], "//", 
                "RootApproximant"}]}], "]"}], ",", "sol"}], "]"}]}]}], "]"}], 
        ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "n"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"enumerate", "[", 
       RowBox[{"rem_", ",", "idx_", ",", "current_"}], "]"}], ":=", 
      RowBox[{"Which", "[", 
       RowBox[{
        RowBox[{"idx", ">", "n"}], ",", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"rem", "==", 
           RowBox[{"ConstantArray", "[", 
            RowBox[{"0", ",", "m"}], "]"}]}], ",", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"results", ",", "current"}], "]"}]}], "]"}], ",", "True", ",", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"enumerate", "[", 
           RowBox[{
            RowBox[{"rem", "-", 
             RowBox[{"k", "*", 
              RowBox[{"M", "[", 
               RowBox[{"[", "idx", "]"}], "]"}]}]}], ",", 
            RowBox[{"idx", "+", "1"}], ",", 
            RowBox[{"Append", "[", 
             RowBox[{"current", ",", "k"}], "]"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", "0", ",", 
            RowBox[{"ubounds", "[", 
             RowBox[{"[", "idx", "]"}], "]"}]}], "}"}]}], "]"}]}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"enumerate", "[", 
      RowBox[{"v", ",", "1", ",", 
       RowBox[{"{", "}"}]}], "]"}], ";", "\[IndentingNewLine]", "results"}]}],
    "]"}]}]], "Input",
