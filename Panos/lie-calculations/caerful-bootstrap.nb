Cell[CellGroupData[{

Cell["Resolving Ambiguities", "Section",
 CellChangeTimes->{{3.985354791837942*^9, 
  3.985354796373461*^9}},ExpressionUUID->"9f833116-b49f-403b-8108-\
52ba4d78d4b2"],

Cell["\<\
As we can see from the answers above for part of the primaries the action of \
the defects is ambiguous and we really only know the trace. Yet we have a lot \
of data, perhaps enough to fully constrain the action on the primaries (up to \
a basis choice). To do this we will use fusion rules. These are highly \
constrained also simply by looking at the action in the nondegenerate \
primaries. Then we will search fusion rules for consistencies using a version \
of BFS.\
\>", "Text",
 CellChangeTimes->{{3.985354805231358*^9, 
  3.9853549465297213`*^9}},ExpressionUUID->"aae6f594-79dd-4478-af97-\
5a7ae1461391"],

Cell[CellGroupData[{

Cell["Defect Manipulations", "Subsection",
 CellChangeTimes->{{3.9853551382637987`*^9, 
  3.985355145263522*^9}},ExpressionUUID->"3f4fa445-15a0-4b29-8fa3-\
e6e6a7449d61"],

Cell["\<\
Since we don\[CloseCurlyQuote]t need a really big matrix to store the action \
of the defects, we will instead opt to store them using a list of 1x1 and 2x2 \
matrices depending on which are ambiguous or not. So we can define an \
associative operation for the tensor product!!\
\>", "Text",
 CellChangeTimes->{{3.9853551464778633`*^9, 3.985355206816071*^9}, 
   3.985355267872313*^9},ExpressionUUID->"63113c20-57c4-44b3-889a-\
29b6d9c323c9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "a", " ", "Defect", " ", "Fusion", " ", "Product", " ", 
    "Operation"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"SetAttributes", "[", 
    RowBox[{"CircleTimes", ",", 
     RowBox[{"{", 
      RowBox[{"Flat", ",", "OneIdentity"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a_", " ", "\[CircleTimes]", " ", "b_"}], ":=", 
     RowBox[{
      RowBox[{
       RowBox[{"Which", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"MatrixQ", "[", 
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}], "&&", 
          RowBox[{"MatrixQ", "[", 
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ".", 
          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ",", "True", ",", 
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "*", 
          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], "&"}], "/@", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"a", ",", "b"}], "}"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"CircleTimes", "[", 
     RowBox[{"a_", ",", "b_", ",", "rest__"}], "]"}], ":=", 
    RowBox[{"CircleTimes", "[", 
     RowBox[{
      RowBox[{"CircleTimes", "[", 
       RowBox[{"a", ",", "b"}], "]"}], ",", "rest"}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "A", " ", "couple", " ", "of", " ", "helper", " ", "functions", " ", 
     "that", " ", "can", " ", "be", " ", "applied", " ", "to", " ", "Lines"}],
     " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"tr", "[", "x_", "]"}], ":=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"MatrixQ", "[", "x", "]"}], ",", 
       RowBox[{"Tr", "[", "x", "]"}], ",", "True", ",", "x"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"inv", "[", "x_", "]"}], ":=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"MatrixQ", "[", "x", "]"}], ",", 
       RowBox[{"Inverse", "[", "x", "]"}], ",", "True", ",", 
       FractionBox["1", "x"]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"dual", "[", "x_", "]"}], ":=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"MatrixQ", "[", "x", "]"}], ",", 
       RowBox[{"ConjugateTranspose", "[", "x", "]"}], ",", "True", ",", 
       RowBox[{"Conjugate", "[", "x", "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     SuperscriptBox["x_", "\[Dagger]"], ":=", 
     RowBox[{"dual", "/@", "x"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ShowLine", "[", "L_", "]"}], ":=", 
     RowBox[{"MatrixForm", "[", 
      RowBox[{"MatrixForm", "/@", "L"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"SetAttributes", "[", 
    RowBox[{"Time", ",", "HoldFirst"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Time", "[", "x_", "]"}], ":=", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"res", "=", 
         RowBox[{"AbsoluteTiming", "[", "x", "]"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"Echo", "[", 
         RowBox[{
          RowBox[{"res", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<Time: \>\""}], "]"}], ";", 
        RowBox[{"res", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "mask", " ", "tells", " ", "us", " ", "if", " ", "the", " ", 
     "current", " ", "primary", " ", "is", " ", "degenerate"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"degMask", "=", 
     RowBox[{"Thread", "[", 
      RowBox[{
       RowBox[{"families", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "!=", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"degPos", "=", 
     RowBox[{"Flatten", "@", 
      RowBox[{"Position", "[", 
       RowBox[{"degMask", ",", "True"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nondegPos", "=", 
     RowBox[{"Flatten", "@", 
      RowBox[{"Position", "[", 
       RowBox[{
        RowBox[{"Not", "/@", "degMask"}], ",", "True"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"deg", "[", "x_", "]"}], ":=", 
     RowBox[{"degMask", "[", 
      RowBox[{"[", "x", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"degNum", "=", 
     RowBox[{"Total", "@", 
      RowBox[{"Boole", "@", "degMask"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"primNum", "=", 
     RowBox[{"Total", "@", 
      RowBox[{"Boole", "@", "degMask"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"famNum", "=", 
     RowBox[{"Length", "@", "families"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"familiesNondeg", "=", 
     RowBox[{"families", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "nondegPos"}], "]"}], "]"}]}], ";"}]}]}]], "Input",\

