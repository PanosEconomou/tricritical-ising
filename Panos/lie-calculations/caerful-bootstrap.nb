           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"defects", "//.", "#"}], ")"}], "&"}], "/@", 
              RowBox[{"DeleteCases", "[", 
