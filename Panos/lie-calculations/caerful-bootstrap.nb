Cell[CellGroupData[{

Cell["Constrain Using Consistency with Themselves.", "Subsection",
 CellChangeTimes->{{3.985623428779269*^9, 3.9856234485777893`*^9}, {
  3.985623506809176*^9, 3.98562350753794*^9}, {3.985784184505721*^9, 
  3.985784199289604*^9}},ExpressionUUID->"39b8bddd-7528-4737-8331-\
0d20d120388c"],

Cell["\<\
We now have candidates for each family constrained by consistency with fusion \
with invertible lines. The next step would be to constrain the parameters \
with respect to their fusion and the fusion with their orientation reversal \
(aka dual).\
\>", "Text",
 CellChangeTimes->{{3.98578424716442*^9, 3.9857843154909897`*^9}, {
  3.9857950898946037`*^9, 
  3.9857951030928698`*^9}},ExpressionUUID->"660ee357-128a-405f-a3e0-\
e789325e82d3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Returns", " ", "which", " ", "column", " ", "indices", " ", "have", " ", 
    "no", " ", "variables"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"noVars", "[", "table_", "]"}], ":=", 
     RowBox[{"Pick", "[", 
      RowBox[{
       RowBox[{"Range", "[", 
        RowBox[{"Length", "@", 
         RowBox[{"First", "@", "table"}]}], "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"VectorQ", "[", 
          RowBox[{"#", ",", "NumericQ"}], "]"}], "&"}], "/@", 
        RowBox[{"Transpose", "[", "table", "]"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Constrain", " ", "using", " ", "fusion", " ", "with", " ", "their", " ", 
     "dual"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ConstrainWithDualFusion", "[", "defects_", "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vars", "=", 
          RowBox[{"Variables", "[", "defects", "]"}]}], ",", "products", ",", 
         "indices", ",", "fusions", ",", "result"}], "}"}], ",", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Calculate", " ", "Fusion", " ", "among", " ", "members", " ", "of", " ",
          "family"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"products", "=", 
         RowBox[{"DeleteDuplicates", "@", 
          RowBox[{"Flatten", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"tr", "/@", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"#", "\[CircleTimes]", " ", 
                    SuperscriptBox["#", "\[Dagger]"]}], "-", 
                    RowBox[{"Li", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], ")"}]}], ")"}], ",", 
                RowBox[{"(", 
                 RowBox[{"tr", "/@", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{
                    SuperscriptBox["#", "\[Dagger]"], "\[CircleTimes]", " ", 
                    "#"}], "-", 
                    RowBox[{"Li", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], ")"}]}], ")"}]}], "}"}],
               "&"}], "/@", "defects"}], ",", "1"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"indices", "=", 
         RowBox[{"noVars", "[", "products", "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Constrain", " ", "their", " ", "possible", " ", "fusion", " ", 
          "pathways", " ", "and", " ", "turn", " ", "them", " ", "into", " ", 
          "equations", " ", "using", " ", "their", " ", "traces"}], " ", 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{"fusions", "=", 
         RowBox[{
          RowBox[{"MapThread", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"N", "[", 
                RowBox[{"tr", "/@", "#1"}], "]"}], ",", 
               RowBox[{"FindIntegerCombinations", "[", 
                RowBox[{
                 RowBox[{"families", "[", 
                  RowBox[{"[", 
                   RowBox[{"All", ",", "indices"}], "]"}], "]"}], ",", 
                 RowBox[{"#2", "[", 
                  RowBox[{"[", "indices", "]"}], "]"}]}], "]"}]}], "}"}], 
             "&"}], ",", 
            RowBox[{"{", 
             RowBox[{"products", ",", "products"}], "}"}]}], "]"}], "//", 
          "DeleteDuplicates"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"fusions", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Transpose", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"fusions", "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"N", "[", 
                 RowBox[{"#", ".", "families"}], "]"}], "&"}], "/@", "#"}]}], 
             "}"}], "]"}], "&"}], "/@", 
          RowBox[{"Tuples", "[", 
           RowBox[{"fusions", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"Solve", " ", "and", " ", "prettify"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"fusions", "=", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Flatten", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"MapThread", "[", "Equal", "]"}], "/@", "#"}], ",", 
              "1"}], "]"}], "&"}], ",", "fusions"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"result", " ", "=", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"defects", "//.", "#"}], ")"}], "&"}], "/@", 
              RowBox[{"DeleteCases", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"Quiet", "@", 
                  RowBox[{"Solve", "[", 
                   RowBox[{"#", ",", "vars"}], "]"}]}], ")"}], ",", 
                RowBox[{"{", "}"}]}], "]"}]}], "&"}], "/@", "fusions"}], ",", 
           "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"result", "=", 
         RowBox[{"result", "/.", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"a_", "?", "NumericQ"}], "/;", 
            RowBox[{"!", 
             RowBox[{"IntegerQ", "[", "a", "]"}]}]}], ":>", 
           RowBox[{"RootApproximant", "[", 
            RowBox[{"a", ",", "4"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"DeleteDuplicates", "[", 
         RowBox[{
          RowBox[{"FullSimplify", "@", "result"}], ",", "OrbitGaugeQ"}], 
         "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Take", " ", "a", " ", "collection", " ", "of", " ", "candidate", " ", 
     "lines", " ", "for", " ", "a", " ", "family", " ", "and", " ", "use", " ",
      "their", " ", "self", " ", "fusion", " ", "to", " ", "further", " ", 
     "constrain", " ", "them"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ConstrainWithSelfFusion", "[", "defects_", "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vars", "=", 
          RowBox[{"Variables", "[", "defects", "]"}]}], ",", "products", ",", 
         "indices", ",", "fusions", ",", "result"}], "}"}], ",", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Calculate", " ", "Fusion", " ", "among", " ", "members", " ", "of", " ",
          "family"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"products", "=", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"tr", "/@", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "\[CircleTimes]", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}]}], ")"}]}], ")"}], "&"}], "/@", 
           RowBox[{"Tuples", "[", 
            RowBox[{"{", 
             RowBox[{"defects", ",", "defects"}], "}"}], "]"}]}], ")"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"indices", "=", 
         RowBox[{"noVars", "[", "products", "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Constrain", " ", "their", " ", "possible", " ", "fusion", " ", 
          "pathways", " ", "and", " ", "turn", " ", "them", " ", "into", " ", 
          "equations", " ", "using", " ", "their", " ", "traces"}], " ", 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{"fusions", "=", 
         RowBox[{
          RowBox[{"MapThread", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"N", "[", 
                RowBox[{"tr", "/@", "#1"}], "]"}], ",", 
               RowBox[{"FindIntegerCombinations", "[", 
                RowBox[{
                 RowBox[{"families", "[", 
                  RowBox[{"[", 
                   RowBox[{"All", ",", "indices"}], "]"}], "]"}], ",", 
                 RowBox[{"#2", "[", 
                  RowBox[{"[", "indices", "]"}], "]"}]}], "]"}]}], "}"}], 
             "&"}], ",", 
            RowBox[{"{", 
             RowBox[{"products", ",", "products"}], "}"}]}], "]"}], "//", 
          "DeleteDuplicates"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"fusions", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Transpose", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"fusions", "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"N", "[", 
                 RowBox[{"#", ".", "families"}], "]"}], "&"}], "/@", "#"}]}], 
             "}"}], "]"}], "&"}], "/@", 
          RowBox[{"Tuples", "[", 
           RowBox[{"fusions", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"fusions", "=", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Flatten", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"MapThread", "[", "Equal", "]"}], "/@", "#"}], ",", 
              "1"}], "]"}], "&"}], ",", "fusions"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"Solve", " ", "and", " ", "prettify"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"result", " ", "=", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"defects", "//.", "#"}], ")"}], "&"}], "/@", 
              RowBox[{"DeleteCases", "[", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"Quiet", "@", 
                  RowBox[{"Solve", "[", 
                   RowBox[{"#", ",", "vars"}], "]"}]}], ")"}], ",", 
                RowBox[{"{", "}"}]}], "]"}]}], "&"}], "/@", "fusions"}], ",", 
           "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"result", "=", 
         RowBox[{"result", "/.", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"a_", "?", "NumericQ"}], "/;", 
            RowBox[{"!", 
             RowBox[{"IntegerQ", "[", "a", "]"}]}]}], ":>", 
           RowBox[{"RootApproximant", "[", 
            RowBox[{"a", ",", "4"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"DeleteDuplicates", "[", 
         RowBox[{
          RowBox[{"FullSimplify", "@", "result"}], ",", "OrbitGaugeQ"}], 
         "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}]}]}]], "Input",
