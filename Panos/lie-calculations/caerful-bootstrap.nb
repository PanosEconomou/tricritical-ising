Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Organize", "[", "e_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"l", ",", "r", ",", "L"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"l", "=", 
       RowBox[{"e", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"r", "=", 
       RowBox[{"e", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"L", "=", 
       RowBox[{"LCM", "@@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Level", "[", 
              RowBox[{
               RowBox[{"List", "@@", "#"}], ",", "1"}], "]"}], "&"}], "/@", 
            RowBox[{"Flatten", "[", 
             RowBox[{"{", 
              RowBox[{"l", ",", "r"}], "}"}], "]"}]}], "//", "Flatten"}], "//",
           "Denominator"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"e", "[", 
        RowBox[{"[", "0", "]"}], "]"}], "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"l", "-", "r"}], ")"}], "//", "ExpandAll"}], ",", "0"}], 
       "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", 
   RowBox[{
    RowBox[{"Inverse", "[", 
     RowBox[{"N", "[", "a", "]"}], "]"}], "//", "Chop"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", 
   RowBox[{"RootApproximant", "/@", "b"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"m", "=", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"ConjugateTranspose", "[", "s", "]"}], " ", ".", " ", 
     RowBox[{"ReplacePart", "[", 
      RowBox[{"z", ",", 
       RowBox[{"Thread", "[", 
        RowBox[{"nz", "\[Rule]", 
         RowBox[{"Simplify", "[", 
          RowBox[{"b", ".", "X"}], "]"}]}], "]"}]}], "]"}], " ", ".", " ", 
     "s"}], "]"}]}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eqn", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"#", " ", "\[GreaterEqual]", " ", "0"}], " ", "&"}], " ", "/@", 
          RowBox[{"(", 
           RowBox[{"m", "//", "Flatten"}], ")"}]}], ")"}], " ", "//", 
        "Expand"}], "//", "Chop"}], "//", "Rationalize"}], "//", "Expand"}], "//",
     " ", "DeleteDuplicates"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mx", "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"Min", " ", "[", 
       RowBox[{"Cases", "[", 
        RowBox[{"eqn", ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"a_.", " ", "*", " ", "#"}], ")"}], ">=", " ", "0"}], " ",
           ":>", "a"}]}], "]"}], "]"}], 
      RowBox[{"-", "1"}]], "&"}], "/@", "X"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"m", "=", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"ConjugateTranspose", "[", "s", "]"}], " ", ".", " ", 
     RowBox[{"ReplacePart", "[", 
      RowBox[{"z", ",", 
       RowBox[{"Thread", "[", 
        RowBox[{"nz", "\[Rule]", 
         RowBox[{"Simplify", "[", 
          RowBox[{"b", ".", 
           RowBox[{"(", 
            RowBox[{"mx", "*", "X"}], ")"}]}], "]"}]}], "]"}]}], "]"}], " ", ".",
      " ", "s"}], "]"}]}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eqn", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"#", " ", "\[GreaterEqual]", " ", "0"}], " ", "&"}], " ", "/@", 
          RowBox[{"(", 
           RowBox[{"m", "//", "Flatten"}], ")"}]}], ")"}], " ", "//", 
        "Expand"}], "//", "Chop"}], "//", "Rationalize"}], "//", "Expand"}], "//",
     " ", "DeleteDuplicates"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eqn", "=", 
   RowBox[{"Organize", "/@", "eqn"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"eqn", "//", "MatrixForm"}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"B", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Coefficient", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"eqn", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", "X"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{"Length", "[", "eqn", "]"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"B", "//", "MatrixPlot"}], ";"}]}], "Input",
