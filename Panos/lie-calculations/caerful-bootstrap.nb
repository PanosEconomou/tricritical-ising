Cell[BoxData[{
 RowBox[{
  RowBox[{"FindRowProducts", "[", 
   RowBox[{"M_", ",", "N_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"m", "=", 
       RowBox[{"Length", "[", "M", "]"}]}], ",", 
      RowBox[{"n", "=", 
       RowBox[{"Length", "[", "N", "]"}]}], ",", " ", 
      RowBox[{"results", "=", 
       RowBox[{"{", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"product", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"M", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "*", 
             RowBox[{"N", "[", 
              RowBox[{"[", "j", "]"}], "]"}]}], "//", "Chop"}]}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"MemberQ", "[", 
            RowBox[{"N", ",", "product"}], "]"}], ",", "\[IndentingNewLine]", 
           
           RowBox[{"AppendTo", "[", 
            RowBox[{"results", ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "j", ",", 
               RowBox[{
                RowBox[{"Position", "[", 
                 RowBox[{"N", ",", "product"}], "]"}], "//", "Flatten"}]}], 
              "}"}]}], "]"}]}], "]"}]}], "\[IndentingNewLine]", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "m"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "results"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"FusionCandidates", "=", 
   RowBox[{"FindRowProducts", "[", 
    RowBox[{
     RowBox[{"d", "[", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{";;", "5"}], ",", 
        RowBox[{";;", "24"}]}], "]"}], "]"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"d", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", 
          RowBox[{";;", "24"}]}], "]"}], "]"}], "//", "N"}], "//", "Chop"}]}],
     "]"}]}], ";"}], "\[IndentingNewLine]", 
