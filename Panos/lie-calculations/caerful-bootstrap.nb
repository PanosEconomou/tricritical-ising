              RowBox[{"#2", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}], "]"}], 
            RowBox[{"KroneckerDelta", "[", 
             RowBox[{
              RowBox[{"#1", "[", 
               RowBox[{"[", "3", "]"}], "]"}], ",", 
              RowBox[{"-", 
               RowBox[{"#2", "[", 
                RowBox[{"[", "3", "]"}], "]"}]}]}], "]"}]}]}], ")"}], 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"KroneckerDelta", "[", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"#1", "[", 
               RowBox[{"[", "3", "]"}], "]"}], "]"}], ",", "2"}], "]"}]}], 
          ")"}], 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"KroneckerDelta", "[", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"#2", "[", 
               RowBox[{"[", "3", "]"}], "]"}], "]"}], ",", "2"}], "]"}]}], 
          ")"}]}], "&"}], ",", "i", ",", "i", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"MatrixPlot", "[", 
    RowBox[{"z", ",", 
     RowBox[{"PlotLabel", "->", "\"\<Modular Mass Matrix z\>\""}]}], 
    "]"}]}]}]], "Input",
