Cell[CellGroupData[{

Cell["Solving with Existing Lines", "Section",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Python", "SessionID" -> "default-python-session", 
     "Evaluator" -> Automatic|>|>,
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.9859465410744543`*^9, 3.98594654740558*^9}, {
  3.985946584082862*^9, 3.985946599817297*^9}, {3.9859468586786833`*^9, 
  3.985946891091023*^9}},ExpressionUUID->"5b3aaac0-eea5-4b60-ae32-\
85f5d0431241"],

Cell["\<\
As we keep going through families with higher and higher quantum dimension we \
can use existing lines to constrain new ones. This is a variation of \
constrain with invertible lines, but this time it uses the full might of the \
already solved families. We will do an extra optimization. Since once a \
family is solved we know all the lines there and not just the traces,  this \
places a much stricter constraint on what the results of fusions can be other \
than their traces.\
\>", "Text",
 CellChangeTimes->{{3.985946901570898*^9, 3.985947046811798*^9}, {
  3.985947098428143*^9, 
  3.985947113563995*^9}},ExpressionUUID->"cf18efc2-42a4-4577-8483-\
3f5dd2711992"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Calculate", " ", "the", " ", "orbit", " ", "of", " ", "the", " ", "new", " ",
     "line", " ", "under", " ", "fusion", " ", "using", " ", "the", " ", 
    "defects", " ", "that", " ", "we", " ", "already", " ", "know"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", "fusionOrbit", "]"}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"fusionOrbit", "[", 
      RowBox[{"x_", ",", 
       RowBox[{"L_", ":", "L"}], ",", 
       RowBox[{"gaugeVarRules_", ":", "gaugeVarRules"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"fusionOrbit", "[", 
       RowBox[{"x", ",", "L", ",", "gaugeVarRules"}], "]"}], "=", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"Outer", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"#1", "\[CircleTimes]", "x", "\[CircleTimes]", "#2"}], 
              "&"}], ",", "L", ",", "L", ",", "1", ",", "1"}], "]"}], ",", 
           "1"}], "]"}], ",", 
         RowBox[{"Assumptions", "->", "gaugeVarRules"}]}], "]"}], "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Find", " ", "possible", " ", "integer", " ", "combinations", " ", "for", 
     " ", "a", " ", "defect", " ", "with", " ", "unknown", " ", "variables"}],
     " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"PossibleSimpleDecompositions", "[", 
      RowBox[{"trace_", ",", 
       RowBox[{"gaugeVars_", ":", "gaugeVars"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vars", "=", 
          RowBox[{"Variables", "[", "trace", "]"}]}], ",", "indices"}], "}"}],
        ",", "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "vars", "]"}], "==", "0"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"FindIntegerCombinationsCached", "[", 
          RowBox[{"families", ",", "trace"}], "]"}], ",", 
         "\[IndentingNewLine]", "True", ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"indices", "=", 
           RowBox[{"Flatten", "@", 
            RowBox[{"Position", "[", 
             RowBox[{"trace", ",", " ", 
              RowBox[{"_", "?", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"FreeQ", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{"Alternatives", "@@", "vars"}]}], "]"}], "&"}], 
                ")"}]}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"Heads", "->", "False"}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"FindIntegerCombinationsCached", "[", 
           RowBox[{
            RowBox[{"families", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "indices"}], "]"}], "]"}], ",", 
            RowBox[{"trace", "[", 
             RowBox[{"[", "indices", "]"}], "]"}]}], "]"}]}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Uses", " ", "trace", " ", "equations", " ", "and", " ", "known", " ", 
     "lines", " ", "to", " ", "produce", " ", "candidates", " ", "for", " ", 
     "the", " ", "unknown", " ", "parameters"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ReduceDecompositions", "[", 
      RowBox[{"defect_", ",", "trace_", ",", "decompositions_"}], "]"}], ":=", 
     RowBox[{"Or", "@@", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"decomp", "|->", 
         RowBox[{"Module", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"sparseDecomp", "=", 
              RowBox[{"SparseArray", "[", "decomp", "]"}]}], ",", "indices", ",",
              "sol"}], "}"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"indices", "=", 
             RowBox[{
              RowBox[{"sparseDecomp", "[", "\"\<NonzeroPositions\>\"", "]"}], 
              "[", 
              RowBox[{"[", 
               RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Which", "[", "\[IndentingNewLine]", 
             RowBox[{"(*", " ", 
              RowBox[{
              "If", " ", "the", " ", "fusion", " ", "is", " ", "in", " ", 
               "one", " ", "family", " ", "and", " ", "it", " ", "has", " ", 
               "been", " ", "solved", " ", "equate", " ", "them", " ", "cell",
                " ", "by", " ", "cell"}], " ", "*)"}], "\[IndentingNewLine]", 
             
             RowBox[{
              RowBox[{"And", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Length", "[", "indices", "]"}], "==", "1"}], ",", 
                RowBox[{"SolvedQ", "[", 
                 RowBox[{"indices", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"Reduce", "[", 
               RowBox[{"Or", "@@", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"And", "@@", 
                    RowBox[{"DeleteCases", "[", 
                    RowBox[{
                    RowBox[{"MapThread", "[", 
                    RowBox[{"Equal", ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Flatten", "[", "defect", "]"}], ",", 
                    RowBox[{"Flatten", "[", "#", "]"}]}], "}"}]}], "]"}], ",",
                     "True"}], "]"}]}], "&"}], "/@", 
                  RowBox[{"solvedFamilies", "[", 
                   RowBox[{"indices", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ")"}]}], "]"}], ",",
               "\[IndentingNewLine]", 
              RowBox[{"(*", " ", 
               RowBox[{
               "Otherwise", " ", "equate", " ", "their", " ", "traces"}], " ",
                "*)"}], "\[IndentingNewLine]", "True", ",", 
              "\[IndentingNewLine]", 
              RowBox[{"Reduce", "[", 
               RowBox[{"And", "@@", 
                RowBox[{"DeleteCases", "[", 
                 RowBox[{
                  RowBox[{"MapThread", "[", 
                   RowBox[{"Equal", ",", 
                    RowBox[{"{", 
                    RowBox[{"trace", ",", 
                    RowBox[{"decomp", ".", "families"}]}], "}"}], ",", "1"}], 
                   "]"}], ",", "True"}], "]"}]}], "]"}]}], 
             "\[IndentingNewLine]", "]"}]}]}], "]"}]}], ")"}], "/@", 
       "decompositions"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ConstrainWithKnown", "[", 
      RowBox[{"defect_", ",", 
       RowBox[{"var_", ":", "x"}], ",", 
       RowBox[{"L_", ":", "L"}], ",", 
       RowBox[{"gaugeVars_", ":", "gaugeVars"}], ",", 
       RowBox[{"gaugeVarRules_", ":", "gaugeVarRules"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vars", "=", 
          RowBox[{"Variables", "[", "defect", "]"}]}], ",", "products", ",", 
         "traces", ",", "decompositions", ",", "result"}], "}"}], ",", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Calculate", " ", "the", " ", "possible", " ", "fusion", " ", 
         "channels", " ", "with", " ", "the", " ", "known", " ", "defects"}], 
        " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"products", "=", 
         RowBox[{"fusionOrbit", "[", 
          RowBox[{"defect", ",", "L", ",", "gaugeVarRules"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"traces", "=", 
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"tr", "/@", "#"}], "&"}], "/@", "products"}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"decompositions", "=", 
         RowBox[{"PossibleSimpleDecompositions", "/@", "traces"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Obtain", " ", "a", " ", "system", " ", "of", " ", "equations", " ", 
          "and", " ", "reduce", " ", "it"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"decompositions", "=", 
         RowBox[{"MapThread", "[", 
          RowBox[{"ReduceDecompositions", ",", 
           RowBox[{"{", 
            RowBox[{
            "products", ",", " ", "traces", ",", " ", "decompositions"}], 
            "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"result", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"defect", "//.", "#"}], ")"}], "&"}], "/@", 
          RowBox[{"(", 
           RowBox[{"QuietSolve", "[", 
            RowBox[{"decompositions", ",", "vars"}], "]"}], ")"}]}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "Convert", " ", "numerical", " ", "constants", " ", "back", " ", 
           "to", " ", "algebraic", " ", "form"}], ",", " ", 
          RowBox[{"preserving", " ", "variables"}]}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"result", "=", 
         RowBox[{"result", "/.", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"a_", "?", "NumericQ"}], "/;", 
            RowBox[{"!", 
             RowBox[{"IntegerQ", "[", "a", "]"}]}]}], ":>", 
           RowBox[{"RootApproximant", "[", 
            RowBox[{"a", ",", "4"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"CanonicalizeVars", "@", 
         RowBox[{"DeleteDuplicates", "[", 
          RowBox[{
           RowBox[{"Simplify", "@", "result"}], ",", "OrbitGaugeQ"}], 
          "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}]}]}]], "Input",
