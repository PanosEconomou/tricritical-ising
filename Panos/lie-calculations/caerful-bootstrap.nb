Cell[CellGroupData[{

Cell["Constrain Using Invertible Defect Fusion", "Subsection",
 CellChangeTimes->{{3.985606375629017*^9, 
  3.9856064134842463`*^9}},ExpressionUUID->"6485ac9b-e864-4737-aa9d-\
986958320d4c"],

Cell["\<\
Use fusion rules with invertible defects to constrain the possible candidates \
for lines in a family up to fusion by invertible and gauge transformations\
\>", "Text",
 CellChangeTimes->{{3.9856064203802557`*^9, 3.985606466079618*^9}, {
  3.9856236593559217`*^9, 
  3.985623660114664*^9}},ExpressionUUID->"d637bdf1-f948-4f89-9f26-\
511a108a7fbd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Functions", " ", "to", " ", "create", " ", "a", " ", "defect", " ", 
     "with", " ", "free", " ", "variables", " ", "and", " ", "given", " ", 
     "traces"}], ",", " ", 
    RowBox[{
    "as", " ", "well", " ", "to", " ", "extract", " ", "the", " ", 
     "variables"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"l", "[", 
      RowBox[{"traces_", ",", "var_"}], "]"}], ":=", " ", 
     RowBox[{"Array", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Which", "[", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"deg", "[", "#", "]"}]}], ",", 
          RowBox[{"traces", "[", 
           RowBox[{"[", "#", "]"}], "]"}], ",", 
          RowBox[{"deg", "[", "#", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"var", "[", 
               RowBox[{"#", ",", "1"}], "]"}], " ", ",", 
              RowBox[{"var", "[", 
               RowBox[{"#", ",", "2"}], "]"}]}], " ", "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"var", "[", 
               RowBox[{"#", ",", "3"}], "]"}], ",", 
              RowBox[{
               RowBox[{"traces", "[", 
                RowBox[{"[", "#", "]"}], "]"}], "-", 
               RowBox[{"var", "[", 
                RowBox[{"#", ",", "1"}], "]"}]}]}], "}"}]}], "}"}]}], "]"}], 
        "&"}], ",", 
       RowBox[{"Length", "@", "traces"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"getVars", "[", "x_", "]"}], ":=", 
     RowBox[{
      RowBox[{"x", "//", "Flatten"}], "//", "Variables"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Solves", " ", "system", " ", "quietly", " ", "ignoring", " ", "the", " ",
      "cases", " ", "when", " ", "parameters", " ", "are", " ", 
     "undetermined"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"QuietSolve", "[", 
       RowBox[{"eqn_", ",", "vars_"}], "]"}], ":=", 
      RowBox[{"Quiet", "[", 
       RowBox[{
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{"eqn", "/.", " ", 
           RowBox[{
            RowBox[{"a_", "?", "InexactNumberQ"}], ":>", 
            RowBox[{"Rationalize", "[", "a", "]"}]}]}], ",", "vars"}], "]"}], 
        ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Solve", "::", "svars"}], ",", 
          RowBox[{"Solve", "::", "fulldim"}]}], "}"}]}], "]"}]}], ";"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"QuietSolve", "[", 
      RowBox[{"eqn_", ",", "vars_"}], "]"}], ":=", 
     RowBox[{"Quiet", "[", 
      RowBox[{
       RowBox[{"Solve", "[", 
        RowBox[{"eqn", ",", "vars"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Solve", "::", "svars"}], ",", 
         RowBox[{"Solve", "::", "fulldim"}], ",", 
         RowBox[{
          StyleBox["Solve", "MessageName"], 
          StyleBox["::", "MessageName"], "ratnz"}]}], "}"}]}], "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Cleans", " ", "up", " ", "some", " ", "variables"}], " ", "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"CanonicalizeVars", "[", "list_", "]"}], ":=", 
     RowBox[{"Array", "[", 
      RowBox[{
       RowBox[{"i", "|->", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "vars", "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"vars", "=", 
            RowBox[{"getVars", "@", 
             RowBox[{"list", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
           
           RowBox[{
            RowBox[{"list", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "/.", 
            RowBox[{"MapIndexed", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"#", "->", 
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "0", "]"}], "]"}], "[", 
                 RowBox[{"i", ",", 
                  RowBox[{"#2", "[", 
                   RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], "&"}], ",", 
              "vars"}], "]"}]}]}]}], "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"Length", "@", "list"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Given", " ", "a", " ", "defect", " ", "with", " ", "free", " ", 
      "variables"}], ",", " ", 
     RowBox[{
     "it", " ", "outputs", " ", "a", " ", "list", " ", "of", " ", "the", " ", 
      "variables", " ", "that", " ", "are", " ", "pure", " ", "gauge"}]}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GaugeParams", "[", "x_", "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"vars", "=", 
         RowBox[{"getVars", "@", "x"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Pick", "[", 
        RowBox[{"vars", ",", 
         RowBox[{"Simplify", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"GaugeQ", "[", 
              RowBox[{"x", ",", 
               RowBox[{"x", "/.", " ", 
                RowBox[{"#", "->", "\[FormalZ]"}]}]}], "]"}], "&"}], "/@", 
            "vars"}], ",", 
           RowBox[{"Assumptions", "->", 
            RowBox[{"Flatten", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Thread", "[", 
                RowBox[{"vars", "!=", "0"}], "]"}], ",", 
               RowBox[{"\[FormalZ]", "!=", "0"}]}], "}"}], "]"}]}]}], "]"}]}],
         "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"AllGaugeQ", "[", "x_", "]"}], ":=", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"First", "/@", 
        RowBox[{"BooleanVariables", "[", 
         RowBox[{"FunctionDomain", "[", 
          RowBox[{
           RowBox[{"Flatten", "[", "x", "]"}], ",", 
           RowBox[{"Variables", "[", "x", "]"}]}], "]"}], "]"}]}], "]"}], "===", 
      RowBox[{"Flatten", "[", 
       RowBox[{"GaugeParams", "[", "x", "]"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Provide", " ", "candidates", " ", "for", " ", "the", " ", 
     "representation", " ", "of", " ", "a", " ", "defect", " ", "line", " ", 
     "up", " ", "to", " ", "fusion", " ", "with", " ", "invertible", " ", 
