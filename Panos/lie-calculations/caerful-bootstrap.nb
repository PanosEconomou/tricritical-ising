 RowBox[{
  RowBox[{"FindRowProducts", "[", "M_", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"n", "=", 
       RowBox[{"Length", "[", "M", "]"}]}], ",", " ", 
      RowBox[{"results", "=", 
       RowBox[{"{", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"product", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"M", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "*", 
             RowBox[{"M", "[", 
              RowBox[{"[", "j", "]"}], "]"}]}], "//", "Chop"}]}], "}"}], ",", 
