          "equations", " ", "using", " ", "their", " ", "traces"}], " ", 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{"fusions", "=", 
         RowBox[{
          RowBox[{"MapThread", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"N", "[", 
                RowBox[{"tr", "/@", "#1"}], "]"}], ",", 
               RowBox[{"FindIntegerCombinationsCached", "[", 
