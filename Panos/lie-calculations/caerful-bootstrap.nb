                RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
              RowBox[{
               RowBox[{
                RowBox[{"N", "[", 
                 RowBox[{"#", ".", "families"}], "]"}], "&"}], "/@", "#"}]}], 
             "}"}], "]"}], "&"}], "/@", 
          RowBox[{"Tuples", "[", 
           RowBox[{"fusions", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"Solve", " ", "and", " ", "prettify"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"fusions", "=", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Flatten", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"MapThread", "[", "Equal", "]"}], "/@", "#"}], ",", 
