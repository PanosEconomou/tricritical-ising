Cell[CellGroupData[{

Cell["Constraining with Self Fusion", "Section",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Python", "SessionID" -> "default-python-session", 
     "Evaluator" -> Automatic|>|>,
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.9859465410744543`*^9, 3.98594654740558*^9}, {
  3.985946584082862*^9, 3.985946599817297*^9}, {3.9859468586786833`*^9, 
  3.985946891091023*^9}, {3.98621206006116*^9, 3.9862120873898563`*^9}, {
  3.986213878643474*^9, 
  3.9862138903420973`*^9}},ExpressionUUID->"27bd6efc-6746-4fb5-85ac-\
c3f6aaeb446b"],

Cell["\<\
The last condition we will impose is the fusion of the defects among \
themselves. In particular, if we have a collection of defects, their products \
should all have fusion decompositions in our fusion ring. This will help us \
pinpoint the remaining gauge degrees of freedom.\
\>", "Text",
 CellChangeTimes->{{3.985946901570898*^9, 3.985947046811798*^9}, {
  3.985947098428143*^9, 3.985947113563995*^9}, {3.986212065085133*^9, 
  3.986212120021104*^9}, {3.986213894014798*^9, 
  3.9862139837361307`*^9}},ExpressionUUID->"19c7fd92-34fa-4ce6-8eec-\
d021d9a83ce3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Constrain", " ", "using", " ", "fusion", " ", "among", " ", 
    "thesemeves"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ConstrainWithSelfFusion", "[", "defects_", "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"vars", "=", 
         RowBox[{"Variables", "[", "defects", "]"}]}], ",", "products", ",", 
        "traces", ",", "decompositions", ",", "result"}], "}"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Calculate", " ", "Fusion", " ", "among", " ", "members", " ", "of", " ",
         "family"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"products", "=", 
        RowBox[{"DeleteDuplicates", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"Outer", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"#1", "\[CircleTimes]", "#2"}], "&"}], ",", "defects", ",",
              "defects", ",", "1", ",", "1"}], "]"}], ",", "1"}], "]"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"traces", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"tr", "/@", "#"}], "&"}], "/@", "products"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Constrain", " ", "their", " ", "possible", " ", "fusion", " ", 
         "pathways", " ", "and", " ", "turn", " ", "them", " ", "into", " ", 
         "equations", " ", "using", " ", "their", " ", "traces"}], " ", 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"PossibleSimpleDecompositions", "/@", "traces"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"MapThread", "[", 
         RowBox[{"ReduceDecompositions", ",", 
          RowBox[{"{", 
           RowBox[{
           "products", ",", " ", "traces", ",", " ", "decompositions"}], 
           "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"result", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"defects", "//.", "#"}], ")"}], "&"}], "/@", 
           RowBox[{"(", 
            RowBox[{"QuietSolve", "[", 
             RowBox[{
              RowBox[{"N", "[", "decompositions", "]"}], ",", "vars"}], "]"}],
             ")"}]}], ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "Convert", " ", "numerical", " ", "constants", " ", "back", " ", 
          "to", " ", "algebraic", " ", "form"}], ",", " ", 
         RowBox[{"preserving", " ", "variables"}]}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"result", "=", 
        RowBox[{"result", "/.", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"a_", "?", "NumericQ"}], "/;", 
           RowBox[{"!", 
            RowBox[{"IntegerQ", "[", "a", "]"}]}]}], ":>", 
          RowBox[{"RootApproximant", "[", 
           RowBox[{"a", ",", "4"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"CanonicalizeVars", "@", 
        RowBox[{"DeleteDuplicates", "[", 
         RowBox[{
          RowBox[{"Simplify", "@", "result"}], ",", "OrbitQ"}], "]"}]}]}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.986214125757845*^9, 3.986214245980966*^9}, {
   3.9862142837183437`*^9, 3.98621430572554*^9}, {3.986214362438805*^9, 
