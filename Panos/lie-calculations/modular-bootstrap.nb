   3.986213337788907*^9}, {3.9862135375328493`*^9, 3.9862135465673027`*^9}, 
   3.986213756739834*^9, {3.986213809637148*^9, 3.986213810690742*^9}, 
   3.986214216870277*^9, {3.9862162046133213`*^9, 3.986216208333033*^9}, {
   3.986216326099175*^9, 3.986216339070815*^9}, {3.9862163780839853`*^9, 
   3.986216383225006*^9}, {3.986216492426753*^9, 3.986216493698085*^9}, {
