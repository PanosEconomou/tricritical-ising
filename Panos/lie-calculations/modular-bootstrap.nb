       "Calculate", " ", "Fusion", " ", "among", " ", "members", " ", "of", " ",
         "family"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"products", "=", 
        RowBox[{"DeleteDuplicates", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"Outer", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"#1", "\[CircleTimes]", "#2"}], "&"}], ",", "defects", ",",
              "defects", ",", "1", ",", "1"}], "]"}], ",", "1"}], "]"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"traces", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"tr", "/@", "#"}], "&"}], "/@", "products"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Constrain", " ", "their", " ", "possible", " ", "fusion", " ", 
         "pathways", " ", "and", " ", "turn", " ", "them", " ", "into", " ", 
         "equations", " ", "using", " ", "their", " ", "traces"}], " ", 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"PossibleSimpleDecompositions", "/@", "traces"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"MapThread", "[", 
         RowBox[{"ReduceDecompositions", ",", 
          RowBox[{"{", 
           RowBox[{
           "products", ",", " ", "traces", ",", " ", "decompositions"}], 
           "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"result", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"defects", "//.", "#"}], ")"}], "&"}], "/@", 
           RowBox[{"(", 
            RowBox[{"QuietSolve", "[", 
             RowBox[{
              RowBox[{"N", "[", "decompositions", "]"}], ",", "vars"}], "]"}],
             ")"}]}], ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
