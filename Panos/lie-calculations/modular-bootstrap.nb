   3.986466187998774*^9, 3.986466190191012*^9}, 3.986466265337545*^9, {
   3.986466311914227*^9, 3.9864663163435097`*^9}, {3.986490871045372*^9, 
   3.9864910025802298`*^9}, {3.986491039470964*^9, 3.986491095528256*^9}, {
   3.986491133615716*^9, 3.986491143866287*^9}, {3.98649119078953*^9, 
   3.9864912077647123`*^9}, {3.98649133399275*^9, 3.9864913776626663`*^9}, {
