   3.9862242635800962`*^9}, {3.9862243001839857`*^9, 3.986224309336206*^9}, {
   3.9862243394328833`*^9, 3.986224340528593*^9}, {3.986224389946123*^9, 
   3.9862243931204863`*^9}, {3.986224589041809*^9, 3.986224589363097*^9}, {
