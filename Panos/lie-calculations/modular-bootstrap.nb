   3.986208479800243*^9, 3.986208555432332*^9}, {3.986208589957261*^9, 
   3.9862086002562037`*^9}, {3.986208689913147*^9, 3.986208698008705*^9}, {
   3.986208776625242*^9, 3.986208781299219*^9}, {3.986208835510778*^9, 
   3.9862088451850567`*^9}, {3.9862089480963993`*^9, 3.986209023766555*^9}, {
   3.9862090570931396`*^9, 3.986209363743894*^9}, {3.986209512823847*^9, 
   3.986209513221322*^9}, {3.9862096348783503`*^9, 3.9862096608273697`*^9}, {
   3.986211951092903*^9, 3.986211951458139*^9}, {3.986214651753705*^9, 
   3.986214658405149*^9}, 3.9862147982513733`*^9, {3.986214905458289*^9, 
   3.986214908834524*^9}, {3.986215550582745*^9, 3.986215558437234*^9}, {
   3.9862158504409103`*^9, 3.9862158668721333`*^9}, {3.986215926582664*^9, 
   3.986215929767542*^9}, {3.986215989452331*^9, 3.986215989707466*^9}, 
   3.986216157588172*^9, {3.986221605048444*^9, 3.986221610107263*^9}, {
   3.986221651827405*^9, 3.986221654346912*^9}, {3.9862217070917587`*^9, 
   3.9862217629414387`*^9}, {3.986221796501652*^9, 3.986221901238233*^9}, {
   3.986221956320776*^9, 3.986221972921953*^9}, {3.986222341587051*^9, 
   3.986222381611492*^9}, {3.986222497699953*^9, 3.9862225059674063`*^9}, {
   3.986222602867491*^9, 3.9862226371569557`*^9}, {3.986223102584878*^9, 
   3.986223102898458*^9}, {3.986224037206153*^9, 3.986224047281962*^9}, {
