Cell[CellGroupData[{

Cell["Search Fusion Rules", "Subsection",
 CellChangeTimes->{{3.985357275402993*^9, 
  3.985357279185727*^9}},ExpressionUUID->"4a25c2cf-92f7-4695-bfe8-\
ec87fb8ae6f3"],

Cell["\<\
Since we can obtain some partial information for the fusion rules among \
defects belonging to each family we can extract and list them in the following\
\>", "Text",
 CellChangeTimes->{{3.9853572836175137`*^9, 3.985357326258501*^9}, {
  3.98560630134757*^9, 
  3.985606303514105*^9}},ExpressionUUID->"42886f58-f746-48dc-bda3-\
3bee21925f9a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Takes", " ", "a", " ", "matrix", " ", "M", " ", "and", " ", "a", " ", 
    "vector", " ", "v", " ", "and", " ", "finds", " ", "all", " ", "possible",
     " ", "nonnegative", " ", "integer", " ", "combinations", " ", "of", " ", 
    "rows", " ", "of", " ", "M", " ", "that", " ", "sum", " ", "to", " ", 
    "v"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"FindIntegerCombinations", "[", 
      RowBox[{"M_", ",", "v_"}], "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"n", "=", 
          RowBox[{"Length", "[", "M", "]"}]}], ",", 
         RowBox[{"m", "=", 
          RowBox[{"Length", "[", "v", "]"}]}], ",", 
         RowBox[{"MT", "=", 
          RowBox[{"Transpose", "[", 
           RowBox[{"N", "[", "M", "]"}], "]"}]}], ",", "ubounds", ",", " ", 
         "enumerate", ",", 
         RowBox[{"results", "=", 
          RowBox[{"{", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Use", " ", "linear", " ", "programming", " ", "to", " ", "estimate", 
         " ", "the", " ", "maximum", " ", "number", " ", "a", " ", "row", " ",
          "can", " ", "be", " ", "added", " ", "in", " ", "a", " ", 
         "solution", " ", "for", " ", "v"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ubounds", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Module", "[", 
            RowBox[{
             RowBox[{"{", "sol", "}"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"sol", "=", 
               RowBox[{"Quiet", "[", 
                RowBox[{"LinearProgramming", "[", 
                 RowBox[{
                  RowBox[{"-", 
                   RowBox[{"UnitVector", "[", 
                    RowBox[{"n", ",", "i"}], "]"}]}], ",", "MT", ",", 
                  RowBox[{"Transpose", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"N", "[", "v", "]"}], ",", 
                    RowBox[{"ConstantArray", "[", 
                    RowBox[{"0", ",", "m"}], "]"}]}], "}"}], "]"}], ",", 
                  RowBox[{"ConstantArray", "[", 
                   RowBox[{"0", ",", "n"}], "]"}]}], "]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"VectorQ", "[", "sol", "]"}], ",", 
                RowBox[{"Max", "[", 
                 RowBox[{"0", ",", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"sol", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "//", "Chop"}], "//", 
                   "RootApproximant"}]}], "]"}], ",", "sol"}], "]"}]}]}], 
            "]"}], "\[IndentingNewLine]", ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "n"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Explore", " ", "the", " ", "rest", " ", "recursively", " ", "until",
           " ", "you", " ", "hit", " ", "zero"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"enumerate", "[", 
          RowBox[{"rem_", ",", "idx_", ",", "current_"}], "]"}], ":=", 
         RowBox[{"Which", "[", 
          RowBox[{
           RowBox[{"idx", ">", "n"}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Chop", "[", 
               RowBox[{"N", "[", "rem", "]"}], "]"}], "==", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"0", ",", "m"}], "]"}]}], ",", 
             RowBox[{"AppendTo", "[", 
              RowBox[{"results", ",", "current"}], "]"}]}], "]"}], ",", 
           "True", ",", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"enumerate", "[", 
              RowBox[{
               RowBox[{"rem", "-", 
                RowBox[{"k", "*", 
                 RowBox[{"M", "[", 
                  RowBox[{"[", "idx", "]"}], "]"}]}]}], ",", 
               RowBox[{"idx", "+", "1"}], ",", 
               RowBox[{"Append", "[", 
                RowBox[{"current", ",", "k"}], "]"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"k", ",", "0", ",", 
               RowBox[{"ubounds", "[", 
                RowBox[{"[", "idx", "]"}], "]"}]}], "}"}]}], "]"}]}], "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"enumerate", "[", 
         RowBox[{"v", ",", "1", ",", 
          RowBox[{"{", "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
        "results"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", "FindIntegerCombinationsCached", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"FindIntegerCombinationsCached", "[", 
      RowBox[{"M_", ",", "v_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"FindIntegerCombinationsCached", "[", 
       RowBox[{"M", ",", "v"}], "]"}], "=", 
      RowBox[{"FindIntegerCombinations", "[", 
       RowBox[{"M", ",", "v"}], "]"}]}]}], ";"}]}]}]], "Input",
