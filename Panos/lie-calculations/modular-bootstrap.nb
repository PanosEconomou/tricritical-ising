                   RowBox[{"hv", "@@", "a1"}], "+", 
                   RowBox[{"hv", "@@", "b1"}], "-", 
                   FractionBox["cv", "12"]}], ")"}]}], "]"}]}], ",", 
              "\[IndentingNewLine]", "True", ",", "0"}], "]"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"s", "=", 
         RowBox[{"Simplify", "[", 
          RowBox[{
           RowBox[{"Array", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"sMaker", "[", 
               RowBox[{
                RowBox[{"i", "[", 
                 RowBox[{"[", "#1", "]"}], "]"}], ",", 
                RowBox[{"i", "[", 
                 RowBox[{"[", "#2", "]"}], "]"}]}], "]"}], "&"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Length", "[", "i", "]"}], ",", 
               RowBox[{"Length", "[", "i", "]"}]}], "}"}]}], "]"}], ",", 
           RowBox[{"ComplexityFunction", "->", "LeafCount"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"s", ",", "t", ",", "i"}], "}"}]}]}], "\[IndentingNewLine]", 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"s", ",", "t", ",", "i"}], "}"}], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Clear", "[", 
         RowBox[{"s", ",", "t", ",", "i"}], "]"}], ";", 
        RowBox[{"FoldedMinimalModularData", "[", 
         RowBox[{"5", ",", "4"}], "]"}]}], ")"}], "//", "Time"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Modular", " ", "Mass", " ", "Matrix"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"z", "=", 
       RowBox[{"Outer", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"KroneckerDelta", "[", 
              RowBox[{"#1", ",", "#2"}], "]"}], " ", "+", " ", 
             RowBox[{
              RowBox[{"KroneckerDelta", "[", 
               RowBox[{
                RowBox[{"#1", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], ",", 
                RowBox[{"#2", "[", 
                 RowBox[{"[", "1", "]"}], "]"}]}], "]"}], 
              RowBox[{"KroneckerDelta", "[", 
               RowBox[{
                RowBox[{"#1", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], ",", 
                RowBox[{"#2", "[", 
                 RowBox[{"[", "2", "]"}], "]"}]}], "]"}], 
              RowBox[{"KroneckerDelta", "[", 
               RowBox[{
                RowBox[{"#1", "[", 
                 RowBox[{"[", "3", "]"}], "]"}], ",", 
                RowBox[{"-", 
                 RowBox[{"#2", "[", 
                  RowBox[{"[", "3", "]"}], "]"}]}]}], "]"}]}]}], ")"}], 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"KroneckerDelta", "[", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"#1", "[", 
                 RowBox[{"[", "3", "]"}], "]"}], "]"}], ",", "2"}], "]"}]}], 
            ")"}], 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"KroneckerDelta", "[", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"#2", "[", 
                 RowBox[{"[", "3", "]"}], "]"}], "]"}], ",", "2"}], "]"}]}], 
            ")"}]}], "&"}], ",", "i", ",", "i", ",", "1"}], "]"}]}], ";"}], "//",
      "Time"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"MatrixPlot", "[", 
    RowBox[{"z", ",", 
     RowBox[{"PlotLabel", "->", "\"\<Modular Mass Matrix z\>\""}]}], 
    "]"}]}]}]], "Input",
