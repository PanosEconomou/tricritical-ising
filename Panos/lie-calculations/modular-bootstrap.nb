Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Obtain", " ", "a", " ", "general", " ", "Gauge", " ", "Transformation", " ",
     "that", " ", "preserves", " ", "the", " ", "solved", " ", "Lines"}], " ",
    "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"gaugeVars", "=", " ", 
     RowBox[{"getVars", "[", "L", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gaugeVarRules", "=", 
     RowBox[{"Thread", "[", 
      RowBox[{"gaugeVars", "!=", "0"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GetGeneralGaugeTransform", "[", 
      RowBox[{"L_", ",", "gaugeVars_", ",", "gaugeVarRules_", ",", 
       RowBox[{"var_", ":", "P"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Lp", ",", "LpInvertibleQ", ",", "Lpp"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Build", " ", "a", " ", "General", " ", "Gauge", " ", 
         "Transformation"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Lp", "=", 
         RowBox[{"Array", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Which", "[", 
             RowBox[{
              RowBox[{"!", 
               RowBox[{"deg", "[", "#", "]"}]}], ",", "1", ",", 
              RowBox[{"deg", "[", "#", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"var", "[", 
                   RowBox[{"#", ",", "1"}], "]"}], " ", ",", 
                  RowBox[{"var", "[", 
                   RowBox[{"#", ",", "2"}], "]"}]}], " ", "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"var", "[", 
                   RowBox[{"#", ",", "3"}], "]"}], ",", 
                  RowBox[{"var", "[", 
                   RowBox[{"#", ",", "4"}], "]"}]}], "}"}]}], "}"}]}], "]"}], 
            "&"}], ",", "famNum"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Lp", "=", 
         RowBox[{"(", 
          RowBox[{"Lp", " ", "//.", 
           RowBox[{"{", 
            RowBox[{"Assuming", "[", 
             RowBox[{"gaugeVarRules", ",", 
              RowBox[{"ToRules", "[", 
               RowBox[{"Reduce", "[", 
                RowBox[{
                 RowBox[{"And", "@@", 
                  RowBox[{"Thread", "[", 
                   RowBox[{
                    RowBox[{"Flatten", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Lp", "\[CircleTimes]", "#"}], " ", "-", 
                    RowBox[{"#", "\[CircleTimes]", "Lp"}]}], ")"}], "&"}], "/@",
                     "L"}], "]"}], "==", "0"}], "]"}]}], ",", 
                 RowBox[{"Backsubstitution", "->", "True"}]}], "]"}], "]"}]}],
              "]"}], "}"}]}], ")"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Lpp", "=", 
         RowBox[{"DeleteElements", "[", 
          RowBox[{
           RowBox[{"Variables", "[", "Lp", "]"}], ",", "gaugeVars"}], "]"}]}],
         ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Checks", " ", "if", " ", "Lp", " ", "is", " ", "invertible", " ", 
          "for", " ", "a", " ", "given", " ", "numerical", " ", "set", " ", 
          "of", " ", "P", " ", "variables"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"vars", "=", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"Unique", "[", "\"\<p\>\"", "]"}], ",", 
               RowBox[{"Length", "@", "Lpp"}]}], "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"varsg", "=", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"Unique", "[", "\"\<g\>\"", "]"}], ",", 
               RowBox[{"Length", "@", "gaugeVars"}]}], "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"invertibleLp", "=", 
             RowBox[{"And", "@@", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"Simplify", "@", 
                   RowBox[{"Not", "@", 
                    RowBox[{"Reduce", "[", 
                    RowBox[{"Or", "@@", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Which", "[", 
                    RowBox[{
                    RowBox[{"MatrixQ", "[", "#", "]"}], ",", 
                    RowBox[{
                    RowBox[{"Det", "[", "#", "]"}], "==", "0"}], ",", "True", 
                    ",", 
                    RowBox[{"#", "==", "0"}]}], "]"}], "&"}], "/@", "#"}], 
                    ")"}]}], "]"}]}]}], ")"}], "&"}], "/@", "Lp"}], 
               ")"}]}]}]}], "\[IndentingNewLine]", "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"invertibleLp", "=", 
            RowBox[{
             RowBox[{"invertibleLp", "/.", 
              RowBox[{"Thread", "[", 
               RowBox[{"Lpp", "->", "vars"}], "]"}]}], "/.", 
             RowBox[{"Thread", "[", 
              RowBox[{"gaugeVars", "->", "varsg"}], "]"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"LpInvertibleQ", ":=", 
            RowBox[{"Function", "@@", 
             RowBox[{"{", 
              RowBox[{"vars", ",", 
               RowBox[{"Assuming", "[", 
                RowBox[{
                 RowBox[{"gaugeVarRules", "/.", 
                  RowBox[{"Thread", "[", 
                   RowBox[{"gaugeVars", "->", "varsg"}], "]"}]}], ",", 
                 RowBox[{"Simplify", "[", 
                  RowBox[{"Evaluate", "[", "invertibleLp", "]"}], "]"}]}], 
                "]"}]}], "}"}]}]}]}]}], "\[IndentingNewLine]", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"Lp", ",", "Lpp", ",", "LpInvertibleQ"}], "}"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"Lp", ",", "Lpp", ",", "LpInvertibleQ"}], "}"}], "=", 
    RowBox[{"GetGeneralGaugeTransform", "[", 
     RowBox[{"L", ",", "gaugeVars", ",", "gaugeVarRules", ",", "P"}], "]"}]}],
    "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.9864625420813017`*^9, 3.98646257916945*^9}, {
