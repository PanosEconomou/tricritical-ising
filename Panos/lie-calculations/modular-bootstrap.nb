 CellLabel->"In[87]:=",ExpressionUUID->"39c142b6-7f29-44a9-9ff1-0512b054f5c2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"GaugeInvariantConstraints", "[", 
   RowBox[{"L_", ",", 
    RowBox[{"Lp_", ":", "Lp"}], ",", 
    RowBox[{"Lpp_", ":", "Lpp"}], ",", 
    RowBox[{"gaugeVarRules_", ":", "gaugeVarRules"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"gaugedL", ",", "orbitEqns"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"The", " ", "orbit", " ", 
       RowBox[{"equation", ":", 
        RowBox[{"L", "'"}]}]}], "=", 
      RowBox[{"Lp", "\[CircleTimes]", "L", "\[CircleTimes]", 
       RowBox[{"Lp", "^", 
        RowBox[{"{", 
         RowBox[{"-", "1"}], "}"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"gaugedL", "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Lp", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "\[CircleTimes]", "L", "\[CircleTimes]", 
         RowBox[{"inv", "/@", 
          RowBox[{"(", 
           RowBox[{"Lp", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ")"}]}]}], ",", 
        RowBox[{"Assumptions", "->", "gaugeVarRules"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "Equations", " ", "saying", " ", "L", " ", "is", " ", "fixed", " ", 
        "by", " ", "the", " ", "orbit"}], ",", 
       RowBox[{"eliminate", " ", "gauge", " ", "params"}]}], "*)"}], 
     RowBox[{"orbitEqns", "=", 
      RowBox[{"And", "@@", 
       RowBox[{"Flatten", "@", 
        RowBox[{"MapThread", "[", 
         RowBox[{"Equal", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Flatten", "[", "gaugedL", "]"}], ",", 
            RowBox[{"Flatten", "[", "L", "]"}]}], "}"}]}], "]"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Echo", "[", 
      RowBox[{"orbitEqns", ",", 
       RowBox[{"And", "@@", "gaugeVarRules"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Eliminate", "[", 
      RowBox[{
       RowBox[{"orbitEqns", "&&", 
        RowBox[{"And", "@@", "gaugeVarRules"}]}], ",", "Lpp"}], "]"}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.98622500593055*^9, 3.986225097995513*^9}, {
