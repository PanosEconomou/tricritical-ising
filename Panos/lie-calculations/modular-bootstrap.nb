    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"conjugateOrbit", "[", 
      RowBox[{"x_", ",", 
       RowBox[{"Li_", ":", "Li"}], ",", 
       RowBox[{"gaugeVarRules_", ":", "gaugeVarRules"}]}], "]"}], ":=", 
