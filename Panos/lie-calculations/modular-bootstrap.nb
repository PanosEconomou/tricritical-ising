             "&"}], ",", "L", ",", "L", ",", "1", ",", "1"}], "]"}], ",", 
          "1"}], "]"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
