Cell[CellGroupData[{

Cell["Orbit Fixing", "Subsection",
 CellChangeTimes->{{3.98649228594814*^9, 
  3.986492296367241*^9}},ExpressionUUID->"b5e94356-ac67-4b78-bb47-\
361928ff67bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Given", " ", "a", " ", "function", " ", "f", " ", "and", " ", "a", " ", 
     "group", " ", "G"}], ",", " ", 
    RowBox[{
     RowBox[{"checks", " ", "if", " ", "f", 
      RowBox[{"(", 
       RowBox[{"G", " ", "A", " ", "G"}], ")"}]}], " ", "==", " ", 
     RowBox[{"f", 
      RowBox[{"(", "A", ")"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"CheckInvariant", "[", 
      RowBox[{"f_", ",", "A_", ",", "G_"}], "]"}], ":=", 
     RowBox[{"AllTrue", "[", 
      RowBox[{
       RowBox[{"Tuples", "[", 
        RowBox[{"{", 
         RowBox[{"G", ",", "G"}], "}"}], "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"Expand", "[", 
          RowBox[{
           RowBox[{"f", "[", "A", "]"}], "-", 
           RowBox[{"f", "[", 
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ".", "A", ".", 
             RowBox[{"#", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "]"}], "===", "0"}], 
        "&"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"CheckInvariantFast", "[", 
      RowBox[{"m_", ",", "orbitSubstitutions_"}], "]"}], ":=", 
     RowBox[{"AllTrue", "[", 
      RowBox[{"orbitSubstitutions", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"Expand", "[", 
          RowBox[{"m", "-", 
           RowBox[{"(", 
            RowBox[{"m", "/.", "#"}], ")"}]}], "]"}], "===", "0"}], "&"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Obtain", " ", "symbolic", " ", "expresssions", " ", "for", " ", "a", " ",
      "generating", " ", "set", " ", "of", " ", "invariants", " ", "under", " ",
      "the", " ", "orbit", " ", "of", " ", "some", " ", "lines"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Optimization", ":", " ", 
     RowBox[{
      RowBox[{"Have", " ", "Z"}], "-", 
      RowBox[{
      "Solve", " ", "solve", " ", "the", " ", "bigger", " ", "matrix", " ", 
       "instead"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Needs", "[", "\"\<math4ti2`\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ClearAll", "[", "OrbitInvariantsSingle", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"OrbitInvariantsSingle", "[", 
      RowBox[{"A_", ",", "G_", ",", "upToOrder_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"OrbitInvariantsSingle", "[", 
       RowBox[{"A", ",", "G", ",", "upToOrder"}], "]"}], "=", 
      RowBox[{"Module", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"vars", " ", "=", 
           RowBox[{"Variables", "[", "A", "]"}]}], ",", "monomials", ",", 
          RowBox[{"flatA", "=", 
           RowBox[{"Flatten", "[", "A", "]"}]}], ",", "orbitSubstitutions", ",",
           "invariantMonomials", ",", "exponents", ",", "basis"}], "}"}], ",",
         "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "Calculate", " ", "a", " ", "lot", " ", "of", " ", "monomials", " ",
            "in", " ", "the", " ", "variables", " ", "of", " ", "A"}], ",", 
          " ", 
          RowBox[{
          "and", " ", "find", " ", "which", " ", "ones", " ", "are", " ", 
           "invariant", " ", "under", " ", "the", " ", "group", " ", 
           "action"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"monomials", "=", 
          RowBox[{"DeleteCases", "[", 
           RowBox[{
            RowBox[{"MonomialList", "[", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"1", "+", 
                RowBox[{"Total", "[", "vars", "]"}]}], ")"}], "upToOrder"], 
             "]"}], ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"orbitSubstitutions", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"Thread", "[", 
             RowBox[{"flatA", "->", 
              RowBox[{"Flatten", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], ".", "A", ".", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}]}], ")"}], " ", "&"}], "/@", 
             " ", 
             RowBox[{"Tuples", "[", 
              RowBox[{"{", 
               RowBox[{"G", ",", "G"}], "}"}], "]"}]}], ")"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"invariantMonomials", "=", 
          RowBox[{"Sort", "[", 
           RowBox[{"Select", "[", 
            RowBox[{"monomials", ",", 
             RowBox[{
              RowBox[{"CheckInvariantFast", "[", 
               RowBox[{"#", ",", "orbitSubstitutions"}], "]"}], "&"}]}], 
            "]"}], "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{
          "Solve", " ", "for", " ", "the", " ", "minimum", " ", 
           "algebraically", " ", "independent", " ", "polynomials", " ", "by",
            " ", "finding", " ", "a", " ", "Hilbert", " ", "basis", " ", "on",
            " ", "the", " ", "exponents"}], " ", "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"exponents", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"Exponent", "[", 
             RowBox[{"#", ",", " ", "vars"}], "]"}], "&"}], "/@", 
           "invariantMonomials"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"basis", "=", 
          RowBox[{
           RowBox[{"math4ti2`hilbert", "[", "exponents", "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{"Convert", " ", "Back", " ", "to", " ", "symbols"}], " ", 
          "*)"}], "\[IndentingNewLine]", 
         RowBox[{"Times", " ", "@@@", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             SuperscriptBox["vars", "#"], "&"}], "/@", "basis"}], ")"}]}]}]}],
        "\[IndentingNewLine]", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"OrbitInvariants", "[", 
      RowBox[{"x_", ",", "defects_", ",", 
       RowBox[{"upToOrder_Integer", ":", "4"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"OrbitInvariants", "[", 
       RowBox[{"x", ",", "defects", ",", "upToOrder"}], "]"}], "=", 
      RowBox[{"MapThread", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"A", ",", "G"}], "}"}], "|->", 
         RowBox[{"Which", "[", 
          RowBox[{
           RowBox[{"MatrixQ", "[", "A", "]"}], ",", 
           RowBox[{"OrbitInvariantsSingle", "[", 
            RowBox[{"A", ",", "G", ",", "upToOrder"}], "]"}], ",", "True", ",", 
           RowBox[{"{", "}"}]}], "]"}]}], "\[IndentingNewLine]", ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"Transpose", "[", "defects", "]"}]}], "}"}]}], "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Somtimes", " ", "invariants", " ", "can", " ", "be", " ", "related", " ",
       "to", " ", "each", " ", "other"}], ",", " ", 
     RowBox[{"this", " ", "calculates", " ", "their", " ", "relations"}]}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ClearAll", "[", "Syzygies", "]"}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"Syzygies", "[", "invariants_", "]"}], ":=", 
     RowBox[{
      RowBox[{"Syzygies", "[", "invariants", "]"}], "=", 
      RowBox[{"Module", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"varsGauge", "=", 
           RowBox[{"Variables", "[", "invariants", "]"}]}], ",", 
          RowBox[{"vars", "=", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"Unique", "[", "\"\<a\>\"", "]"}], ",", 
             RowBox[{"Length", "@", "invariants"}]}], "]"}]}]}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "==", "0"}], "&"}], "/@", 
         RowBox[{"GroebnerBasis", "[", 
          RowBox[{
           RowBox[{"MapThread", "[", 
            RowBox[{"Equal", ",", 
             RowBox[{"{", 
              RowBox[{"invariants", ",", "vars"}], "}"}]}], "]"}], ",", 
           "vars", ",", "varsGauge"}], "]"}]}]}], "\[IndentingNewLine]", 
       "]"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Calculate", " ", "the", " ", "invariants", " ", "for", " ", "the", " ", 
     "invertible", " ", "lines", " ", "up", " ", "to", " ", "Gauge", " ", 
     "Transformation"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ll", "=", 
     RowBox[{"lGaugeFixed", "[", "x", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"llflat", "=", 
     RowBox[{"Flatten", "[", "ll", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"invertibleInvariants", "=", 
     RowBox[{"OrbitInvariants", "[", 
      RowBox[{"ll", ",", "Li"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"InvertibleInvariants", "=", 
     RowBox[{"Function", "[", 
      RowBox[{"x", ",", 
       RowBox[{"invertibleInvariants", "/.", 
        RowBox[{"Thread", "[", 
         RowBox[{"llflat", "->", 
          RowBox[{"Flatten", "[", "x", "]"}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"invertibleSyzygies", "=", 
     RowBox[{"Syzygies", "/@", "invertibleInvariants"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Check", " ", "if", " ", "two", " ", "lines", " ", "are", " ", "in", " ", 
     "the", " ", "same", " ", "orbit"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", "InvertibleOrbitQ", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"InvertibleOrbitQ", "[", 
     RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"InvertibleOrbitQ", "[", 
      RowBox[{"x", ",", "y"}], "]"}], "=", 
     RowBox[{"AllTrue", "[", 
      RowBox[{
       RowBox[{"Flatten", "@", 
        RowBox[{"Expand", "[", 
         RowBox[{
          RowBox[{"InvertibleInvariants", "[", "x", "]"}], "-", 
          RowBox[{"InvertibleInvariants", "[", "y", "]"}]}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"#", "===", "0"}], "&"}]}], "]"}]}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "A", " ", "solve", " ", "function", " ", "that", " ", "uses", " ", 
     "orbit", " ", "fixing", " ", "to", " ", "speed", " ", "things", " ", 
     "up"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"QuietSolveOrbitFixed", "[", 
      RowBox[{"eqns_", ",", "orbitInvariants_", ",", "vars_"}], "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"orbitVars", "=", 
          RowBox[{"Array", "[", 
           RowBox[{"\[FormalA]", ",", 
            RowBox[{"Length", "@", "orbitInvariants"}]}], "]"}]}], ",", 
         "orbitEqns", ",", "orbitSols", ",", "sygyzies"}], "}"}], ",", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Solve", " ", "the", " ", "equation", " ", "in", " ", "invariant", " ",
          "space"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"orbitEqns", "=", 
         RowBox[{"GroebnerBasis", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Join", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"List", "@@", "eqns"}], ")"}], "/.", " ", 
              RowBox[{
               RowBox[{"Equal", "[", 
                RowBox[{"a_", ",", "b_"}], "]"}], ":>", 
               RowBox[{"a", "-", "b"}]}]}], ",", "\[IndentingNewLine]", 
             RowBox[{"MapThread", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"#1", "-", "#2"}], "&"}], ",", 
               RowBox[{"{", 
                RowBox[{"orbitInvariants", ",", "orbitVars"}], "}"}]}], 
              "]"}]}], "\[IndentingNewLine]", "]"}], ",", 
           "\[IndentingNewLine]", "orbitVars", ",", "\[IndentingNewLine]", 
           "vars", ",", "\[IndentingNewLine]", 
           RowBox[{"MonomialOrder", "->", "EliminationOrder"}]}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"orbitSols", "=", " ", 
         RowBox[{"QuietSolve", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"#", "==", "0"}], "&"}], "/@", "orbitEqns"}], ",", 
           "orbitVars"}], "]"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"sygyzies", "=", 
         RowBox[{"Syzygies", "[", "orbitInvariants", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"First", "@", 
           RowBox[{"QuietSolve", "[", 
            RowBox[{
             RowBox[{"Join", "[", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{
                RowBox[{"MapThread", "[", 
                 RowBox[{"Equal", ",", 
                  RowBox[{"{", 
                   RowBox[{"orbitVars", ",", "orbitInvariants"}], "}"}]}], 
                 "]"}], "/.", "#"}], ",", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{
                 RowBox[{"#", "==", "0"}], "&"}], "/@", "sygyzies"}]}], 
              "\[IndentingNewLine]", "]"}], ",", "vars"}], "]"}]}], "&"}], "/@",
          "orbitSols"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.986492615551046*^9, 3.9864927267928963`*^9}, {
   3.986492767961135*^9, 3.986492826033185*^9}, {3.986493753581959*^9, 
   3.986493945446437*^9}, {3.986494001296447*^9, 3.9864941087534447`*^9}, {
   3.986494140017654*^9, 3.986494164817541*^9}, 3.9864942403540363`*^9, {
   3.986494283178176*^9, 3.986494474967704*^9}, {3.9864947115495043`*^9, 
   3.9864947894211817`*^9}, {3.98649483698139*^9, 3.9864948495500813`*^9}, {
   3.9864949602631617`*^9, 3.986494961877528*^9}, 3.986494992843454*^9, {
   3.9864950434225807`*^9, 3.986495102567075*^9}, {3.9864951645685883`*^9, 
   3.986495208190531*^9}, {3.986495308135393*^9, 3.986495359070558*^9}, {
   3.986495397486717*^9, 3.986495402306525*^9}, 3.986495493319303*^9, 
   3.986495530139099*^9, {3.9864956382802887`*^9, 3.986495855809586*^9}, {
   3.986495981695784*^9, 3.9864959839296923`*^9}, {3.9864960214339037`*^9, 
   3.986496154602016*^9}, {3.986496197923786*^9, 3.986496348355246*^9}, {
   3.98649652554744*^9, 3.9864965407998238`*^9}, {3.986496573854577*^9, 
   3.986496614543787*^9}, {3.986496648825388*^9, 3.986496669317945*^9}, {
   3.986496742646738*^9, 3.986496822184966*^9}, {3.9864968868397903`*^9, 
   3.986497012243882*^9}, {3.986497085648231*^9, 3.9864972414420443`*^9}, {
   3.986497284662483*^9, 3.986497319411518*^9}, {3.98649735394545*^9, 
   3.986497386527021*^9}, {3.9864974168827477`*^9, 3.986497437213365*^9}, {
   3.986497475731086*^9, 3.986497530446123*^9}, {3.986498253890107*^9, 
   3.98649845683248*^9}, {3.986498504367332*^9, 3.986498507446966*^9}, {
   3.986498658528129*^9, 3.986498741290824*^9}, {3.986498776375641*^9, 
   3.986498777253932*^9}, {3.9864988385748987`*^9, 3.98649912888935*^9}, {
   3.986499293444872*^9, 3.9864993310550737`*^9}, {3.986499385757964*^9, 
   3.986499395354576*^9}, {3.986499601061389*^9, 3.986499603449645*^9}, {
   3.9864996595589857`*^9, 3.986499774541402*^9}, {3.986499897991362*^9, 
