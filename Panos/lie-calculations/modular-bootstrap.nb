Cell[CellGroupData[{

Cell["Constraining with Dual Fusion", "Section",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Python", "SessionID" -> "default-python-session", 
     "Evaluator" -> Automatic|>|>,
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.9859465410744543`*^9, 3.98594654740558*^9}, {
  3.985946584082862*^9, 3.985946599817297*^9}, {3.9859468586786833`*^9, 
  3.985946891091023*^9}, {3.98621206006116*^9, 3.9862120873898563`*^9}, {
  3.986213878643474*^9, 
  3.986213879902981*^9}},ExpressionUUID->"e70a6dd4-4f7f-442e-b8b6-\
b9e54ce2b61c"],

Cell["\<\
Each defect must fuse with its dual such that it produces the identity. In a \
unitary representation the dual is given by the conjugate transpose, and \
therefore we can impose this as a consistency condition as well. \
\>", "Text",
 CellChangeTimes->{{3.985946901570898*^9, 3.985947046811798*^9}, {
  3.985947098428143*^9, 3.985947113563995*^9}, {3.986212065085133*^9, 
  3.986212120021104*^9}},ExpressionUUID->"2ff4fc7a-a9b2-47d5-92bd-\
3432c7158e9d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Constrain", " ", "using", " ", "fusion", " ", "with", " ", "their", " ", 
    "dual"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ConstrainWithDualFusion", "[", 
     RowBox[{"defects_", ",", 
      RowBox[{"Li_", ":", "Li"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"vars", "=", 
         RowBox[{"Variables", "[", "defects", "]"}]}], ",", "products", ",", 
        "traces", ",", "decompositions", ",", "orbitInvariants", ",", 
        "result"}], "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      
      RowBox[{"(*", " ", 
       RowBox[{
       "Calculate", " ", "Fusion", " ", "among", " ", "members", " ", "of", " ",
         "family"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"products", "=", 
        RowBox[{"Simplify", "[", 
         RowBox[{
          RowBox[{"Flatten", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"#", "\[CircleTimes]", " ", 
                    SuperscriptBox["#", "\[Dagger]"]}], "-", 
                   RowBox[{"Li", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], ")"}], ")"}], ",", 
                RowBox[{"(", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{
                    SuperscriptBox["#", "\[Dagger]"], "\[CircleTimes]", " ", 
                    "#"}], "-", 
                   RowBox[{"Li", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], ")"}], ")"}]}], "}"}], 
              "&"}], "/@", "defects"}], ",", "1"}], "]"}], ",", 
          RowBox[{"Assumptions", "->", 
           RowBox[{"Thread", "[", 
            RowBox[{"vars", "\[Element]", "Reals"}], "]"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"traces", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"tr", "/@", "#"}], "&"}], "/@", "products"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Constrain", " ", "their", " ", "possible", " ", "fusion", " ", 
         "pathways", " ", "and", " ", "turn", " ", "them", " ", "into", " ", 
         "equations", " ", "using", " ", "their", " ", "traces"}], " ", 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"PossibleSimpleDecompositions", "/@", "traces"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"MapThread", "[", 
         RowBox[{"ReduceDecompositions", ",", 
          RowBox[{"{", 
           RowBox[{
           "products", ",", " ", "traces", ",", " ", "decompositions"}], 
           "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"orbitInvariants", "=", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"OrbitInvariants", "[", 
            RowBox[{"#", ",", "Li"}], "]"}], "&"}], "/@", "res"}], "//", 
         "Flatten"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"result", "=", 
        RowBox[{"DeleteDuplicates", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"defects", "//.", "#"}], ")"}], "&"}], "/@", 
            RowBox[{"(", 
             RowBox[{"QuietSolveOrbitFixed", "[", 
              RowBox[{
               RowBox[{"And", "@@", "decompositions"}], ",", 
               "orbitInvariants", ",", "vars"}], "]"}], ")"}]}], ",", "1"}], 
          "]"}], "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "Convert", " ", "numerical", " ", "constants", " ", "back", " ", 
          "to", " ", "algebraic", " ", "form"}], ",", " ", 
         RowBox[{"preserving", " ", "variables"}]}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"result", "=", 
        RowBox[{"result", "/.", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"a_", "?", "NumericQ"}], "/;", 
           RowBox[{"!", 
            RowBox[{"IntegerQ", "[", "a", "]"}]}]}], ":>", 
          RowBox[{"RootApproximant", "[", 
           RowBox[{"a", ",", "4"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"CanonicalizeVars", "@", 
        RowBox[{"DeleteDuplicates", "[", 
         RowBox[{
          RowBox[{"Simplify", "@", "result"}], ",", "InvertibleOrbitQ"}], 
         "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{
  3.986212146186796*^9, {3.9862122600112553`*^9, 3.98621229362427*^9}, {
   3.986212343136037*^9, 3.9862124038128567`*^9}, {3.986212459212804*^9, 
