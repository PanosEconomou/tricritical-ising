             RowBox[{"inv", "/@", "#"}], ")"}]}], ",", 
           RowBox[{"Assumptions", "->", "gaugeVarRules"}]}], "]"}], "&"}], "/@",
         "Li"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
