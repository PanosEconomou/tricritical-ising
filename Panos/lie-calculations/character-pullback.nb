       RowBox[{"chiralSolns", ",", "chiralCandidates"}], "}"}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Finally", " ", "we", " ", "can", " ", "define", " ", "a", " ", "change", " ",
     "of", " ", "basis", " ", "matrix", " ", "from", " ", "the", " ", "coset",
