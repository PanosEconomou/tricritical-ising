Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Matrix", " ", "Equations", " ", "for", " ", "each", " ", "module"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Mats", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"CoefficientList", "[", 
           RowBox[{"#", ",", "q", ",", "n"}], "]"}], "&"}], "@", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "&"}], "/@", 
      "candidateCharactersModified"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Vecs", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"CoefficientList", "[", 
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", "q", ",", "n"}], "]"}], "&"}], 
      "/@", "candidateCharactersModified"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "We", " ", "calculate", " ", "a", " ", "basis", " ", "for", " ", "the", " ",
       "null", " ", "space", " ", "for", " ", "each", " ", "module"}], ",", 
     " ", 
     RowBox[{
     "then", " ", "obtain", " ", "a", " ", "particular", " ", "solution"}], ",",
      " ", 
     RowBox[{"and", " ", "finally", " ", "sum", " ", 
      RowBox[{"them", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solve", "=", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"ns", " ", "=", " ", 
           RowBox[{"NullSpace", "[", "#1", "]"}]}], ",", 
          RowBox[{"ls", "=", 
           RowBox[{"LeastSquares", "[", 
            RowBox[{"#1", ",", "#2"}], "]"}]}]}], "}"}], ",", 
        RowBox[{"With", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"length", "=", 
            RowBox[{"Length", "[", "ns", "]"}]}], "}"}], ",", 
          RowBox[{"Normalize", " ", "/@", " ", 
           RowBox[{"(", 
            RowBox[{"ns", "+", 
             RowBox[{"ConstantArray", "[", 
              RowBox[{"ls", ",", "length"}], "]"}]}], ")"}]}]}], "]"}]}], 
       "]"}], "&"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Solns", "=", 
     RowBox[{"MapThread", "[", 
      RowBox[{"solve", ",", 
       RowBox[{"{", 
        RowBox[{"Mats", ",", "Vecs"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Now", " ", "convert", " ", "the", " ", "solutions", " ", "to", " ", 
     "vectors", " ", "where", " ", "each", " ", "coefficient", " ", 
     "corresponds", " ", "to", " ", "an", " ", "ishibashi", " ", "state", " ",
      "in", " ", "the", " ", "Gauged", " ", "model"}], " ", "*)"}], 
   RowBox[{
    RowBox[{"SolnsConverted", "=", 
     RowBox[{"MapThread", "[", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"solnList", ",", "cand"}], "}"}], ",", 
