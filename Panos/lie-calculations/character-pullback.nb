              RowBox[{"Length", "[", "hgM", "]"}]}]}], "}"}], ",", 
           RowBox[{"Map", "[", 
            RowBox[{
             RowBox[{"Function", "[", 
              RowBox[{"v", ",", 
               RowBox[{"Normal", "@", 
                RowBox[{"SparseArray", "[", 
