Cell[BoxData[{
 RowBox[{
  RowBox[{"Sc", "=", 
   RowBox[{
    RowBox[{"Array", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Sqrt]", 
          RowBox[{"(", 
           FractionBox["4", 
            RowBox[{"k", 
             RowBox[{"(", 
              RowBox[{"k", "+", "2"}], ")"}]}]], ")"}]}], 
         RowBox[{"Sin", "[", 
          FractionBox[
           RowBox[{"\[Pi]", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"W", "[", 
               RowBox[{"[", 
                RowBox[{"#1", ",", "1"}], "]"}], "]"}], "+", "1"}], ")"}], 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"W", "[", 
               RowBox[{"[", 
                RowBox[{"#2", ",", "1"}], "]"}], "]"}], "+", "1"}], ")"}]}], 
           RowBox[{"k", "+", "2"}]], "]"}], 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Pi]", " ", 
           FractionBox[
            RowBox[{
             RowBox[{"W", "[", 
              RowBox[{"[", 
               RowBox[{"#1", ",", "2"}], "]"}], "]"}], 
             RowBox[{"W", "[", 
              RowBox[{"[", 
               RowBox[{"#2", ",", "2"}], "]"}], "]"}]}], "k"]}]]}], ")"}], 
       "&"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Length", "[", "W", "]"}], ",", 
        RowBox[{"Length", "[", "W", "]"}]}], "}"}]}], "]"}], "//", 
    "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
