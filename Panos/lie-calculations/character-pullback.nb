Cell[BoxData[{
 RowBox[{
  RowBox[{"Xg", "=", 
   RowBox[{"Rationalize", "[", 
    RowBox[{"Chop", "[", 
     RowBox[{
      RowBox[{"N", "[", "Xvt", "]"}], ",", 
      SuperscriptBox["10", 
       RowBox[{"-", "7"}]]}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Xc", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["q", 
        RowBox[{
         RowBox[{"hw", "@@", "#"}], "-", 
         FractionBox["cw", "24"]}]], 
       RowBox[{"\[Chi]w", "[", 
        RowBox[{
         RowBox[{"#", "[", 
