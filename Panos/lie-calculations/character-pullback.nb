      "chiralCandidateCharactersModified"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "We", " ", "calculate", " ", "a", " ", "basis", " ", "for", " ", "the", " ",
      "null", " ", "space", " ", "for", " ", "each", " ", "module"}], ",", 
    " ", 
    RowBox[{
    "then", " ", "obtain", " ", "a", " ", "particular", " ", "solution"}], ",",
     " ", 
    RowBox[{"and", " ", "finally", " ", "sum", " ", 
     RowBox[{"them", "."}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"chiralSolve", "=", 
   RowBox[{
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"ns", " ", "=", " ", 
         RowBox[{
          RowBox[{"NullSpace", "[", "#1", "]"}], " ", "/.", " ", 
          RowBox[{
           RowBox[{"{", "}"}], ":>", 
           RowBox[{"{", 
            RowBox[{"ConstantArray", "[", 
             RowBox[{"0", ",", 
              RowBox[{
               RowBox[{"Dimensions", "[", "#1", "]"}], "[", 
               RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "}"}]}]}]}], ",", 
        RowBox[{"ls", "=", 
         RowBox[{"LeastSquares", "[", 
          RowBox[{"#1", ",", "#2"}], "]"}]}]}], "}"}], ",", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"length", "=", 
