Cell[TextData[{
 StyleBox["\nCalculating pool for pullbacks on the level of Diagonal chiral \
characters\n",
  FontWeight->"Bold"],
 "We want to create a list where for each module in the Coset theory which \
are the possible candidates for modules that it decomposes to in the gauged \
theory. To do this we are looking at which Gauged chiral module weights are \
at most an integer apart from the weight of the coset module."
}], "Text",
 CellChangeTimes->{{3.9573473311984*^9, 3.957347332348187*^9}, {
  3.95734741220002*^9, 3.957347550284718*^9}, {3.9573476872444077`*^9, 
  3.957347690428998*^9}, {3.963078593270915*^9, 
  3.9630786067905197`*^9}},ExpressionUUID->"be4af4a5-65cc-4735-b971-\
850df46fd197"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"chiralCandidates", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"#", ",", 
       RowBox[{"Join", "@@", 
        RowBox[{"Position", "[", 
         RowBox[{
          RowBox[{"Mod", "[", 
           RowBox[{"hg", ",", "1"}], "]"}], ",", 
          RowBox[{"Mod", "[", 
           RowBox[{"#", ",", "1"}], "]"}]}], "]"}]}]}], "}"}], "&"}], "/@", 
    "hc"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Row", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"chiralCandidates", " ", "//", "MatrixForm"}], ",", 
    RowBox[{
     RowBox[{"Array", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"chiralCandidates", "[", 
           RowBox[{"[", 
            RowBox[{"#", ",", "1"}], "]"}], "]"}], ",", 
          RowBox[{"hg", "[", 
           RowBox[{"[", 
            RowBox[{"chiralCandidates", "[", 
             RowBox[{"[", 
              RowBox[{"#", ",", "2"}], "]"}], "]"}], "]"}], "]"}]}], "}"}], 
        "&"}], ",", 
       RowBox[{"{", 
        RowBox[{"Length", "[", "chiralCandidates", "]"}], "}"}]}], "]"}], "//",
      "MatrixForm"}]}], "}"}], "]"}]}], "Input",
 CellChangeTimes->{
  3.957346031107733*^9, {3.957347737525506*^9, 3.957347758550846*^9}, {
   3.9573477950369062`*^9, 3.957348007567182*^9}, {3.9573480398532057`*^9, 
   3.957348071496951*^9}, {3.957348216306334*^9, 3.957348222969355*^9}, {
   3.957365868399376*^9, 3.95736587246878*^9}, 3.962819806726472*^9, 
   3.963078611633333*^9, 3.963078669962204*^9, {3.963078716390746*^9, 
