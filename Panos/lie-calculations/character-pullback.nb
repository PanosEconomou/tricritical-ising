         RowBox[{"Floor", "[", 
          RowBox[{"n", "-", 
           RowBox[{"hw", "@@", "#"}], "+", 
           FractionBox["cw", "24"], "+", "5"}], "]"}]}], "]"}]}], "&"}], "/@",
      "W"}]}], ";"}], "\[LineSeparator]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "It", " ", "is", " ", "now", " ", "time", " ", "to", " ", "create", " ", 
    "the", " ", "previous", " ", "list", " ", "but", " ", "with", " ", "the", 
    " ", "partition", " ", "function"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"chiralCandidateCharacters", "=", 
   RowBox[{"Array", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         SuperscriptBox["q", 
          RowBox[{" ", 
           RowBox[{
            FractionBox["cw", "24"], "-", 
            RowBox[{"chiralCandidates", "[", 
             RowBox[{"[", 
              RowBox[{"#", ",", "1"}], "]"}], "]"}]}]}]], 
         RowBox[{"Xc", "[", 
          RowBox[{"[", "#", "]"}], "]"}]}], ",", 
        RowBox[{
         SuperscriptBox["q", 
          RowBox[{" ", 
           RowBox[{
            FractionBox["cw", "24"], "-", 
            RowBox[{"chiralCandidates", "[", 
             RowBox[{"[", 
              RowBox[{"#", ",", "1"}], "]"}], "]"}]}]}]], 
         RowBox[{"Xg", "[", 
          RowBox[{"[", 
