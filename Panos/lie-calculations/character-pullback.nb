        RowBox[{"(", 
         RowBox[{"ns", "+", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"ls", ",", "length"}], "]"}]}], ")"}]}], "]"}]}], "]"}], 
    "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"chiralSolns", "=", 
    RowBox[{"MapThread", "[", 
     RowBox[{"chiralSolve", ",", 
      RowBox[{"{", 
       RowBox[{"chiralMats", ",", "chiralVecs"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Now", " ", "convert", " ", "the", " ", "solutions", " ", "to", " ", 
    "vectors", " ", "where", " ", "each", " ", "coefficient", " ", 
    "corresponds", " ", "to", " ", "an", " ", "ishibashi", " ", "state", " ", 
    "in", " ", "the", " ", "Gauged", " ", "model"}], " ", "*)"}], 
  RowBox[{
   RowBox[{"chiralSolnsConverted", "=", 
