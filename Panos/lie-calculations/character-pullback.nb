  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"chiralCandidateCharactersModified", "=", 
    RowBox[{"MapThread", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Series", "[", 
        RowBox[{
         RowBox[{
          SuperscriptBox["q", 
           RowBox[{"-", "#2"}]], "#1"}], ",", 
         RowBox[{"{", 
          RowBox[{"q", ",", "0", ",", 
           RowBox[{"n", "+", "#2", "-", "1"}]}], "}"}]}], "]"}], "&"}], ",", 
      RowBox[{"{", 
       RowBox[{"chiralCandidateCharacters", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"Min", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Exponent", "[", 
              RowBox[{"#", ",", "q", ",", "Min"}], "]"}], "&"}], "/@", 
            RowBox[{"#", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "&"}], " ", "/@", 
         "chiralCandidateCharacters"}]}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Matrix", " ", "Equations", " ", "for", " ", "each", " ", "module"}], " ", 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"chiralMats", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"CoefficientList", "[", 
         RowBox[{"#", ",", "q", ",", "n"}], "]"}], "&"}], "@", 
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "&"}], "/@", 
    "chiralCandidateCharactersModified"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"chiralVecs", "=", 
