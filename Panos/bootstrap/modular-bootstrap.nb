Cell[CellGroupData[{

Cell["Solving with Existing Lines", "Section",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Python", "SessionID" -> "default-python-session", 
     "Evaluator" -> Automatic|>|>,
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.9859465410744543`*^9, 3.98594654740558*^9}, {
  3.985946584082862*^9, 3.985946599817297*^9}, {3.9859468586786833`*^9, 
  3.985946891091023*^9}},ExpressionUUID->"3d7df1d1-a170-4aec-8810-\
cdb2e1def83c"],

Cell["\<\
As we keep going through families with higher and higher quantum dimension we \
can use existing lines to constrain new ones. This is a variation of \
constrain with invertible lines, but this time it uses the full might of the \
already solved families. We will do an extra optimization. Since once a \
family is solved we know all the lines there and not just the traces,  this \
places a much stricter constraint on what the results of fusions can be other \
than their traces.\
\>", "Text",
 CellChangeTimes->{{3.985946901570898*^9, 3.985947046811798*^9}, {
  3.985947098428143*^9, 
  3.985947113563995*^9}},ExpressionUUID->"ffbe10d8-7bb2-4eb5-9e5d-\
d896100d9bc6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Find", " ", "possible", " ", "integer", " ", "combinations", " ", "for", " ",
     "a", " ", "defect", " ", "with", " ", "unknown", " ", "variables"}], " ",
    "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PossibleSimpleDecompositions", "[", "trace_", "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vars", "=", 
          RowBox[{"Variables", "[", "trace", "]"}]}], ",", "indices"}], "}"}],
        ",", "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "vars", "]"}], "==", "0"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"FindIntegerCombinationsCached", "[", 
          RowBox[{"families", ",", "trace"}], "]"}], ",", 
         "\[IndentingNewLine]", "True", ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"indices", "=", 
           RowBox[{"Flatten", "@", 
            RowBox[{"Position", "[", 
             RowBox[{"trace", ",", " ", 
              RowBox[{"_", "?", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"FreeQ", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{"Alternatives", "@@", "vars"}]}], "]"}], "&"}], 
                ")"}]}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"Heads", "->", "False"}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"FindIntegerCombinationsCached", "[", 
           RowBox[{
            RowBox[{"families", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "indices"}], "]"}], "]"}], ",", 
            RowBox[{"trace", "[", 
             RowBox[{"[", "indices", "]"}], "]"}]}], "]"}]}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Uses", " ", "trace", " ", "equations", " ", "and", " ", "known", " ", 
     "lines", " ", "to", " ", "produce", " ", "candidates", " ", "for", " ", 
     "the", " ", "unknown", " ", "parameters"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ReduceDecompositions", "[", 
      RowBox[{"defect_", ",", "trace_", ",", "decompositions_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"decomp", "|->", 
        RowBox[{"Module", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"sparseDecomp", "=", 
             RowBox[{"SparseArray", "[", "decomp", "]"}]}], ",", "indices"}], 
           "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"indices", "=", 
            RowBox[{
             RowBox[{"sparseDecomp", "[", "\"\<NonzeroPositions\>\"", "]"}], "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Which", "[", "\[IndentingNewLine]", 
            RowBox[{"(*", " ", 
             RowBox[{
             "If", " ", "the", " ", "fusion", " ", "is", " ", "in", " ", 
              "one", " ", "family", " ", "and", " ", "it", " ", "has", " ", 
              "been", " ", "solved", " ", "equate", " ", "them", " ", "cell", 
              " ", "by", " ", "cell"}], " ", "*)"}], "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"And", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Length", "[", "indices", "]"}], "==", "1"}], ",", 
               RowBox[{"SolvedQ", "[", 
                RowBox[{"indices", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"MapThread", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Expand", "[", 
                   RowBox[{"#1", "-", "#2"}], "]"}], "&"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"Flatten", "[", "defect", "]"}], ",", 
                   RowBox[{"Flatten", "[", "#", "]"}]}], "}"}]}], "]"}], 
               "&"}], "/@", 
              RowBox[{"solvedFamilies", "[", 
               RowBox[{"indices", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", " ", 
              RowBox[{
              "Otherwise", " ", "equate", " ", "their", " ", "traces"}], " ", 
              "*)"}], "\[IndentingNewLine]", "True", ",", 
             "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"MapThread", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Expand", "[", 
                  RowBox[{"#1", "-", "#2"}], "]"}], "&"}], ",", 
                RowBox[{"{", 
                 RowBox[{"trace", ",", 
                  RowBox[{"decomp", ".", "families"}]}], "}"}], ",", "1"}], 
               "]"}], "}"}]}], "\[IndentingNewLine]", "]"}]}]}], "]"}]}], 
       ")"}], "/@", "decompositions"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"CommonSubstitutions", "[", "constaints_", "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"fixedValues", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Select", "[", 
            RowBox[{"#", ",", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"Length", "@", 
                  RowBox[{"Variables", "[", "#", "]"}]}], "==", "1"}], "&&", 
                RowBox[{
                 RowBox[{"Exponent", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{"First", "@", 
                    RowBox[{"Variables", "[", "#", "]"}]}]}], "]"}], "==", 
                 "1"}]}], " ", "&"}], ")"}]}], "]"}], "&"}], "/@", 
          "constraints"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"First", "@", 
        RowBox[{"Solve", "@", 
         RowBox[{"Thread", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Intersection", "@@", "fixedValues"}], ")"}], "==", "0"}],
           "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GroebnerBlockReduce", "[", 
      RowBox[{"polys_", ",", "vars_"}], "]"}], ":=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"GroebnerBasis", "/@", 
       RowBox[{"(", 
        RowBox[{"List", "@@", 
         RowBox[{"GroupBy", "[", 
          RowBox[{
           RowBox[{"DeleteCases", "[", 
            RowBox[{"polys", ",", "0"}], "]"}], ",", 
           RowBox[{
            RowBox[{"First", "/@", 
             RowBox[{"Variables", "[", "#", "]"}]}], "&"}]}], "]"}]}], 
        ")"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ConstraintsFromKnown", "[", 
     RowBox[{"defect_", ",", 
      RowBox[{"L_", ":", "L"}], ",", 
      RowBox[{"substitutions_", ":", 
       RowBox[{"{", "}"}]}]}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"reducedDefect", "=", 
         RowBox[{"defect", "/.", "substitutions"}]}], ",", "vars", ",", 
        "products", ",", "traces", ",", "decompositions"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"vars", "=", 
        RowBox[{"Variables", "[", "reducedDefect", "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Calculate", " ", "the", " ", "possible", " ", "fusion", " ", 
         "channels", " ", "with", " ", "the", " ", "known", " ", "defects"}], 
        " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"products", "=", 
        RowBox[{"bilinearFusionOrbit", "[", 
         RowBox[{"reducedDefect", ",", "L"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"traces", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"tr", "/@", "#"}], "&"}], "/@", "products"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"PossibleSimpleDecompositions", "/@", "traces"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"Join", "@@@", 
         RowBox[{"MapThread", "[", 
          RowBox[{"ReduceDecompositions", ",", 
           RowBox[{"{", 
            RowBox[{
            "products", ",", " ", "traces", ",", " ", "decompositions"}], 
            "}"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Obtain", " ", "a", " ", "system", " ", "of", " ", "equations", " ", 
         "and", " ", "reduce", " ", "it"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"SortBy", "[", 
        RowBox[{
         RowBox[{"DeleteDuplicates", "[", 
          RowBox[{"Sort", "/@", 
           RowBox[{"Map", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"GroebnerBasis", "[", 
               RowBox[{"#", ",", "vars"}], "]"}], "&"}], ",", 
             "decompositions", ",", 
             RowBox[{"{", "2", "}"}]}], "]"}]}], "]"}], ",", "Length"}], 
        "]"}]}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Constrain", " ", "using", " ", "fusion", " ", "with", " ", "their", " ", 
     "dual"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ConstraintsFromDualFusion", "[", 
      RowBox[{"defect_", ",", 
       RowBox[{"Li_", ":", "Li"}], ",", 
       RowBox[{"substitutions_", ":", 
        RowBox[{"{", "}"}]}]}], "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"reducedDefect", "=", 
          RowBox[{"defect", "/.", "substitutions"}]}], ",", "vars", ",", 
         "products", ",", "traces", ",", "decompositions"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"vars", "=", 
         RowBox[{"Variables", "[", "reducedDefect", "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Calculate", " ", "Fusion", " ", "among", " ", "members", " ", "of", 
          " ", "family"}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"products", "=", 
         RowBox[{"DeleteDuplicates", "[", 
          RowBox[{"Assuming", "[", 
           RowBox[{
            RowBox[{"Thread", "[", 
             RowBox[{"vars", " ", "\[Element]", "Reals"}], "]"}], " ", ",", 
            RowBox[{"Simplify", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"reducedDefect", "\[CircleTimes]", 
                 RowBox[{"(", 
                  SuperscriptBox["reducedDefect", "\[Dagger]"], ")"}]}], "-", 
                
                RowBox[{"Li", "[", 
                 RowBox[{"[", "1", "]"}], "]"}]}], ",", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  SuperscriptBox["reducedDefect", "\[Dagger]"], ")"}], "\[CircleTimes]",
                  " ", "reducedDefect"}], "-", 
                RowBox[{"Li", "[", 
                 RowBox[{"[", "1", "]"}], "]"}]}]}], "}"}], "]"}]}], "]"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"traces", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"tr", "/@", "#"}], "&"}], "/@", "products"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Constrain", " ", "their", " ", "possible", " ", "fusion", " ", 
