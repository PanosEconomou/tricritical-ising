       RowBox[{"traces", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"tr", "/@", "#"}], "&"}], "/@", "products"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"PossibleSimpleDecompositions", "/@", "traces"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
