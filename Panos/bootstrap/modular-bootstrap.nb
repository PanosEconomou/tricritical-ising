Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "These", " ", "are", " ", "Queries", " ", "for", " ", "if", " ", "a", " ",
      "line", " ", "is", " ", "related", " ", "by", " ", "conjugation", " ", 
     "of", " ", "invertible", " ", "defects"}], ",", " ", 
    RowBox[{
    "or", " ", "by", " ", "a", " ", "change", " ", "of", " ", "Gauge"}], ",", 
    " ", 
    RowBox[{"or", " ", "both"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "conjugateOrbit", ",", "invertibleOrbit", ",", "fusionOrbit", ",", 
      "bilinearFusionOrbit"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"conjugateOrbit", "[", 
      RowBox[{"x_", ",", 
       RowBox[{"Li_", ":", "Li"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"conjugateOrbit", "[", 
       RowBox[{"x", ",", "Li"}], "]"}], "=", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Simplify", "[", 
          RowBox[{"#", "\[CircleTimes]", "x", "\[CircleTimes]", 
           RowBox[{"(", 
            RowBox[{"inv", "/@", "#"}], ")"}]}], "]"}], "&"}], "/@", "Li"}], 
       "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"fusionOrbit", "[", 
      RowBox[{"x_", ",", 
       RowBox[{"L_", ":", "L"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"fusionOrbit", "[", 
       RowBox[{"x", ",", "L"}], "]"}], "=", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "\[CircleTimes]", "x"}], "&"}], "/@", "L"}], "]"}], 
       "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"bilinearFusionOrbit", "[", 
      RowBox[{"x_", ",", 
       RowBox[{"L_", ":", "L"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"bilinearFusionOrbit", "[", 
       RowBox[{"x", ",", "L"}], "]"}], "=", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{"Simplify", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"Outer", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"#1", "\[CircleTimes]", "x", "\[CircleTimes]", "#2"}], 
             "&"}], ",", "L", ",", "L", ",", "1", ",", "1"}], "]"}], ",", 
          "1"}], "]"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"invertibleOrbit", "[", 
      RowBox[{"x_", ",", 
       RowBox[{"Li_", ":", "Li"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"invertibleOrbit", "[", 
       RowBox[{"x", ",", "Li"}], "]"}], "=", 
      RowBox[{"Module", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"trace", "=", 
          RowBox[{"Chop", "@", 
           RowBox[{"N", "[", 
            RowBox[{"tr", "/@", "x"}], "]"}]}]}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"bilinearFusionOrbit", "[", 
           RowBox[{"x", ",", "Li"}], "]"}], ",", 
          RowBox[{
           RowBox[{"trace", " ", "==", " ", 
            RowBox[{"Chop", "@", 
             RowBox[{"N", "[", 
              RowBox[{"tr", "/@", "#"}], "]"}]}]}], "&"}]}], "]"}]}], 
       "\[IndentingNewLine]", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Given", " ", "a", " ", "Matrix", " ", "for", " ", "a", " ", "gauge", " ",
      "transformation", " ", "this", " ", "calculates", " ", "traceless", " ",
      "Lie", " ", "Algebra", " ", "generators"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"LieGenerators", "[", "x_", "]"}], ":=", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"MatrixQ", "[", "x", "]"}], ",", 
       RowBox[{"Module", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"II", "=", 
            RowBox[{"IdentityMatrix", "[", 
             RowBox[{"Length", "[", "x", "]"}], "]"}]}], ",", 
           RowBox[{"vars", "=", 
            RowBox[{"Variables", "[", "x", "]"}]}]}], "}"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"DeleteCases", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"#", "-", 
              RowBox[{
               FractionBox[
                RowBox[{"Tr", "[", "#", "]"}], "2"], "II"}]}], "&"}], "/@", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"D", "[", 
                RowBox[{"x", ",", "#"}], "]"}], "&"}], "/@", "vars"}], 
             ")"}]}], ",", 
           RowBox[{"0", "*", "II"}]}], "]"}]}], "\[IndentingNewLine]", "]"}], 
       ",", "True", ",", 
       RowBox[{"{", "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Takes", " ", "a", " ", "defect", " ", "x", " ", "and", " ", "a", " ", 
     "parameterized", " ", "Gauge", " ", "Transformation", " ", "Lp", " ", 
     "and", " ", "returns", " ", "the", " ", "relations", " ", "needed", " ", 
     "to", " ", "put", " ", "x", " ", "in", " ", "a", " ", "fixed", " ", 
     "gauge"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GaugeFixingRelations", "[", 
      RowBox[{"x_", ",", 
       RowBox[{"Lp_", ":", 
        RowBox[{"Lp", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"Simplify", "@", "And"}], "@@", 
      RowBox[{"MapThread", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"A", ",", "P"}], "}"}], "|->", 
         RowBox[{"Module", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"generators", "=", 
             RowBox[{"LieGenerators", "[", "P", "]"}]}], "}"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Which", "[", 
            RowBox[{
             RowBox[{"!", 
              RowBox[{"MatrixQ", "[", "A", "]"}]}], ",", "True", ",", 
