   3.9867591368187923`*^9, 3.986759160068047*^9}, {3.986759205957881*^9, 
   3.986759208260357*^9}, {3.986759240350915*^9, 3.986759266439131*^9}, {
   3.986759308230041*^9, 3.9867593283485603`*^9}, {3.9867593669966183`*^9, 
   3.986759372531786*^9}, {3.986759406508898*^9, 3.9867594084905987`*^9}, {
   3.986759471738559*^9, 3.9867595921172447`*^9}, {3.986759692591136*^9, 
   3.986759693737158*^9}, {3.9867597443924828`*^9, 3.986759744677767*^9}, 
   3.98675978182515*^9, {3.98691148551714*^9, 3.986911503226652*^9}, {
   3.9869162077578573`*^9, 3.986916245532526*^9}, {3.986916401176448*^9, 
   3.986916411491001*^9}, {3.9869854193196373`*^9, 3.9869854199246798`*^9}, {
   3.986985452647503*^9, 3.986985467275298*^9}, {3.986985507327744*^9, 
   3.9869855180057173`*^9}, {3.986987234794159*^9, 3.9869872367286167`*^9}, {
   3.986987280177705*^9, 3.986987285457097*^9}, {3.986987333877286*^9, 
   3.986987340377846*^9}, {3.986987565642214*^9, 3.9869875742564793`*^9}, {
   3.986987649832542*^9, 3.986987650421885*^9}, {3.986987687023121*^9, 
   3.986987816097857*^9}, {3.9869878955994062`*^9, 3.9869878995612097`*^9}, {
   3.986988067254014*^9, 3.9869881009136477`*^9}, {3.9869900515412207`*^9, 
   3.9869900692139273`*^9}, {3.98699011660536*^9, 3.9869902709501677`*^9}, {
   3.986990304975165*^9, 3.986990568824213*^9}, {3.986990609896036*^9, 
   3.986990611149242*^9}, {3.986990645481916*^9, 3.98699065273599*^9}, {
   3.9869907025738792`*^9, 3.986990716781952*^9}, {3.98699078450386*^9, 
   3.9869907910619793`*^9}, {3.986990826945456*^9, 3.9869908351761093`*^9}, 
   3.986999347837859*^9, {3.987259497804575*^9, 3.9872595235578537`*^9}, {
   3.987259858438376*^9, 3.987259879382112*^9}, {3.9872601296854067`*^9, 
   3.9872601761998367`*^9}, {3.987261002633038*^9, 3.987261003256297*^9}, {
   3.987261104744213*^9, 3.987261105065384*^9}, {3.987261354143317*^9, 
