Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
     "Calculates", " ", "the", " ", "nullspace", " ", "of", " ", "the", " ", 
      "Jacobian", " ", "of", " ", "Lp", " ", "x"}], " ", "-", " ", 
     RowBox[{"x", " ", "Lp"}]}], ",", " ", 
    RowBox[{
    "and", " ", "if", " ", "it", " ", "is", " ", "empty", " ", "then", " ", 
     "there", " ", "is", " ", "no", " ", "gauge", " ", "transformation"}]}], 
   " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"gaugeNullSpace", "[", 
      RowBox[{"x_", ",", "y_", ",", 
       RowBox[{"Lp_", ":", "Lp"}], ",", 
       RowBox[{"Lpp_", ":", "Lpp"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"gaugeNullSpace", "[", 
       RowBox[{"x", ",", "y", ",", "Lp", ",", "Lpp"}], "]"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"NullSpace", "@", 
          RowBox[{"Outer", "[", 
           RowBox[{"D", ",", 
            RowBox[{"Flatten", "[", 
             RowBox[{"ExpandAll", "[", 
              RowBox[{
               RowBox[{"#", "\[CircleTimes]", "x"}], "-", 
               RowBox[{"y", "\[CircleTimes]", "#"}]}], "]"}], "]"}], ",", 
            "Lpp"}], "]"}]}], ")"}], "&"}], "/@", "Lp"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GaugeQ", "[", 
      RowBox[{"x_", ",", "y_", ",", 
       RowBox[{"Lp_", ":", "Lp"}], ",", 
       RowBox[{"Lpp_", ":", "Lpp"}], ",", 
       RowBox[{"LpInvertibleQ_", ":", "LpInvertibleQ"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"ns", ",", "dummies"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ns", "=", 
         RowBox[{"gaugeNullSpace", "[", 
          RowBox[{"x", ",", "y", ",", "Lp", ",", "Lpp"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Or", "@@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Which", "[", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"#", "===", 
               RowBox[{"{", "}"}]}], ",", "False", ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Length", "@", "#"}], " ", "===", 
               RowBox[{"Length", "@", "Lpp"}]}], ",", "True", ",", 
              "\[IndentingNewLine]", "True", ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"dummies", "=", 
                RowBox[{"Array", "[", 
                 RowBox[{"\[FormalX]", ",", 
                  RowBox[{"Length", "@", "#"}]}], "]"}]}], ";", 
               "\[IndentingNewLine]", 
               RowBox[{"Assuming", "[", 
                RowBox[{
                 RowBox[{"Thread", "[", 
                  RowBox[{
                   RowBox[{"Variables", "[", 
                    RowBox[{"{", 
                    RowBox[{"x", ",", "y", ",", "dummies"}], "}"}], "]"}], "!=",
