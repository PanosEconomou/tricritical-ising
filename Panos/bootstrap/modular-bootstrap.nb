Cell[CellGroupData[{

Cell["Obtaining Modular Bootstrap Equations", "Subsection",
 CellChangeTimes->{{3.985351008868718*^9, 
  3.985351054383965*^9}},ExpressionUUID->"44fa9f5a-2a50-472e-92ae-\
bcc03f1248d6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"processInequalities", "[", 
     RowBox[{"ineqs_List", ",", "vars_List"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"c", "=", "0"}], "}"}], ",", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Function", "[", 
          RowBox[{"lhs", ",", 
           RowBox[{"With", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"coeffs", "=", 
               RowBox[{"Append", "[", 
                RowBox[{
                 RowBox[{"Table", "[", 
                  RowBox[{
                   RowBox[{"Coefficient", "[", 
                    RowBox[{"lhs", ",", "v"}], "]"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"v", ",", "vars"}], "}"}]}], "]"}], ",", 
                 RowBox[{"lhs", "/.", " ", 
                  RowBox[{"Thread", "[", 
                   RowBox[{"vars", "->", "0"}], "]"}]}]}], "]"}]}], "}"}], ",", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"AnyTrue", "[", 
                RowBox[{"coeffs", ",", 
                 RowBox[{
                  RowBox[{"!", 
                   RowBox[{"IntegerQ", "[", "#", "]"}]}], "&"}]}], "]"}], ",", 
               RowBox[{"With", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"lcm", "=", 
                    RowBox[{"LCM", "@@", 
                    RowBox[{"Denominator", "/@", "coeffs"}]}]}], ",", 
                   RowBox[{"w", "=", 
                    RowBox[{"Symbol", "[", 
                    RowBox[{"\"\<w\>\"", "<>", 
                    RowBox[{"ToString", "[", 
                    RowBox[{"++", "c"}], "]"}]}], "]"}]}]}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"w", ">=", "0"}], ",", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"Expand", "[", 
                    RowBox[{"lcm", "*", "lhs"}], "]"}], "-", 
                    RowBox[{"lcm", "*", "w"}]}], "==", "0"}]}], "}"}]}], 
                "]"}], ",", 
               RowBox[{"lhs", ">=", "0"}]}], "]"}]}], "]"}]}], "]"}], "/@", 
         RowBox[{"(", 
          RowBox[{"ineqs", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}], ")"}]}], ",", "1"}], 
       "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SolveModularBootstrap", "[", 
     RowBox[{"z_", ",", "s_"}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"X", ",", "nz", ",", " ", 
        RowBox[{"st", "=", 
         RowBox[{"ConjugateTranspose", "[", "s", "]"}]}], ",", "m", ",", 
        "coeff", ",", "A", ",", " ", "eqn", ",", "multipliers", ",", "basis", 
        ",", "toRoot"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Needs", "[", "\"\<math4ti2`\>\"", "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Get", " ", "Nonzero", " ", "positions", " ", "on", " ", "the", " ", 
         "Mass", " ", "Matrix", " ", "and", " ", "replace", " ", "them", " ", 
         "with", " ", "variables"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"nz", "=", 
        RowBox[{"Position", "[", 
         RowBox[{"z", ",", " ", 
          RowBox[{"_", "?", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"#", " ", "!=", "0"}], " ", "&"}], ")"}]}]}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"X", "=", 
        RowBox[{"Array", "[", 
         RowBox[{"\[FormalX]", ",", 
          RowBox[{"Length", "[", "nz", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"m", "=", 
        RowBox[{
         RowBox[{"st", ".", " ", 
          RowBox[{"ReplacePart", "[", 
           RowBox[{"z", ",", 
            RowBox[{"Thread", "[", 
             RowBox[{"nz", "\[Rule]", "X"}], "]"}]}], "]"}], " ", ".", " ", 
          "s"}], "//", "Flatten"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Extract", " ", "the", " ", "coefficients", " ", "for", " ", "each", " ",
          "variable", " ", "in", " ", "the", " ", "S", " ", "transformed", " ",
          "Mass", " ", "Matrix"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"coeff", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"CoefficientArrays", "[", 
             RowBox[{"m", ",", "X"}], "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}], "//", "Normal"}], "//", "N"}], "//",
          "Chop"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Pick", " ", "the", " ", "maximum", " ", "number", " ", "of", " ", 
         "independent", " ", "equations", " ", "and", " ", "invert", " ", 
         "them"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"A", "=", 
        RowBox[{"Chop", "@", 
         RowBox[{"Inverse", "@", 
          RowBox[{"N", "@", 
           RowBox[{"coeff", "[", 
            RowBox[{"[", 
             RowBox[{"Flatten", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"FirstPosition", "[", 
                 RowBox[{"#", ",", "1"}], "]"}], "&"}], "/@", 
               RowBox[{"DeleteCases", "[", 
                RowBox[{
                 RowBox[{"Chop", "@", 
                  RowBox[{"RowReduce", "@", 
                   RowBox[{"N", "@", 
                    RowBox[{"Transpose", "@", "coeff"}]}]}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"0", ".."}], "}"}]}], "]"}]}], "]"}], "]"}], 
            "]"}]}]}]}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "Plug", " ", "them", " ", "back", " ", "in", " ", "to", " ", "the", " ",
           "S"}], "-", 
         RowBox[{
         "Transformed", " ", "Modular", " ", "Matrix", " ", "to", " ", 
          "obtain", " ", "constraints"}]}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"m", "=", 
        RowBox[{
         RowBox[{"Chop", "[", 
          RowBox[{"N", "[", 
           RowBox[{"coeff", ".", "A"}], "]"}], "]"}], ".", "X"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"A", "=", 
          RowBox[{"RootApproximant", "[", "A", "]"}]}], ";"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"eqn", "=", 
        RowBox[{"DeleteDuplicates", "@", 
         RowBox[{"Rationalize", "@", 
          RowBox[{"Chop", "@", 
           RowBox[{"Expand", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"#", ">=", "0"}], "&"}], "/@", "m"}], "]"}]}]}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"eqn", "=", 
          RowBox[{"DeleteDuplicates", "@", 
           RowBox[{"Rationalize", "@", 
            RowBox[{"Chop", "@", 
             RowBox[{"Expand", "[", "m", "]"}]}]}]}]}], ";"}], "*)"}], 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Rescale", " ", "any", " ", "variables", " ", "that", " ", "need", " ",
          "it", " ", "so", " ", "that", " ", "the", " ", "system", " ", "has",
          " ", "integer", " ", "coefficients"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"multipliers", "=", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Min", "@", 
            RowBox[{"Cases", "[", 
             RowBox[{"eqn", ",", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"a_.", "*", "#"}], ")"}], ">=", "0"}], ":>", 
               RowBox[{"Abs", "[", "a", "]"}]}]}], "]"}]}], "^", 
           RowBox[{"-", "1"}]}], "&"}], "/@", "X"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"multipliers", "=", 
          RowBox[{
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"Min", "@", 
               RowBox[{"Abs", "[", 
                RowBox[{"DeleteCases", "[", 
                 RowBox[{
                  RowBox[{"Coefficient", "[", 
                   RowBox[{"eqn", ",", "#"}], "]"}], ",", "0"}], "]"}], 
                "]"}]}], ")"}], 
             RowBox[{"-", "1"}]], "&"}], "/@", "X"}]}], ";"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"eqn", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"#", "[", 
             RowBox[{"[", "0", "]"}], "]"}], "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Subtract", "@@", "#"}], "//", "ExpandAll"}], ",", 
             "0"}], "]"}], ")"}], "&"}], "/@", 
         RowBox[{"(", 
          RowBox[{"eqn", "/.", " ", 
           RowBox[{"Thread", "[", 
            RowBox[{"X", "->", 
             RowBox[{"multipliers", "*", "X"}]}], "]"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"eqn", "=", 
        RowBox[{"processInequalities", "[", 
         RowBox[{"eqn", ",", "X"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"Use", " ", "Z"}], "-", 
         RowBox[{
         "Solve", " ", "to", " ", "find", " ", "a", " ", "basis", " ", "of", " ",
           "simple", " ", "objects"}]}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"basis", " ", "=", 
        RowBox[{
         RowBox[{"math4ti2`zsolve", "[", "eqn", "]"}], "//", "Time"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Echo", "[", 
        RowBox[{
         RowBox[{"basis", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "//", "MatrixPlot"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"basis", "=", 
        RowBox[{
         RowBox[{"basis", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "[", 
