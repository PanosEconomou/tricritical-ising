Cell[CellGroupData[{

Cell["Search Fusion Rules", "Subsection",
 CellChangeTimes->{{3.985357275402993*^9, 
  3.985357279185727*^9}},ExpressionUUID->"4a25c2cf-92f7-4695-bfe8-\
ec87fb8ae6f3"],

Cell["\<\
Since we can obtain some partial information for the fusion rules among \
defects belonging to each family we can extract and list them in the following\
\>", "Text",
 CellChangeTimes->{{3.9853572836175137`*^9, 3.985357326258501*^9}, {
  3.98560630134757*^9, 
  3.985606303514105*^9}},ExpressionUUID->"42886f58-f746-48dc-bda3-\
3bee21925f9a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Takes", " ", "a", " ", "matrix", " ", "M", " ", "and", " ", "a", " ", 
    "vector", " ", "v", " ", "and", " ", "finds", " ", "all", " ", "possible",
     " ", "nonnegative", " ", "integer", " ", "combinations", " ", "of", " ", 
    "rows", " ", "of", " ", "M", " ", "that", " ", "sum", " ", "to", " ", 
    "v"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"FindIntegerCombinations", "[", 
      RowBox[{"M_", ",", "v_"}], "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"n", "=", 
          RowBox[{"Length", "[", "M", "]"}]}], ",", 
         RowBox[{"m", "=", 
          RowBox[{"Length", "[", "v", "]"}]}], ",", 
         RowBox[{"MT", "=", 
          RowBox[{"Transpose", "[", 
           RowBox[{"N", "[", "M", "]"}], "]"}]}], ",", "ubounds", ",", " ", 
         "enumerate", ",", 
         RowBox[{"results", "=", 
          RowBox[{"{", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Use", " ", "linear", " ", "programming", " ", "to", " ", "estimate", 
         " ", "the", " ", "maximum", " ", "number", " ", "a", " ", "row", " ",
          "can", " ", "be", " ", "added", " ", "in", " ", "a", " ", 
         "solution", " ", "for", " ", "v"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ubounds", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"Module", "[", 
            RowBox[{
             RowBox[{"{", "sol", "}"}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"sol", "=", 
               RowBox[{"Quiet", "[", 
                RowBox[{"LinearProgramming", "[", 
                 RowBox[{
                  RowBox[{"-", 
                   RowBox[{"UnitVector", "[", 
                    RowBox[{"n", ",", "i"}], "]"}]}], ",", "MT", ",", 
                  RowBox[{"Transpose", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"N", "[", "v", "]"}], ",", 
                    RowBox[{"ConstantArray", "[", 
                    RowBox[{"0", ",", "m"}], "]"}]}], "}"}], "]"}], ",", 
                  RowBox[{"ConstantArray", "[", 
                   RowBox[{"0", ",", "n"}], "]"}]}], "]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"VectorQ", "[", "sol", "]"}], ",", 
                RowBox[{"Max", "[", 
                 RowBox[{"0", ",", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"sol", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "//", "Chop"}], "//", 
                   "RootApproximant"}]}], "]"}], ",", "sol"}], "]"}]}]}], 
            "]"}], "\[IndentingNewLine]", ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "n"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Explore", " ", "the", " ", "rest", " ", "recursively", " ", "until",
           " ", "you", " ", "hit", " ", "zero"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"enumerate", "[", 
          RowBox[{"rem_", ",", "idx_", ",", "current_"}], "]"}], ":=", 
         RowBox[{"Which", "[", 
          RowBox[{
           RowBox[{"idx", ">", "n"}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Chop", "[", 
               RowBox[{"N", "[", "rem", "]"}], "]"}], "==", 
              RowBox[{"ConstantArray", "[", 
               RowBox[{"0", ",", "m"}], "]"}]}], ",", 
             RowBox[{"AppendTo", "[", 
              RowBox[{"results", ",", "current"}], "]"}]}], "]"}], ",", 
           "True", ",", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"enumerate", "[", 
              RowBox[{
               RowBox[{"rem", "-", 
                RowBox[{"k", "*", 
                 RowBox[{"M", "[", 
                  RowBox[{"[", "idx", "]"}], "]"}]}]}], ",", 
               RowBox[{"idx", "+", "1"}], ",", 
               RowBox[{"Append", "[", 
                RowBox[{"current", ",", "k"}], "]"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"k", ",", "0", ",", 
               RowBox[{"ubounds", "[", 
                RowBox[{"[", "idx", "]"}], "]"}]}], "}"}]}], "]"}]}], "]"}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"enumerate", "[", 
         RowBox[{"v", ",", "1", ",", 
          RowBox[{"{", "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
        "results"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", "FindIntegerCombinationsCached", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"FindIntegerCombinationsCached", "[", 
      RowBox[{"M_", ",", "v_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"FindIntegerCombinationsCached", "[", 
       RowBox[{"M", ",", "v"}], "]"}], "=", 
      RowBox[{"FindIntegerCombinations", "[", 
       RowBox[{"M", ",", "v"}], "]"}]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9853573293745947`*^9, 3.985357355083605*^9}, {
   3.9853574421551*^9, 3.985357630591894*^9}, {3.985357671648127*^9, 
   3.985357804412588*^9}, {3.985357862270877*^9, 3.9853578833133993`*^9}, {
   3.985358382954053*^9, 3.9853584141917133`*^9}, {3.9853586361387167`*^9, 
   3.985358637795376*^9}, 3.985358929128791*^9, 3.985359046771819*^9, {
   3.985359145952524*^9, 3.9853592176757097`*^9}, 3.985359302909829*^9, {
   3.985359396971925*^9, 3.9853593973895683`*^9}, {3.985359491877936*^9, 
   3.985359496260504*^9}, 3.985367914646564*^9, {3.9853680159323*^9, 
   3.985368045442729*^9}, {3.985368269181342*^9, 3.985368269570895*^9}, {
   3.985368314887126*^9, 3.9853683762385607`*^9}, 3.9853684716231422`*^9, 
   3.985368578092824*^9, 3.985368632947525*^9, {3.985368679772201*^9, 
   3.9853686824588947`*^9}, 3.98536886465869*^9, {3.985369008854233*^9, 
   3.985369030225857*^9}, {3.985369089335786*^9, 3.985369096241766*^9}, 
   3.985369170579146*^9, 3.985369229851967*^9, {3.9853692909880867`*^9, 
   3.985369298347982*^9}, {3.985369391260331*^9, 3.985369391947888*^9}, {
   3.985369458276133*^9, 3.9853694595816917`*^9}, {3.985370011670536*^9, 
   3.985370015149963*^9}, {3.98537004988813*^9, 3.9853700678891478`*^9}, {
   3.985370155486998*^9, 3.9853701561090603`*^9}, {3.985370239620748*^9, 
   3.9853702520206203`*^9}, {3.9853703563012247`*^9, 
   3.9853703609254436`*^9}, {3.98537039929458*^9, 3.985370401893641*^9}, {
   3.98560620346139*^9, 3.9856062208208437`*^9}, 3.985606268267918*^9, {
   3.985623568082878*^9, 3.985623568578953*^9}, {3.9857033976719923`*^9, 
   3.9857033995942907`*^9}, {3.985801504991123*^9, 3.9858015084182663`*^9}, {
   3.985801539978643*^9, 3.985801559175988*^9}, {3.985801650259076*^9, 
   3.985801669232503*^9}, 3.985805457980014*^9, {3.985854234289031*^9, 
   3.985854257077722*^9}, {3.9858580309221563`*^9, 3.985858031096974*^9}, {
   3.986209466415723*^9, 3.986209467039222*^9}, {3.986462442606024*^9, 
   3.9864624614538116`*^9}},
 CellLabel->"In[69]:=",ExpressionUUID->"25b53d80-3110-4a8c-a848-096ad28d22de"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Solving with Existing Lines", "Section",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Python", "SessionID" -> "default-python-session", 
     "Evaluator" -> Automatic|>|>,
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.9859465410744543`*^9, 3.98594654740558*^9}, {
  3.985946584082862*^9, 3.985946599817297*^9}, {3.9859468586786833`*^9, 
  3.985946891091023*^9}},ExpressionUUID->"3d7df1d1-a170-4aec-8810-\
cdb2e1def83c"],

Cell["\<\
As we keep going through families with higher and higher quantum dimension we \
can use existing lines to constrain new ones. This is a variation of \
constrain with invertible lines, but this time it uses the full might of the \
already solved families. We will do an extra optimization. Since once a \
family is solved we know all the lines there and not just the traces,  this \
places a much stricter constraint on what the results of fusions can be other \
than their traces.\
\>", "Text",
 CellChangeTimes->{{3.985946901570898*^9, 3.985947046811798*^9}, {
  3.985947098428143*^9, 
  3.985947113563995*^9}},ExpressionUUID->"ffbe10d8-7bb2-4eb5-9e5d-\
d896100d9bc6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Find", " ", "possible", " ", "integer", " ", "combinations", " ", "for", " ",
     "a", " ", "defect", " ", "with", " ", "unknown", " ", "variables"}], " ",
    "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PossibleSimpleDecompositions", "[", "trace_", "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vars", "=", 
          RowBox[{"Variables", "[", "trace", "]"}]}], ",", "indices"}], "}"}],
        ",", "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "vars", "]"}], "==", "0"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"FindIntegerCombinationsCached", "[", 
          RowBox[{"families", ",", "trace"}], "]"}], ",", 
         "\[IndentingNewLine]", "True", ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"indices", "=", 
           RowBox[{"Flatten", "@", 
            RowBox[{"Position", "[", 
             RowBox[{"trace", ",", " ", 
              RowBox[{"_", "?", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"FreeQ", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{"Alternatives", "@@", "vars"}]}], "]"}], "&"}], 
                ")"}]}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"Heads", "->", "False"}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"FindIntegerCombinationsCached", "[", 
           RowBox[{
            RowBox[{"families", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "indices"}], "]"}], "]"}], ",", 
            RowBox[{"trace", "[", 
             RowBox[{"[", "indices", "]"}], "]"}]}], "]"}]}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Uses", " ", "trace", " ", "equations", " ", "and", " ", "known", " ", 
     "lines", " ", "to", " ", "produce", " ", "candidates", " ", "for", " ", 
     "the", " ", "unknown", " ", "parameters"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ReduceDecompositions", "[", 
      RowBox[{"defect_", ",", "trace_", ",", "decompositions_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"decomp", "|->", 
        RowBox[{"Module", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"sparseDecomp", "=", 
             RowBox[{"SparseArray", "[", "decomp", "]"}]}], ",", "indices"}], 
           "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"indices", "=", 
            RowBox[{
             RowBox[{"sparseDecomp", "[", "\"\<NonzeroPositions\>\"", "]"}], "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Which", "[", "\[IndentingNewLine]", 
            RowBox[{"(*", " ", 
             RowBox[{
             "If", " ", "the", " ", "fusion", " ", "is", " ", "in", " ", 
              "one", " ", "family", " ", "and", " ", "it", " ", "has", " ", 
              "been", " ", "solved", " ", "equate", " ", "them", " ", "cell", 
              " ", "by", " ", "cell"}], " ", "*)"}], "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"And", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Length", "[", "indices", "]"}], "==", "1"}], ",", 
               RowBox[{"SolvedQ", "[", 
                RowBox[{"indices", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"MapThread", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Expand", "[", 
                   RowBox[{"#1", "-", "#2"}], "]"}], "&"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"Flatten", "[", "defect", "]"}], ",", 
                   RowBox[{"Flatten", "[", "#", "]"}]}], "}"}]}], "]"}], 
               "&"}], "/@", 
              RowBox[{"solvedFamilies", "[", 
               RowBox[{"indices", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", " ", 
              RowBox[{
              "Otherwise", " ", "equate", " ", "their", " ", "traces"}], " ", 
              "*)"}], "\[IndentingNewLine]", "True", ",", 
             "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"MapThread", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Expand", "[", 
                  RowBox[{"#1", "-", "#2"}], "]"}], "&"}], ",", 
                RowBox[{"{", 
                 RowBox[{"trace", ",", 
                  RowBox[{"decomp", ".", "families"}]}], "}"}], ",", "1"}], 
               "]"}], "}"}]}], "\[IndentingNewLine]", "]"}]}]}], "]"}]}], 
       ")"}], "/@", "decompositions"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"CommonSubstitutions", "[", "constaints_", "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"fixedValues", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Select", "[", 
            RowBox[{"#", ",", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"Length", "@", 
                  RowBox[{"Variables", "[", "#", "]"}]}], "==", "1"}], "&&", 
                RowBox[{
                 RowBox[{"Exponent", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{"First", "@", 
                    RowBox[{"Variables", "[", "#", "]"}]}]}], "]"}], "==", 
                 "1"}]}], " ", "&"}], ")"}]}], "]"}], "&"}], "/@", 
          "constraints"}]}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{"First", "@", 
        RowBox[{"Solve", "@", 
         RowBox[{"Thread", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Intersection", "@@", "fixedValues"}], ")"}], "==", "0"}],
           "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"GroebnerBlockReduce", "[", 
      RowBox[{"polys_", ",", "vars_"}], "]"}], ":=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"GroebnerBasis", "/@", 
       RowBox[{"(", 
        RowBox[{"List", "@@", 
         RowBox[{"GroupBy", "[", 
          RowBox[{
           RowBox[{"DeleteCases", "[", 
            RowBox[{"polys", ",", "0"}], "]"}], ",", 
           RowBox[{
            RowBox[{"First", "/@", 
             RowBox[{"Variables", "[", "#", "]"}]}], "&"}]}], "]"}]}], 
        ")"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ConstraintsFromKnown", "[", 
     RowBox[{"defect_", ",", 
      RowBox[{"L_", ":", "L"}], ",", 
      RowBox[{"substitutions_", ":", 
       RowBox[{"{", "}"}]}]}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"reducedDefect", "=", 
         RowBox[{"defect", "/.", "substitutions"}]}], ",", "vars", ",", 
        "products", ",", "traces", ",", "decompositions"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"vars", "=", 
        RowBox[{"Variables", "[", "reducedDefect", "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Calculate", " ", "the", " ", "possible", " ", "fusion", " ", 
         "channels", " ", "with", " ", "the", " ", "known", " ", "defects"}], 
        " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"products", "=", 
        RowBox[{"bilinearFusionOrbit", "[", 
         RowBox[{"reducedDefect", ",", "L"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"traces", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"tr", "/@", "#"}], "&"}], "/@", "products"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"PossibleSimpleDecompositions", "/@", "traces"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"Join", "@@@", 
         RowBox[{"MapThread", "[", 
          RowBox[{"ReduceDecompositions", ",", 
           RowBox[{"{", 
            RowBox[{
            "products", ",", " ", "traces", ",", " ", "decompositions"}], 
            "}"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Obtain", " ", "a", " ", "system", " ", "of", " ", "equations", " ", 
         "and", " ", "reduce", " ", "it"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"SortBy", "[", 
