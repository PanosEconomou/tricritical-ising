                   RowBox[{"hv", "@@", "a1"}], "+", 
                   RowBox[{"hv", "@@", "b1"}], "-", 
                   FractionBox["cv", "12"]}], ")"}]}], "]"}]}], ",", 
              "\[IndentingNewLine]", "True", ",", "0"}], "]"}]}], 
           "\[IndentingNewLine]", "]"}]}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"s", "=", 
