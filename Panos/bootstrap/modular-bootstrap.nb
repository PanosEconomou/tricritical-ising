  3.9862139837361307`*^9}},ExpressionUUID->"19c7fd92-34fa-4ce6-8eec-\
d021d9a83ce3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Constrain", " ", "using", " ", "fusion", " ", "among", " ", 
    "thesemeves"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ConstrainWithSelfFusion", "[", "defects_", "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"vars", "=", 
         RowBox[{"Variables", "[", "defects", "]"}]}], ",", "products", ",", 
        "traces", ",", "decompositions", ",", "result"}], "}"}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Calculate", " ", "Fusion", " ", "among", " ", "members", " ", "of", " ",
         "family"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"products", "=", 
        RowBox[{"DeleteDuplicates", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"Outer", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"#1", "\[CircleTimes]", "#2"}], "&"}], ",", "defects", ",",
              "defects", ",", "1", ",", "1"}], "]"}], ",", "1"}], "]"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"traces", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"tr", "/@", "#"}], "&"}], "/@", "products"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Constrain", " ", "their", " ", "possible", " ", "fusion", " ", 
         "pathways", " ", "and", " ", "turn", " ", "them", " ", "into", " ", 
         "equations", " ", "using", " ", "their", " ", "traces"}], " ", 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"PossibleSimpleDecompositions", "/@", "traces"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"MapThread", "[", 
         RowBox[{"ReduceDecompositions", ",", 
          RowBox[{"{", 
           RowBox[{
           "products", ",", " ", "traces", ",", " ", "decompositions"}], 
           "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"result", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"defects", "//.", "#"}], ")"}], "&"}], "/@", 
           RowBox[{"(", 
            RowBox[{"QuietSolve", "[", 
             RowBox[{
              RowBox[{"N", "[", "decompositions", "]"}], ",", "vars"}], "]"}],
             ")"}]}], ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "Convert", " ", "numerical", " ", "constants", " ", "back", " ", 
          "to", " ", "algebraic", " ", "form"}], ",", " ", 
         RowBox[{"preserving", " ", "variables"}]}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"result", "=", 
        RowBox[{"result", "/.", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"a_", "?", "NumericQ"}], "/;", 
           RowBox[{"!", 
            RowBox[{"IntegerQ", "[", "a", "]"}]}]}], ":>", 
          RowBox[{"RootApproximant", "[", 
           RowBox[{"a", ",", "4"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"CanonicalizeVars", "@", 
        RowBox[{"DeleteDuplicates", "[", 
         RowBox[{
          RowBox[{"Simplify", "@", "result"}], ",", "InvertibleOrbitQ"}], 
         "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}]}]], "Input",
