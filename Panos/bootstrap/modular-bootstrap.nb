         RowBox[{"element", " ", "list"}]}], ")"}]}]}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"topArgs", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Head", "[", "expr", "]"}], "===", "And"}], ",", 
        RowBox[{"List", "@@", "expr"}], ",", 
        RowBox[{"{", "expr", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Flat", " ", 
       RowBox[{"generators", ":", 
        RowBox[{"top", "-", 
         RowBox[{"level", " ", "equalities", " ", "only"}]}]}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"flatGens", "=", 
      RowBox[{"eqToPoly", "/@", 
       RowBox[{"Cases", "[", 
        RowBox[{"topArgs", ",", "_Equal"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"OR", " ", 
       RowBox[{"blocks", ":", 
        RowBox[{
         RowBox[{
         "each", " ", "Or", " ", "becomes", " ", "a", " ", "list", " ", "of", 
          " ", "per"}], "-", 
         RowBox[{"branch", " ", "generator", " ", "lists"}]}]}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"orBlocks", "=", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{"Function", "[", 
         RowBox[{"orExpr", ",", "\[IndentingNewLine]", 
          RowBox[{"Map", "[", 
           RowBox[{
            RowBox[{"Function", "[", 
             RowBox[{"branch", ",", "\[IndentingNewLine]", 
              RowBox[{"Switch", "[", 
               RowBox[{
                RowBox[{"Head", "[", "branch", "]"}], ",", 
                "\[IndentingNewLine]", "And", ",", 
                RowBox[{"eqToPoly", "/@", 
                 RowBox[{"Cases", "[", 
                  RowBox[{
                   RowBox[{"List", "@@", "branch"}], ",", "_Equal"}], "]"}]}],
                 ",", "\[IndentingNewLine]", "Equal", ",", 
                RowBox[{"{", 
                 RowBox[{"eqToPoly", "[", "branch", "]"}], "}"}], ",", 
                "\[IndentingNewLine]", "True", ",", 
                RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", "_", ",", 
                RowBox[{"{", "}"}]}], "\[IndentingNewLine]", "]"}]}], 
             "\[IndentingNewLine]", "]"}], ",", 
            RowBox[{"List", "@@", "orExpr"}]}], "]"}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{"branches", " ", "of", " ", "this", " ", "Or"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"Cases", "[", 
         RowBox[{"topArgs", ",", "_Or"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"flatGens", ",", "orBlocks"}], "}"}]}]}], 
   "]"}]}], "\[IndentingNewLine]"}], "Input",
