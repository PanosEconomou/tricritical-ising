Cell[CellGroupData[{

Cell["Solving with Existing Lines", "Section",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Python", "SessionID" -> "default-python-session", 
     "Evaluator" -> Automatic|>|>,
 CellEvaluationLanguage->"Python",
 CellChangeTimes->{{3.9859465410744543`*^9, 3.98594654740558*^9}, {
  3.985946584082862*^9, 3.985946599817297*^9}, {3.9859468586786833`*^9, 
  3.985946891091023*^9}},ExpressionUUID->"3d7df1d1-a170-4aec-8810-\
cdb2e1def83c"],

Cell["\<\
As we keep going through families with higher and higher quantum dimension we \
can use existing lines to constrain new ones. This is a variation of \
constrain with invertible lines, but this time it uses the full might of the \
already solved families. We will do an extra optimization. Since once a \
family is solved we know all the lines there and not just the traces,  this \
places a much stricter constraint on what the results of fusions can be other \
than their traces.\
\>", "Text",
 CellChangeTimes->{{3.985946901570898*^9, 3.985947046811798*^9}, {
  3.985947098428143*^9, 
  3.985947113563995*^9}},ExpressionUUID->"ffbe10d8-7bb2-4eb5-9e5d-\
d896100d9bc6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Find", " ", "possible", " ", "integer", " ", "combinations", " ", "for", " ",
     "a", " ", "defect", " ", "with", " ", "unknown", " ", "variables"}], " ",
    "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"PossibleSimpleDecompositions", "[", "trace_", "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vars", "=", 
          RowBox[{"Variables", "[", "trace", "]"}]}], ",", "indices"}], "}"}],
        ",", "\[IndentingNewLine]", 
       RowBox[{"Which", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "vars", "]"}], "==", "0"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"FindIntegerCombinationsCached", "[", 
          RowBox[{"families", ",", "trace"}], "]"}], ",", 
         "\[IndentingNewLine]", "True", ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"indices", "=", 
           RowBox[{"Flatten", "@", 
            RowBox[{"Position", "[", 
             RowBox[{"trace", ",", " ", 
              RowBox[{"_", "?", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"FreeQ", "[", 
                  RowBox[{"#", ",", 
                   RowBox[{"Alternatives", "@@", "vars"}]}], "]"}], "&"}], 
                ")"}]}], ",", 
              RowBox[{"{", "1", "}"}], ",", 
              RowBox[{"Heads", "->", "False"}]}], "]"}]}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"FindIntegerCombinationsCached", "[", 
           RowBox[{
            RowBox[{"families", "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "indices"}], "]"}], "]"}], ",", 
            RowBox[{"trace", "[", 
             RowBox[{"[", "indices", "]"}], "]"}]}], "]"}]}]}], 
        "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Uses", " ", "trace", " ", "equations", " ", "and", " ", "known", " ", 
     "lines", " ", "to", " ", "produce", " ", "candidates", " ", "for", " ", 
     "the", " ", "unknown", " ", "parameters"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"ReduceDecompositions", "[", 
      RowBox[{"defect_", ",", "trace_", ",", "decompositions_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"decomp", "|->", 
        RowBox[{"Module", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"sparseDecomp", "=", 
             RowBox[{"SparseArray", "[", "decomp", "]"}]}], ",", "indices"}], 
           "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"indices", "=", 
            RowBox[{
             RowBox[{"sparseDecomp", "[", "\"\<NonzeroPositions\>\"", "]"}], "[", 
             RowBox[{"[", 
              RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"Which", "[", "\[IndentingNewLine]", 
            RowBox[{"(*", " ", 
             RowBox[{
             "If", " ", "the", " ", "fusion", " ", "is", " ", "in", " ", 
              "one", " ", "family", " ", "and", " ", "it", " ", "has", " ", 
              "been", " ", "solved", " ", "equate", " ", "them", " ", "cell", 
              " ", "by", " ", "cell"}], " ", "*)"}], "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"And", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Length", "[", "indices", "]"}], "==", "1"}], ",", 
               RowBox[{"SolvedQ", "[", 
                RowBox[{"indices", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{
               RowBox[{"MapThread", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Expand", "[", 
                   RowBox[{"#1", "-", "#2"}], "]"}], "&"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"Flatten", "[", "defect", "]"}], ",", 
                   RowBox[{"Flatten", "[", "#", "]"}]}], "}"}]}], "]"}], 
               "&"}], "/@", 
              RowBox[{"solvedFamilies", "[", 
               RowBox[{"indices", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"(*", 
              RowBox[{
               RowBox[{"Or", "@@", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"And", "@@", 
                    RowBox[{"DeleteCases", "[", 
                    RowBox[{
                    RowBox[{"Expand", "[", 
                    RowBox[{"MapThread", "[", 
                    RowBox[{"Equal", ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Flatten", "[", "defect", "]"}], ",", 
                    RowBox[{"Flatten", "[", "#", "]"}]}], "}"}]}], "]"}], 
                    "]"}], ",", "True"}], "]"}]}], "&"}], "/@", 
                  RowBox[{"solvedFamilies", "[", 
                   RowBox[{"indices", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ")"}]}], ","}], 
              "*)"}], "\[IndentingNewLine]", 
             RowBox[{"(*", " ", 
              RowBox[{
              "Otherwise", " ", "equate", " ", "their", " ", "traces"}], " ", 
              "*)"}], "\[IndentingNewLine]", "True", ",", 
             "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"MapThread", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Expand", "[", 
                  RowBox[{"#1", "-", "#2"}], "]"}], "&"}], ",", 
                RowBox[{"{", 
                 RowBox[{"trace", ",", 
                  RowBox[{"decomp", ".", "families"}]}], "}"}], ",", "1"}], 
               "]"}], "}"}]}], "\[IndentingNewLine]", "]"}]}]}], "]"}]}], 
       ")"}], "/@", "decompositions"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ConstraintsFromKnown", "[", 
     RowBox[{"defect_", ",", 
      RowBox[{"L_", ":", "L"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"vars", "=", 
         RowBox[{"Variables", "[", "defect", "]"}]}], ",", "products", ",", 
        "traces", ",", "decompositions"}], "}"}], ",", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Calculate", " ", "the", " ", "possible", " ", "fusion", " ", 
        "channels", " ", "with", " ", "the", " ", "known", " ", "defects"}], 
       " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"products", "=", 
        RowBox[{"fusionOrbit", "[", 
         RowBox[{"defect", ",", "L"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"traces", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"tr", "/@", "#"}], "&"}], "/@", "products"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"PossibleSimpleDecompositions", "/@", "traces"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{"Join", "@@@", 
         RowBox[{"MapThread", "[", 
          RowBox[{"ReduceDecompositions", ",", 
           RowBox[{"{", 
            RowBox[{
            "products", ",", " ", "traces", ",", " ", "decompositions"}], 
            "}"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Obtain", " ", "a", " ", "system", " ", "of", " ", "equations", " ", 
         "and", " ", "reduce", " ", "it"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"SortBy", "[", 
        RowBox[{
         RowBox[{"DeleteDuplicates", "[", 
          RowBox[{"Sort", "/@", 
           RowBox[{"Map", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"GroebnerBasis", "[", 
               RowBox[{"#", ",", "vars"}], "]"}], "&"}], ",", 
             "decompositions", ",", 
             RowBox[{"{", "2", "}"}]}], "]"}]}], "]"}], ",", "Length"}], 
        "]"}]}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Given", " ", "some", " ", "constraints", " ", "from", " ", "some", " ", 
     "fusion", " ", "combine", " ", "it", " ", "with", " ", "the", " ", 
     "existing", " ", "ones", " ", "or", " ", "prune", " ", "if", " ", 
     "needed"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Fuse", "[", 
      RowBox[{
      "fusion_", ",", "constraints_", ",", "vars_", ",", "invariants_", ",", 
       "varsinv_"}], "]"}], ":=", "\[IndentingNewLine]", 
     RowBox[{"Map", "[", 
      RowBox[{"First", ",", 
       RowBox[{"GatherBy", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"DeleteCases", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Flatten", "[", 
            RowBox[{
             RowBox[{"Outer", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"GroebnerBasis", "[", 
                 RowBox[{
                  RowBox[{"Join", "[", "##", "]"}], ",", "vars"}], "]"}], 
                "&"}], ",", "constraints", ",", "fusion", ",", "1", ",", 
               "1"}], "]"}], ",", "1"}], "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"{", "1", "}"}]}], "\[IndentingNewLine]", "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"GroebnerBasis", "[", 
           RowBox[{
            RowBox[{"Join", "[", 
             RowBox[{"#", ",", "invariants"}], "]"}], ",", "varsinv", ",", 
            "vars"}], "]"}], "&"}]}], "\[IndentingNewLine]", "]"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ReduceConstraints", "[", 
     RowBox[{
     "fusions_", ",", "constraints_", ",", "vars_", ",", "invariants_", ",", 
      "varsinv_"}], "]"}], ":=", " ", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"result", ",", " ", "singleFusionConstraints", ",", 
        RowBox[{"remainingFusions", "=", 
         RowBox[{"Select", "[", 
          RowBox[{"fusions", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"Length", "[", "#", "]"}], "!=", "1"}], "&"}]}], 
          "]"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"singleFusionConstraints", "=", 
        RowBox[{"GroebnerBasis", "[", 
         RowBox[{
          RowBox[{"Flatten", "@", 
           RowBox[{"Select", "[", 
            RowBox[{"fusions", ",", 
             RowBox[{
              RowBox[{
               RowBox[{"Length", "[", "#", "]"}], "==", "1"}], "&"}]}], 
            "]"}]}], ",", "vars"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"result", "=", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"GroebnerBasis", "[", 
             RowBox[{
              RowBox[{"Join", "[", 
               RowBox[{"#", ",", "singleFusionConstraints"}], "]"}], ",", 
              "vars"}], "]"}], "&"}], "/@", "constraints"}], ",", 
          RowBox[{"{", "1", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Fold", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Fuse", "[", 
           RowBox[{
           "#2", ",", "#1", ",", "vars", ",", "invariants", ",", "varsinv"}], 
           "]"}], "&"}], ",", "result", ",", "remainingFusions"}], "]"}]}]}], 
     "\[IndentingNewLine]", "]"}]}]}]}]], "Input",
