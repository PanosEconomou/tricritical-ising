             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"MatrixQ", "[", "P", "]"}], "&&", 
              RowBox[{"DiagonalMatrixQ", "[", "P", "]"}]}], ",", 
             RowBox[{"Reduce", "[", 
              RowBox[{"And", "@@", 
               RowBox[{"Flatten", "[", 
                RowBox[{"Table", "[", 
                 RowBox[{
                  RowBox[{"If", "[", 
                   RowBox[{
                    RowBox[{"i", "!=", "j"}], ",", 
                    RowBox[{
                    RowBox[{"A", "[", 
                    RowBox[{"[", 
                    RowBox[{"i", ",", "j"}], "]"}], "]"}], "==", 
                    RowBox[{"A", "[", 
                    RowBox[{"[", 
                    RowBox[{"j", ",", "i"}], "]"}], "]"}]}], ",", "Nothing"}],
                    "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"i", ",", 
                    RowBox[{"Length", "[", "A", "]"}]}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"j", ",", 
                    RowBox[{"Length", "[", "A", "]"}]}], "}"}]}], "]"}], 
                "]"}]}], "]"}], ",", "\[IndentingNewLine]", "True", ",", 
             RowBox[{"Reduce", "[", 
              RowBox[{"Thread", "[", 
