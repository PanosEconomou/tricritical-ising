                     "]"}], "&"}], "/@", "generators"}], ")"}], "==", "0"}], 
               "]"}], "]"}]}], "]"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "Lp"}], "}"}]}], "]"}]}]}], ";"}], 
