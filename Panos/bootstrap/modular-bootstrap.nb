   3.987261387812113*^9}, {3.9872614597792997`*^9, 3.9872615722578506`*^9}, {
   3.987445944283794*^9, 3.987445955439075*^9}},
 CellLabel->"In[65]:=",ExpressionUUID->"9a4377be-7060-4302-bd61-ee60ffafffdf"]
