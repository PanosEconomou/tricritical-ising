Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Given", " ", "the", " ", "action", " ", "of", " ", "a", " ", "line", " ", 
    "on", " ", "the", " ", "traces", " ", "of", " ", "the", " ", "primaries", 
    " ", "calculate", " ", "the", " ", "corresponding", " ", "twisted", " ", 
    "hilbert", " ", "space"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"TwistedSector", "[", 
      RowBox[{"s_", ",", "z_", ",", "defect_"}], "]"}], ":=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"nz", "=", 
          RowBox[{"Position", "[", 
           RowBox[{"z", ",", " ", 
            RowBox[{"_", "?", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"#", " ", "!=", "0"}], " ", "&"}], ")"}]}]}], "]"}]}], 
         ",", 
         RowBox[{"st", "=", 
          RowBox[{
           RowBox[{"ConjugateTranspose", "[", "s", "]"}], "//", "N"}]}]}], 
        "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"st", ".", " ", 
           RowBox[{"ReplacePart", "[", 
            RowBox[{"z", ",", 
             RowBox[{"Thread", "[", 
              RowBox[{"nz", "\[Rule]", "defect"}], "]"}]}], "]"}], " ", ".", 
           " ", "s"}], "//", "N"}], "//", "Chop"}], "//", "Rationalize"}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"zz", "=", 
     RowBox[{
      RowBox[{"MapWithProgress", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"TwistedSector", "[", 
          RowBox[{"s", ",", "z", ",", "#"}], "]"}], "&"}], ",", "families"}], 
       "]"}], "//", "Time"}]}], ";"}]}]}]], "Input",
