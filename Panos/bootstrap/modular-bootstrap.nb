Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Given", " ", "a", " ", "function", " ", "f", " ", "and", " ", "a", " ", 
     "group", " ", "G"}], ",", " ", 
    RowBox[{
     RowBox[{"checks", " ", "if", " ", "f", 
      RowBox[{"(", 
       RowBox[{"G", " ", "A", " ", "G"}], ")"}]}], " ", "==", " ", 
     RowBox[{"f", 
      RowBox[{"(", "A", ")"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"OuterG", "[", "G_", "]"}], ":=", 
     RowBox[{
      RowBox[{"OuterG", "[", "G", "]"}], "=", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{"Tuples", "[", 
        RowBox[{"{", 
         RowBox[{"G", ",", "G"}], "}"}], "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"CheckInvariant", "[", 
      RowBox[{"f_", ",", "A_", ",", "G_"}], "]"}], ":=", 
     RowBox[{"AllTrue", "[", 
      RowBox[{
       RowBox[{"OuterG", "[", "G", "]"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"Expand", "[", 
          RowBox[{
           RowBox[{"f", "[", "A", "]"}], "-", 
           RowBox[{"f", "[", 
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ".", "A", ".", 
             RowBox[{"#", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "]"}], "===", "0"}], 
        "&"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"CheckInvariantFast", "[", 
      RowBox[{"m_", ",", "orbitSubstitutions_"}], "]"}], ":=", 
     RowBox[{"AllTrue", "[", 
      RowBox[{"orbitSubstitutions", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"Expand", "[", 
          RowBox[{"m", "-", 
           RowBox[{"(", 
            RowBox[{"m", "/.", "#"}], ")"}]}], "]"}], "===", "0"}], "&"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"InvariantMonomialsFast", "[", 
      RowBox[{"A_", ",", "G_", ",", "upToOrder_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"InvariantMonomialsFast", "[", 
       RowBox[{"A", ",", "G", ",", "upToOrder"}], "]"}], "=", 
      RowBox[{"Module", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"vars", "=", 
           RowBox[{"Variables", "[", "A", "]"}]}], ",", 
          RowBox[{"Aflat", "=", 
           RowBox[{"Flatten", "[", "A", "]"}]}], ",", "monomials", ",", 
          "orbitSubstitutions"}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"monomials", "=", 
          RowBox[{"DeleteCases", "[", 
           RowBox[{
            RowBox[{"MonomialList", "[", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"1", "+", 
                RowBox[{"Total", "[", "vars", "]"}]}], ")"}], "upToOrder"], 
             "]"}], ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"orbitSubstitutions", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"Thread", "[", 
             RowBox[{"Aflat", "->", 
              RowBox[{"Flatten", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"#", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], ".", "A", ".", 
                RowBox[{"#", "[", 
                 RowBox[{"[", "2", "]"}], "]"}]}], ")"}], " ", "&"}], "/@", 
             " ", 
             RowBox[{"OuterG", "[", "G", "]"}]}], ")"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Sort", "[", 
          RowBox[{"Select", "[", 
           RowBox[{"monomials", ",", 
            RowBox[{
             RowBox[{"CheckInvariantFast", "[", 
              RowBox[{"#", ",", "orbitSubstitutions"}], "]"}], "&"}]}], "]"}],
           "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Obtain", " ", "symbolic", " ", "expresssions", " ", "for", " ", "a", " ",
      "generating", " ", "set", " ", "of", " ", "invariants", " ", "under", " ",
      "the", " ", "orbit", " ", "of", " ", "some", " ", "lines"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Optimization", ":", " ", 
     RowBox[{
      RowBox[{"Have", " ", "Z"}], "-", 
      RowBox[{
      "Solve", " ", "solve", " ", "the", " ", "bigger", " ", "matrix", " ", 
       "instead"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Needs", "[", "\"\<math4ti2`\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{"OrbitInvariantsSingle", ",", "OrbitInvariants"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"OrbitInvariantsSingle", "[", 
      RowBox[{"A_", ",", "G_", ",", "upToOrder_"}], "]"}], ":=", 
     RowBox[{
      RowBox[{"OrbitInvariantsSingle", "[", 
       RowBox[{"A", ",", "G", ",", "upToOrder"}], "]"}], "=", 
      RowBox[{"Module", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"vars", " ", "=", 
           RowBox[{"Variables", "[", "A", "]"}]}], ",", 
          RowBox[{"Aformal", "=", 
           RowBox[{"Array", "[", 
            RowBox[{"\[FormalA]", ",", 
             RowBox[{"Dimensions", "[", "A", "]"}]}], "]"}]}], ",", 
          RowBox[{"Aflat", "=", 
           RowBox[{"Flatten", "[", "A", "]"}]}], ",", "invariantMonomials", ",",
           "exponents", ",", "basis"}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "Calculate", " ", "a", " ", "lot", " ", "of", " ", "monomials", " ",
            "in", " ", "the", " ", "variables", " ", "of", " ", "A"}], ",", 
          " ", 
          RowBox[{
          "and", " ", "find", " ", "which", " ", "ones", " ", "are", " ", 
           "invariant", " ", "under", " ", "the", " ", "group", " ", 
           "action"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"invariantMonomials", "=", 
          RowBox[{
           RowBox[{"InvariantMonomialsFast", "[", 
            RowBox[{"Aformal", ",", "G", ",", "upToOrder"}], "]"}], "//.", 
           RowBox[{"Thread", "[", 
            RowBox[{
             RowBox[{"Flatten", "[", "Aformal", "]"}], "->", "Aflat"}], 
            "]"}]}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{
          "Solve", " ", "for", " ", "the", " ", "minimum", " ", 
           "algebraically", " ", "independent", " ", "polynomials", " ", "by",
            " ", "finding", " ", "a", " ", "Hilbert", " ", "basis", " ", "on",
            " ", "the", " ", "exponents"}], " ", "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"exponents", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"Exponent", "[", 
             RowBox[{"#", ",", " ", "vars"}], "]"}], "&"}], "/@", 
           "invariantMonomials"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"basis", "=", 
          RowBox[{
           RowBox[{"math4ti2`hilbert", "[", "exponents", "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{"Convert", " ", "Back", " ", "to", " ", "symbols"}], " ", 
          "*)"}], "\[IndentingNewLine]", 
         RowBox[{"Times", " ", "@@@", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             SuperscriptBox["vars", "#"], "&"}], "/@", "basis"}], ")"}]}]}]}],
        "\[IndentingNewLine]", "]"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"OrbitInvariants", "[", 
      RowBox[{"x_", ",", "defects_", ",", 
       RowBox[{"upToOrder_Integer", ":", "4"}]}], "]"}], ":=", 
     RowBox[{
      RowBox[{"OrbitInvariants", "[", 
       RowBox[{"x", ",", "defects", ",", "upToOrder"}], "]"}], "=", 
      RowBox[{"MapThread", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"A", ",", "G"}], "}"}], "|->", 
         RowBox[{"Which", "[", 
          RowBox[{
           RowBox[{"MatrixQ", "[", "A", "]"}], ",", 
           RowBox[{"OrbitInvariantsSingle", "[", 
            RowBox[{"A", ",", "G", ",", "upToOrder"}], "]"}], ",", "True", ",", 
           RowBox[{"{", "}"}]}], "]"}]}], "\[IndentingNewLine]", ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"Transpose", "[", "defects", "]"}]}], "}"}]}], "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]"}]}]], "Input",
