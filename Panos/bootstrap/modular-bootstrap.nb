                    RowBox[{"ConjugateTranspose", "[", "#", "]"}], ".", "A"}],
                     "]"}], "&"}], "/@", "generators"}], ")"}], "==", "0"}], 
               "]"}], "]"}]}], "]"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "Lp"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
