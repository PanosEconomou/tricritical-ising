        "Obtain", " ", "a", " ", "system", " ", "of", " ", "equations", " ", 
         "and", " ", "reduce", " ", "it"}], " ", "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"decompositions", "=", 
        RowBox[{
         RowBox[{"Simplify", "@", "Reduce"}], "/@", 
         RowBox[{"MapThread", "[", 
          RowBox[{"ReduceDecompositions", ",", 
           RowBox[{"{", 
