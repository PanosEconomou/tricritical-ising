 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"InvariantMonomialsMixed", "[", 
     RowBox[{"A_", ",", "Ac_", ",", "G_", ",", "upToOrder_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"InvariantMonomialsMixed", "[", 
      RowBox[{"A", ",", "Ac", ",", "G", ",", "upToOrder"}], "]"}], "=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vars", "=", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"Variables", "[", "A", "]"}], ",", 
            RowBox[{"Variables", "[", "Ac", "]"}]}], "]"}]}], ",", 
         RowBox[{"Aflat", "=", 
          RowBox[{"Flatten", "[", "A", "]"}]}], ",", 
         RowBox[{"Acflat", "=", 
          RowBox[{"Flatten", "[", "Ac", "]"}]}], ",", "monomials", ",", 
         "orbitSubstitutions"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"monomials", "=", 
         RowBox[{"DeleteCases", "[", 
          RowBox[{
           RowBox[{"MonomialList", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "+", 
               RowBox[{"Total", "[", "vars", "]"}]}], ")"}], "^", 
             "upToOrder"}], "]"}], ",", "1"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"orbitSubstitutions", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Thread", "[", 
            RowBox[{
             RowBox[{"Join", "[", 
              RowBox[{"Aflat", ",", "Acflat"}], "]"}], "->", 
             RowBox[{"Join", "[", 
              RowBox[{
               RowBox[{"Flatten", "[", 
                RowBox[{
                 RowBox[{"#", "[", 
                  RowBox[{"[", "1", "]"}], "]"}], ".", "A", ".", 
                 RowBox[{"#", "[", 
                  RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ",", 
               RowBox[{"Flatten", "[", 
                RowBox[{
                 RowBox[{"Conjugate", "[", 
                  RowBox[{"#", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], "]"}], ".", "Ac", ".", 
                 RowBox[{"Conjugate", "[", 
                  RowBox[{"#", "[", 
                   RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "]"}]}], "]"}]}], 
            "]"}], "&"}], "/@", 
          RowBox[{"OuterG", "[", "G", "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Sort", "[", 
         RowBox[{"Select", "[", 
          RowBox[{"monomials", ",", 
           RowBox[{
            RowBox[{"CheckInvariantFast", "[", 
             RowBox[{"#", ",", "orbitSubstitutions"}], "]"}], "&"}]}], "]"}], 
         "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"OrbitInvariantsSingleMixed", "[", 
     RowBox[{"A_", ",", "Ac_", ",", "G_", ",", "upToOrder_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"OrbitInvariantsSingleMixed", "[", 
      RowBox[{"A", ",", "Ac", ",", "G", ",", "upToOrder"}], "]"}], "=", 
     RowBox[{"Module", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vars", "=", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"Variables", "[", "A", "]"}], ",", 
            RowBox[{"Variables", "[", "Ac", "]"}]}], "]"}]}], ",", 
         RowBox[{"Aformal", "=", 
          RowBox[{"Array", "[", 
           RowBox[{"\[FormalA]", ",", 
            RowBox[{"Dimensions", "[", "A", "]"}]}], "]"}]}], ",", 
         RowBox[{"Acformal", "=", 
          RowBox[{"Array", "[", 
           RowBox[{"\[FormalB]", ",", 
            RowBox[{"Dimensions", "[", "A", "]"}]}], "]"}]}], ",", 
         "invariantMonomials", ",", "exponents", ",", "basis"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"invariantMonomials", "=", 
         RowBox[{
          RowBox[{"InvariantMonomialsMixed", "[", 
           RowBox[{"Aformal", ",", "Acformal", ",", "G", ",", "upToOrder"}], 
           "]"}], "//.", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"Thread", "[", 
             RowBox[{
              RowBox[{"Flatten", "[", "Aformal", "]"}], "->", 
              RowBox[{"Flatten", "[", "A", "]"}]}], "]"}], ",", 
            RowBox[{"Thread", "[", 
             RowBox[{
              RowBox[{"Flatten", "[", "Acformal", "]"}], "->", 
              RowBox[{"Flatten", "[", "Ac", "]"}]}], "]"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"exponents", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"Exponent", "[", 
            RowBox[{"#", ",", "vars"}], "]"}], "&"}], "/@", 
          "invariantMonomials"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"basis", "=", 
         RowBox[{
          RowBox[{"math4ti2`hilbert", "[", "exponents", "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Times", "@@@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"vars", "^", "#"}], "&"}], "/@", "basis"}], ")"}]}]}]}], 
      "\[IndentingNewLine]", "]"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 

