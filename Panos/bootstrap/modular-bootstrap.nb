Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"processInequalities", "[", 
     RowBox[{"ineqs_List", ",", "vars_List"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"c", "=", "0"}], "}"}], ",", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Function", "[", 
          RowBox[{"lhs", ",", 
           RowBox[{"With", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"coeffs", "=", 
               RowBox[{"Append", "[", 
                RowBox[{
                 RowBox[{"Table", "[", 
                  RowBox[{
                   RowBox[{"Coefficient", "[", 
                    RowBox[{"lhs", ",", "v"}], "]"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"v", ",", "vars"}], "}"}]}], "]"}], ",", 
                 RowBox[{"lhs", "/.", " ", 
                  RowBox[{"Thread", "[", 
                   RowBox[{"vars", "->", "0"}], "]"}]}]}], "]"}]}], "}"}], ",", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"AnyTrue", "[", 
                RowBox[{"coeffs", ",", 
                 RowBox[{
                  RowBox[{"!", 
                   RowBox[{"IntegerQ", "[", "#", "]"}]}], "&"}]}], "]"}], ",", 
               RowBox[{"With", "[", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"lcm", "=", 
                    RowBox[{"LCM", "@@", 
                    RowBox[{"Denominator", "/@", "coeffs"}]}]}], ",", 
                   RowBox[{"w", "=", 
                    RowBox[{"Symbol", "[", 
                    RowBox[{"\"\<w\>\"", "<>", 
                    RowBox[{"ToString", "[", 
                    RowBox[{"++", "c"}], "]"}]}], "]"}]}]}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"w", ">=", "0"}], ",", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"Expand", "[", 
                    RowBox[{"lcm", "*", "lhs"}], "]"}], "-", 
                    RowBox[{"lcm", "*", "w"}]}], "==", "0"}]}], "}"}]}], 
                "]"}], ",", 
               RowBox[{"lhs", ">=", "0"}]}], "]"}]}], "]"}]}], "]"}], "/@", 
         RowBox[{"(", 
          RowBox[{"ineqs", "[", 
           RowBox[{"[", 
