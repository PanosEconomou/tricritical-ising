     RowBox[{"GetGeneralGaugeTransform", "[", 
      RowBox[{"L_", ",", 
       RowBox[{"var_", ":", "P"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Lp", ",", "LpInvertibleQ", ",", "Lpp"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Build", " ", "a", " ", "General", " ", "Gauge", " ", 
         "Transformation"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Lp", "=", 
         RowBox[{"l", "[", "var", "]"}]}], 
        RowBox[{"(*", 
         RowBox[{"Array", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Which", "[", 
             RowBox[{
              RowBox[{"!", 
               RowBox[{"deg", "[", "#", "]"}]}], ",", "1", ",", 
              RowBox[{"deg", "[", "#", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"var", "[", 
                   RowBox[{"#", ",", "1"}], "]"}], " ", ",", 
                  RowBox[{"var", "[", 
                   RowBox[{"#", ",", "2"}], "]"}]}], " ", "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"var", "[", 
                   RowBox[{"#", ",", "3"}], "]"}], ",", 
                  RowBox[{"var", "[", 
                   RowBox[{"#", ",", "4"}], "]"}]}], "}"}]}], "}"}]}], "]"}], 
            "&"}], ",", "famNum"}], "]"}], "*)"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Lp", "=", 
         RowBox[{"(", 
          RowBox[{"Lp", " ", "//.", 
           RowBox[{"{", 
            RowBox[{"ToRules", "[", 
             RowBox[{"Reduce", "[", 
              RowBox[{
               RowBox[{"And", "@@", 
                RowBox[{"Thread", "[", 
                 RowBox[{
                  RowBox[{"Flatten", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Lp", "\[CircleTimes]", "#"}], " ", "-", 
                    RowBox[{"#", "\[CircleTimes]", "Lp"}]}], ")"}], "&"}], "/@",
                     "L"}], "]"}], "==", "0"}], "]"}]}], ",", 
               RowBox[{"Backsubstitution", "->", "True"}]}], "]"}], "]"}], 
            "}"}]}], ")"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Lpp", "=", 
         RowBox[{"Variables", "[", "Lp", "]"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Checks", " ", "if", " ", "Lp", " ", "is", " ", "invertible", " ", 
          "for", " ", "a", " ", "given", " ", "numerical", " ", "set", " ", 
          "of", " ", "P", " ", "variables"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"vars", "=", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"Unique", "[", "\"\<p\>\"", "]"}], ",", 
               RowBox[{"Length", "@", "Lpp"}]}], "]"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"invertibleLp", "=", 
             RowBox[{"And", "@@", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"Simplify", "@", 
                   RowBox[{"Not", "@", 
                    RowBox[{"Reduce", "[", 
                    RowBox[{"Or", "@@", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Which", "[", 
                    RowBox[{
                    RowBox[{"MatrixQ", "[", "#", "]"}], ",", 
                    RowBox[{
                    RowBox[{"Det", "[", "#", "]"}], "==", "0"}], ",", "True", 
                    ",", 
                    RowBox[{"#", "==", "0"}]}], "]"}], "&"}], "/@", "#"}], 
                    ")"}]}], "]"}]}]}], ")"}], "&"}], "/@", "Lp"}], 
               ")"}]}]}]}], "\[IndentingNewLine]", "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"invertibleLp", "=", 
            RowBox[{"invertibleLp", "/.", 
             RowBox[{"Thread", "[", 
              RowBox[{"Lpp", "->", "vars"}], "]"}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"LpInvertibleQ", ":=", 
            RowBox[{"Function", "@@", 
             RowBox[{"{", 
              RowBox[{"vars", ",", 
               RowBox[{"Simplify", "[", 
                RowBox[{"Evaluate", "[", "invertibleLp", "]"}], "]"}]}], 
              "}"}]}]}]}]}], "\[IndentingNewLine]", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"Lp", ",", "Lpp", ",", "LpInvertibleQ"}], "}"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Lp", ",", "Lpp", ",", "LpInvertibleQ"}], "}"}], "=", 
